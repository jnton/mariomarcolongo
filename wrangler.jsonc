{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "mariomarcolongo",
  "compatibility_date": "2026-07-14",
  "main": "src/_worker.js",
  "assets": {
    "directory": "./dist",
    "binding": "ASSETS",
    "html_handling": "drop-trailing-slash",
    "not_found_handling": "404-page"
  }
}