       ======================================== -->
  <script is:inline src="/data/source.js"></script>
  <script is:inline>
    const D = window.MARIO_DOSSIER || {};

    // ---- SCROLL REVEAL ----
    const revealObserver = new IntersectionObserver((entries) => {
      entries.forEach(entry => {
        if (entry.isIntersecting) {
          entry.target.classList.add('visible');
          revealObserver.unobserve(entry.target);
        }
      });
    }, { threshold: 0.1, rootMargin: '0px 0px -40px 0px' });

    document.querySelectorAll('.reveal').forEach(el => revealObserver.observe(el));

    // ---- NAV SCROLL & ACTIVE SECTION HIGHLIGHTING ----
    const nav = document.getElementById('siteNav');
    const navLinks = document.querySelectorAll('.nav-link[href^="#"]');
    const sectionIds = Array.from(navLinks).map(link => link.getAttribute('href').substring(1));
    const sections = sectionIds.map(id => document.getElementById(id)).filter(Boolean);
    const scrollProgressEl = document.getElementById('scrollProgress');
    const supportsScrollTimeline = CSS.supports('animation-timeline', 'scroll()');

    window.addEventListener('scroll', () => {
      const scrollY = window.scrollY;
      if (nav) nav.classList.toggle('scrolled', scrollY > 40);

      // Scroll Progress bar JS fallback for non-supporting browsers
      if (!supportsScrollTimeline && scrollProgressEl) {
        const scrollable = document.documentElement.scrollHeight - window.innerHeight;
        const progress = scrollable > 0 ? (scrollY / scrollable) : 0;
        scrollProgressEl.style.transform = `scaleX(${progress})`;
      }

      // Highlight active navigation section
      let currentSectionId = '';
      const triggerY = scrollY + 140;
      sections.forEach(sec => {
        if (sec.offsetTop <= triggerY && sec.offsetTop + sec.offsetHeight > triggerY) {
          currentSectionId = sec.getAttribute('id');
        }
      });

      navLinks.forEach(link => {
        const targetId = link.getAttribute('href').substring(1);
        link.classList.toggle('active', targetId === currentSectionId && currentSectionId !== '');
      });
    }, { passive: true });

    // ---- VISUALIZATION TABS ----
    function showViz(index, btn) {
      const viz = D.visualizations && D.visualizations[index];
      if (!viz) return;

      const img = document.getElementById('vizImg');
      const cap = document.getElementById('vizCaption');
      const lnk = document.getElementById('vizLink');
      if (img) {
        img.src = viz.src;
        img.alt = viz.title;
      }
      if (cap) cap.textContent = viz.caption;
      if (lnk) lnk.href = viz.fileUrl;

      if (btn) {
        document.querySelectorAll('.viz-tab').forEach(t => t.classList.remove('active'));
        btn.classList.add('active');
      }
    }

    // ---- WIKIMEDIA BREAKDOWN BARS ANIMATION ----
    function initWikiBreakdown() {
      const breakdown = document.getElementById('wikiBreakdown');
      if (!breakdown) return;

      const barObserver = new IntersectionObserver((entries) => {
        entries.forEach(entry => {
          if (entry.isIntersecting) {
            entry.target.querySelectorAll('.wiki-bar-fill').forEach(bar => {
              bar.style.width = bar.dataset.width;
            });
            barObserver.unobserve(entry.target);
          }
        });
      }, { threshold: 0.3 });

      breakdown.querySelectorAll('.wiki-bar-fill').forEach(bar => {
        bar.style.width = '0%';
      });
      barObserver.observe(breakdown);
    }

    // ---- INTERACTIVE CITATION SYSTEM ("VERIFIED, NOT ASSERTED") ----
    const CITATIONS = {
      edits: {
        text: "1,592 English Wikipedia edits, 752 Italian Wikipedia edits, 1,249 on Wikidata, 684 on Wikimedia Commons — 4,317 total publicly inspectable contributions under one CentralAuth identity.",
        href: "https://commons.wikimedia.org/wiki/Special:CentralAuth/Digressivo",
        label: "Wikimedia CentralAuth Public Record ↗"
      },
      ena: {
        text: "Designed and iteratively validated a local downstream bioinformatics workflow transforming VCF datasets to Plink2 format and running Nextflow pgsc_calc with ancestry projection against reference panels, along with custom Python VEP extraction scripts under ENA Accession PRJEB109744 (personal genomics workflow and open-data pipeline published on GitHub: jnton/git-nome).",
        href: "https://www.ebi.ac.uk/ena/browser/view/PRJEB109744",
        label: "ENA Accession PRJEB109744 & Pipeline Repository ↗"
      },
      registry: {
        text: "Founder & architect of Yourself to Science™ — an open-source research-participation directory indexing 55+ research studies across genomes, clinical trials, and bio-donations, cited across 37 Wikidata entities (P854).",
        href: "https://yourselftoscience.org",
        label: "yourselftoscience.org ↗"
      },
      book: {
        text: "Giacomo Moro Mauretto's 'Italiani Veri', published by Mondadori in April 2025 — official acknowledgment published on the final page.",
        href: "https://www.mondadori.it/libri/italiani-veri-giacomo-moro-mauretto/",
        label: "Italiani Veri — Mondadori ↗"
      },
      grayswan: {
        text: "Ranked in the top 8% among ranked Gray Swan Proving Ground participants as of July 2026 — 75 platform-confirmed model breaks across chat, image, agentic tool-use and indirect prompt-injection challenges.",
        href: "https://app.grayswan.ai/arena/user/6a57be70d15e123775a1e9cf",
        label: "Gray Swan Proving Ground Profile ↗"
      },
      agentready: {
        text: "Agent-discovery and machine-readable endpoints implemented; live audit to be rerun after deployment (including live A2A Agent Card, DNS-AID, and llms.txt).",
        href: "https://isitagentready.com/mariomarcolongo.com?checks=robotsTxt%2Csitemap%2ClinkHeaders%2CdnsAid%2CmarkdownNegotiation%2CrobotsTxtAiRules%2CcontentSignals%2CwebBotAuth%2CapiCatalog%2CoauthDiscovery%2CoauthProtectedResource%2CauthMd%2CmcpServerCard%2Ca2aAgentCard%2CagentSkills%2CwebMcp%2Cx402%2Cmpp%2Cucp%2Cacp",
        label: "Live Agent-Readiness Audit Status ↗"
      }
    };

    let activePopover = null;

    function initCitations() {
      document.querySelectorAll('.cite-btn').forEach(btn => {
        btn.addEventListener('click', (e) => {
          e.preventDefault();
          e.stopPropagation();
          const key = btn.dataset.cite;
          if (activePopover && activePopover.key === key) {
            closePopover();
            return;
          }
          openPopover(btn, CITATIONS[key], key);
        });
      });

      document.addEventListener('click', closePopover);
      document.addEventListener('keydown', (e) => { if (e.key === 'Escape') closePopover(); });
      window.addEventListener('scroll', closePopover, { passive: true });
    }

    function openPopover(btn, data, key) {
      closePopover();
      if (!data) return;
      const pop = document.createElement('div');
      pop.className = 'cite-popover';
      pop.setAttribute('role', 'tooltip');
      pop.innerHTML = `<p>${data.text}</p><a href="${data.href}" target="_blank" rel="noopener noreferrer">${data.label}</a>`;
      pop.addEventListener('click', (e) => e.stopPropagation());
      document.body.appendChild(pop);

      const rect = btn.getBoundingClientRect();
      const popRect = pop.getBoundingClientRect();
      let left = rect.left + window.scrollX - popRect.width / 2 + rect.width / 2;
      left = Math.max(16, Math.min(left, window.innerWidth - popRect.width - 16));
      const top = rect.bottom + window.scrollY + 10;
      pop.style.left = left + 'px';
      pop.style.top = top + 'px';

      btn.setAttribute('aria-expanded', 'true');
      activePopover = { el: pop, key, btn };
    }

    function closePopover() {
      if (activePopover) {
        activePopover.el.remove();
        activePopover.btn.setAttribute('aria-expanded', 'false');
        activePopover = null;
      }
    }

    // Cryptographically secure pseudorandom number generator for visual coordinate initialization
    function getPseudoRand() {
      if (typeof window !== 'undefined' && window.crypto && window.crypto.getRandomValues) {
        const arr = new Uint32Array(1);
        window.crypto.getRandomValues(arr);
        return arr[0] / 4294967296;
      }
      return 0.5;
    }

    // ---- NODE NETWORK VISUALIZATION (Emergent Humanity Interactive Simulation) ----
    function initNodeNetwork() {
      const canvas = document.getElementById('nodeCanvas');
      if (!canvas) return;
      const ctx = canvas.getContext('2d');
      const reduceMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

      let mouse = { x: null, y: null, active: false };
      let draggedNode = null;
      let pulses = [];

      function resizeCanvas() {
        const rect = canvas.parentElement.getBoundingClientRect();
        canvas.width = rect.width * 2;
        canvas.height = rect.height * 2;
        ctx.setTransform(2, 0, 0, 2, 0, 0);
      }

      const NODE_COUNT = 18;
      let nodes = [];

      function initNodes() {
        const rect = canvas.parentElement.getBoundingClientRect();
        nodes = Array.from({ length: NODE_COUNT }, () => ({
          x: getPseudoRand() * rect.width,
          y: getPseudoRand() * rect.height,
          vx: (getPseudoRand() - 0.5) * 0.22,
          vy: (getPseudoRand() - 0.5) * 0.22,
          r: 2.8 + getPseudoRand() * 2.2,
          signal: 0
        }));
      }

      canvas.addEventListener('mousemove', (e) => {
        const rect = canvas.getBoundingClientRect();
        mouse.x = e.clientX - rect.left;
        mouse.y = e.clientY - rect.top;
        mouse.active = true;

        if (draggedNode) {
          draggedNode.x = mouse.x;
          draggedNode.y = mouse.y;
          canvas.style.cursor = 'grabbing';
        } else {
          const hovered = nodes.some(n => Math.hypot(n.x - mouse.x, n.y - mouse.y) < 14);
          canvas.style.cursor = hovered ? 'pointer' : 'default';
        }
      });

      canvas.addEventListener('mouseleave', () => {
        mouse.active = false;
        draggedNode = null;
        canvas.style.cursor = 'default';
      });

      canvas.addEventListener('mousedown', (e) => {
        const rect = canvas.getBoundingClientRect();
        const mx = e.clientX - rect.left;
        const my = e.clientY - rect.top;
        const target = nodes.find(n => Math.hypot(n.x - mx, n.y - my) < 16);
        if (target) {
          draggedNode = target;
          target.signal = 1;
        }
      });

      canvas.addEventListener('mouseup', () => {
        draggedNode = null;
      });

      canvas.addEventListener('click', (e) => {
        const rect = canvas.getBoundingClientRect();
        const mx = e.clientX - rect.left;
        const my = e.clientY - rect.top;
        pulses.push({ x: mx, y: my, radius: 0, maxRadius: Math.max(rect.width, rect.height) * 0.75 });
      });

      function stepPulses() {
        pulses = pulses.filter(p => p.radius < p.maxRadius);
        pulses.forEach(p => {
          p.radius += 3.5;
          ctx.strokeStyle = `rgba(245, 158, 11, ${0.45 * (1 - p.radius / p.maxRadius)})`;
          ctx.lineWidth = 1.5;
          ctx.beginPath();
          ctx.arc(p.x, p.y, p.radius, 0, Math.PI * 2);
          ctx.stroke();

          nodes.forEach(n => {
            if (Math.abs(Math.hypot(n.x - p.x, n.y - p.y) - p.radius) < 10) {
              n.signal = 1;
            }
          });
        });
      }

      function stepNodes(rect) {
        if (reduceMotion) return;
        nodes.forEach(n => {
          if (n !== draggedNode) {
            n.x += n.vx;
            n.y += n.vy;
            if (n.x < 0 || n.x > rect.width) n.vx *= -1;
            if (n.y < 0 || n.y > rect.height) n.vy *= -1;
          }
          if (n.signal > 0) n.signal = Math.max(0, n.signal - 0.02);
        });
      }

      function renderConnections(rect) {
        for (let i = 0; i < nodes.length; i++) {
          for (let j = i + 1; j < nodes.length; j++) {
            const a = nodes[i], b = nodes[j];
            const d = Math.hypot(a.x - b.x, a.y - b.y);
            const maxD = rect.width * 0.38;
            if (d < maxD) {
              const alpha = 0.65 * (1 - d / maxD);
              const isSignal = a.signal > 0.2 || b.signal > 0.2;
              ctx.strokeStyle = isSignal
                ? `rgba(245, 158, 11, ${Math.min(1, alpha * 2)})`
                : `rgba(154, 91, 19, ${alpha})`;
              ctx.lineWidth = isSignal ? 1.5 : 1;
              ctx.beginPath();
              ctx.moveTo(a.x, a.y);
              ctx.lineTo(b.x, b.y);
              ctx.stroke();
            }
          }
        }
      }

      function renderMouseBridge(rect) {
        if (!mouse.active || mouse.x === null) return;
        nodes.forEach(n => {
          const d = Math.hypot(n.x - mouse.x, n.y - mouse.y);
          const maxD = rect.width * 0.32;
          if (d < maxD) {
            ctx.strokeStyle = `rgba(245, 158, 11, ${0.75 * (1 - d / maxD)})`;
            ctx.lineWidth = 1.2;
            ctx.beginPath();
            ctx.moveTo(mouse.x, mouse.y);
            ctx.lineTo(n.x, n.y);
            ctx.stroke();
          }
        });
      }

      function renderNodes() {
        nodes.forEach(n => {
          ctx.fillStyle = n.signal > 0.1 ? '#F59E0B' : '#EFEEE6';
          ctx.beginPath();
          ctx.arc(n.x, n.y, n.r + (n.signal * 2), 0, Math.PI * 2);
          ctx.fill();
        });
      }

      function drawFrame() {
        const rect = canvas.parentElement.getBoundingClientRect();
        ctx.clearRect(0, 0, rect.width, rect.height);
        stepPulses();
        stepNodes(rect);
        renderConnections(rect);
        renderMouseBridge(rect);
        renderNodes();
        if (!reduceMotion) requestAnimationFrame(drawFrame);
      }

      function setup() {
        resizeCanvas();
        initNodes();
        drawFrame();
      }

      setup();
      window.addEventListener('resize', () => {
        ctx.setTransform(1, 0, 0, 1, 0, 0);
        setup();
      });
    }

    // ---- INIT ----
    document.addEventListener('DOMContentLoaded', () => {
      initCitations();
      initWikiBreakdown();
      initNodeNetwork();
    });

  </script>
