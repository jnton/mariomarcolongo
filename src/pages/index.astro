        <p class="section-desc">Open to high-impact projects, AI research teams, and global opportunities.</p>
      </div>

      <div class="contact-grid reveal">
        <div class="contact-row">
          <span class="contact-label">Email</span>
          <span class="contact-value"><a href="mailto:me@mariomarcolongo.com" id="contactEmail">me@mariomarcolongo.com</a></span>
        </div>
        <div class="contact-row">
          <span class="contact-label">LinkedIn</span>
          <span class="contact-value"><a href="https://www.linkedin.com/in/mario-marcolongo" target="_blank" rel="noopener noreferrer" id="contactLinkedin">linkedin.com/in/mario-marcolongo ↗</a></span>
        </div>
        <div class="contact-row">
          <span class="contact-label">ORCID</span>
          <span class="contact-value"><a href="https://orcid.org/0000-0003-2846-7115" target="_blank" rel="noopener noreferrer">0000-0003-2846-7115 ↗</a></span>
        </div>
        <div class="contact-row">
          <span class="contact-label">GitHub</span>
          <span class="contact-value"><a href="https://github.com/jnton" target="_blank" rel="noopener noreferrer" id="contactGithub">github.com/jnton ↗</a></span>
        </div>
      </div>

      <div class="reveal contact-cv-action">
        <a href="cv.html" class="btn btn-primary">View Comprehensive Profile & CV →</a>
      </div>
    </div>
  </section>

  <!-- ========================================
       FOOTER
       ======================================== -->
  <footer class="site-footer">
    <div class="container">
      <div class="footer-content">
        <span class="footer-text">© 2026 Mario Marcolongo · Built Open-Source</span>
        <div class="footer-links">
          <a href="llms-full.txt" target="_blank" rel="noopener noreferrer">llms.txt</a>
          <a href="sitemap.xml" target="_blank" rel="noopener noreferrer">Sitemap</a>
          <a href="https://github.com/jnton" target="_blank" rel="noopener noreferrer">GitHub</a>
        </div>
      </div>
    </div>
  </footer>

  <!-- ========================================
       SCRIPTS
       ======================================== -->
  <script is:inline>
    const D = window.MARIO_DOSSIER || {};

    // ---- SCROLL REVEAL ----
    const revealObserver = new IntersectionObserver((entries) => {
      entries.forEach(entry => {
        if (entry.isIntersecting) {
          entry.target.classList.add('visible');
          revealObserver.unobserve(entry.target);
        }
      });
    }, { threshold: 0.1, rootMargin: '0px 0px -40px 0px' });

    document.querySelectorAll('.reveal').forEach(el => revealObserver.observe(el));

    // ---- NAV SCROLL & ACTIVE SECTION HIGHLIGHTING ----
    const nav = document.getElementById('mainNav');
    const navLinks = document.querySelectorAll('.nav-link[href^="#"]');
    const sectionIds = Array.from(navLinks).map(link => link.getAttribute('href').substring(1));
    const sections = sectionIds.map(id => document.getElementById(id)).filter(Boolean);
    const scrollProgressEl = document.getElementById('scrollProgress');
    const supportsScrollTimeline = CSS.supports('animation-timeline', 'scroll()');

    window.addEventListener('scroll', () => {
      const scrollY = window.scrollY;
      if (nav) nav.classList.toggle('scrolled', scrollY > 40);

      // Scroll Progress bar JS fallback for non-supporting browsers
      if (!supportsScrollTimeline && scrollProgressEl) {
        const scrollable = document.documentElement.scrollHeight - window.innerHeight;
        const progress = scrollable > 0 ? (scrollY / scrollable) : 0;
        scrollProgressEl.style.transform = `scaleX(${progress})`;
      }

      // Highlight active navigation section
      let currentSectionId = '';
      const triggerY = scrollY + 140;
      sections.forEach(sec => {
        if (sec.offsetTop <= triggerY && sec.offsetTop + sec.offsetHeight > triggerY) {
          currentSectionId = sec.getAttribute('id');
        }
      });

      navLinks.forEach(link => {
        const targetId = link.getAttribute('href').substring(1);
        link.classList.toggle('active', targetId === currentSectionId && currentSectionId !== '');
      });
    }, { passive: true });

    // ---- THEME ----
    function toggleTheme() {
      const html = document.documentElement;
      const current = html.getAttribute('data-theme');
      const next = current === 'dark' ? 'light' : 'dark';
      html.setAttribute('data-theme', next);
      document.getElementById('themeBtn').textContent = next === 'dark' ? '☾' : '☀';
      try { localStorage.setItem('mm-theme', next); } catch(e) {}
    }

    // Restore saved theme
    try {
      const saved = localStorage.getItem('mm-theme');
      if (saved) {
        document.documentElement.setAttribute('data-theme', saved);
        document.getElementById('themeBtn').textContent = saved === 'dark' ? '☾' : '☀';
      }
    } catch(e) {}

    // ---- HYDRATE PILLARS ----
    function hydratePillars() {
      const grid = document.getElementById('pillarGrid');
      if (!D.pillars || !grid) return;

      grid.innerHTML = D.pillars.map(p => `
        <div class="pillar reveal">
          <div class="pillar-header">
            <div class="pillar-icon-box" aria-hidden="true">${p.icon}</div>
            ${p.category ? `<span class="pillar-category">${p.category}</span>` : ''}
          </div>
          <h3 class="pillar-title">${p.title}</h3>
          <p class="pillar-lead">${p.lead || p.desc}</p>
          ${p.highlights ? `
            <div class="pillar-highlights">
              ${p.highlights.map(h => `
                <div class="pillar-highlight-item">
                  <span class="pillar-highlight-dot"></span>
                  <div class="pillar-highlight-text">
                    <strong>${h.label}:</strong> ${h.detail}
                  </div>
                </div>
              `).join('')}
            </div>
          ` : ''}
        </div>
      `).join('');

      grid.querySelectorAll('.reveal').forEach(el => revealObserver.observe(el));
    }

    // ---- HYDRATE PROJECTS ----
    function hydrateProjects() {
      const list = document.getElementById('projectList');
      if (!D.projects || !list) return;

      list.innerHTML = D.projects.map((p, i) => {
        const visual = buildProjectVisual(p, i);
        const links = buildProjectLinks(p);
        const highlights = p.highlights ? p.highlights.map(h => `<li>${h}</li>`).join('') : '';
        const isEven = i % 2 === 0;

        return `
          <article class="project-card reveal" style="${!isEven ? 'direction: rtl;' : ''}">
            <div class="project-info" style="direction: ltr;">
              <div class="project-tag">${p.role}</div>
              <h3 class="project-title">${p.title}</h3>
              <p class="project-one-liner">${p.oneLiner}</p>
              ${highlights ? `<ul class="project-highlights">${highlights}</ul>` : ''}
              <div class="project-links">${links}</div>
            </div>
            <div class="project-visual" style="direction: ltr;">
              ${visual}
            </div>
          </article>
        `;
      }).join('');

      list.querySelectorAll('.reveal').forEach(el => revealObserver.observe(el));
    }

    function buildProjectVisual(p, i) {
      if (p.id === 'mdpi-filter' && p.links && p.links.screenshots && p.links.screenshots[0]) {
        return `<img src="${p.links.screenshots[0]}" alt="${p.title} screenshot" loading="lazy">`;
      }
      if (p.id === 'telegram-bot') {
        return `
          <div class="telegram-mock">
            <div class="tg-header">
              <div class="tg-avatar">
                <img src="telegram-bot-icon.svg" alt="Wikipedia Link Converter Bot Icon" style="width: 100%; height: 100%; object-fit: contain;">
              </div>
              <div>
                <div class="tg-name">Wikipedia Link Converter</div>
                <div class="tg-status">serverless bot</div>
              </div>
            </div>
            <div class="tg-body">
              <div class="tg-bubble-out">
                <span class="tg-link">https://it.wikipedia.org/wiki/Bianco_e_nero</span>
              </div>
              <div class="tg-bubble-in">
                English canonical page resolved for <strong>Bianco e nero</strong>:<br>
                <span class="tg-link">https://en.wikipedia.org/wiki/Black_and_white</span>
              </div>
            </div>
          </div>
        `;
      }
      if (p.id === 'referendum-map') {
        return `<img src="referendum-turnout-threshold-by-country.svg" alt="Referendum Turnout Threshold World Map" loading="lazy" style="object-fit: contain; padding: 20px;">`;
      }
      if (p.id === 'entropy-for-life') {
        return `
          <div class="mock-visual-box" style="padding: 36px 28px; width: 100%; height: 100%; display: flex; flex-direction: column; justify-content: center; align-items: center; gap: 26px;">
            <!-- Channel Header -->
            <div style="display: flex; flex-direction: column; align-items: center; gap: 12px;">
              <div style="width: 68px; height: 68px; border-radius: 20px; background: linear-gradient(135deg, #F43F5E, #BE123C); display: flex; align-items: center; justify-content: center; font-size: 30px; color: #FFF; box-shadow: 0 8px 26px rgba(225,29,72,0.35);">▶</div>
              <div>
                <div style="font-family: var(--font-display); font-size: 24px; font-weight: 800; color: var(--ink); letter-spacing: -0.02em;">@EntropyforLife</div>
                <div style="font-size: 13px; color: var(--ink-soft); font-weight: 500; margin-top: 2px;">Giacomo Moro Mauretto · Evolutionary Biology</div>
              </div>
            </div>

            <!-- Hero Community Metric -->
            <div style="display: flex; flex-direction: column; align-items: center;">
              <div style="font-family: var(--font-display); font-size: 46px; font-weight: 900; color: var(--ink); line-height: 1; letter-spacing: -0.03em;">480,000+</div>
              <div style="font-size: 12px; font-weight: 700; color: var(--accent); text-transform: uppercase; letter-spacing: 0.08em; margin-top: 6px;">Total Cross-Platform Community</div>
            </div>

            <!-- 3 Key Metric Cards Grid -->
            <div style="display: grid; grid-template-columns: repeat(3, 1fr); gap: 12px; width: 100%; max-width: 440px;">
              <div style="background: var(--bg-surface); border: 1px solid var(--line); border-radius: 14px; padding: 14px 10px; text-align: center; box-shadow: var(--shadow);">
                <div style="font-family: var(--font-display); font-size: 20px; font-weight: 800; color: var(--ink);">266K+</div>
                <div style="font-size: 11px; color: var(--ink-soft); font-weight: 600; margin-top: 3px;">YouTube Subs</div>
