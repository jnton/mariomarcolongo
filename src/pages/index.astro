---
import Layout from "../layouts/Layout.astro";
import SiteNav from "../components/SiteNav.astro";
import SiteFooter from "../components/SiteFooter.astro";
import "../styles/portfolio-human-v2.css";
import D from "../../data/source.js";
import H from "../../data/portfolio-human.js";
import { buildProfileGraph } from "../lib/structured-data.js";

const pageTitle = "Mario Marcolongo — Scientific Verification, AI Evaluation & Operations";
const pageDescription = "Scientific verification, AI model-behavior evaluation, research operations, public-interest products and data visualization.";
const profileJsonLd = buildProfileGraph(D, "https://mariomarcolongo.com/", pageTitle);

const selectedExperience = [
  D.experience.find((item) => item.org?.includes("Entropy for Life")),
  D.experience.find((item) => item.role?.includes("Model-Behavior")),
  D.experience.find((item) => item.org?.includes("Yourself to Science")),
  D.experience.find((item) => item.role?.includes("Focus-Group")),
  D.experience.find((item) => item.org?.includes("Wikipedia"))
].filter(Boolean);

const mainProject = H.heroProjects[0];
const secondaryProjects = H.heroProjects.slice(1);
---

<Layout title={pageTitle} description={pageDescription} canonical="https://mariomarcolongo.com/">
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(profileJsonLd)}></script>
  </Fragment>

  <SiteNav activePage="home" />

  <main class="portfolio-v4" id="content">
    <section class="pv4-hero" aria-labelledby="portfolio-title">
      <div class="pv4-hero-copy">
        <div class="pv4-eyebrow">{H.eyebrow}</div>
        <h1 id="portfolio-title">I work on difficult problems where <em>evidence</em>, systems and human judgment meet.</h1>
        <p class="pv4-intro">{H.introduction}</p>
        <div class="pv4-actions">
          <a class="pv4-button pv4-button-primary" href="#work">See the evidence <span aria-hidden="true">↓</span></a>
          <a class="pv4-button" href="#products">Explore shipped products</a>
          <a class="pv4-button" href="#fit">Choose a targeted CV</a>
        </div>
        <div class="pv4-facts" aria-label="Location and working information">
          <span>Based in Italy</span>
          <span>EU work authorization</span>
          <span>Open to worldwide relocation</span>
          <span>International B2B contracting</span>
        </div>
      </div>

      <div class="pv4-stage" aria-label="Selected public products and data work">
        <span class="pv4-stage-label">Public work, not decorative imagery</span>
        <figure class="pv4-stage-main">
          <img src={mainProject.image} alt={mainProject.imageAlt} width="1280" height="800" loading="eager" decoding="async" />
          <figcaption>
            <span><strong>{mainProject.title}</strong> · {mainProject.label}</span>
            <a href={mainProject.href} target="_blank" rel="noopener noreferrer">Open ↗</a>
          </figcaption>
        </figure>
        <div class="pv4-stage-thumbs">
          {secondaryProjects.map((project) => (
            <a class="pv4-stage-thumb" href={project.href} target="_blank" rel="noopener noreferrer">
              <img src={project.image} alt={project.imageAlt} width="640" height="360" loading="eager" decoding="async" />
              <span><strong>{project.title}</strong><br />{project.label}</span>
            </a>
          ))}
        </div>
      </div>
    </section>

    <section class="pv4-proof" aria-label="Selected public proof">
      {H.proofMetrics.map((metric) => (
        <a class="pv4-proof-card" href={metric.source} target={metric.source.startsWith("http") ? "_blank" : undefined} rel={metric.source.startsWith("http") ? "noopener noreferrer" : undefined}>
          <strong>{metric.value}</strong>
          <span>{metric.label}</span>
          <small>{metric.detail}</small>
        </a>
      ))}
    </section>

    <section class="pv4-section" id="work" aria-labelledby="work-title" data-testid="human-work">
      <div class="pv4-section-head">
        <div>
          <span class="pv4-section-index">01 · Selected outcomes</span>
          <h2 id="work-title">Scale, failure modes, systems and evidence.</h2>
        </div>
        <p>The homepage now prioritizes paid work, public reach, shipped tools and role-relevant outcomes. Smaller or more unusual records remain available, but they no longer lead the story.</p>
      </div>

      <div class="pv4-stories" data-testid="human-capabilities">
        {H.stories.map((story) => (
          <article class={`pv4-story pv4-story-${story.id}`}>
            <div class="pv4-story-visual">
              {story.visual === "audience" ? (
                <div class="pv4-audience" role="img" aria-label="Entropy for Life audience: more than 250,000 YouTube subscribers, 158,000 Instagram followers and 54,000 TikTok followers">
                  <span class="pv4-stage-label">Audience of the science-communication project I support</span>
                  <div class="pv4-audience-main">
                    <strong>250K+</strong>
                    <span>YouTube subscribers</span>
                  </div>
                  <div class="pv4-audience-secondary">
                    <div><strong>158K</strong><span>Instagram followers</span></div>
                    <div><strong>54K</strong><span>TikTok followers</span></div>
                  </div>
                </div>
              ) : (
                <figure class="pv4-story-frame">
                  <img src={story.image} alt={story.imageAlt} width="1440" height="900" loading="lazy" decoding="async" />
                  <span class="pv4-story-number" aria-hidden="true">{story.number}</span>
                </figure>
              )}
            </div>

            <div class="pv4-story-copy">
              <span class="pv4-story-label">{story.number} · {story.label}</span>
              <h3>{story.title}</h3>
              <p class="pv4-story-summary">{story.summary}</p>
              <div class="pv4-story-role"><strong>My role:</strong> {story.role}</div>
              <ul>{story.process.map((step) => <li>{step}</li>)}</ul>
              <div class="pv4-story-result"><strong>Outcome:</strong> {story.result}</div>
              <a class="pv4-story-link" href={story.href} target={story.href.startsWith("http") ? "_blank" : undefined} rel={story.href.startsWith("http") ? "noopener noreferrer" : undefined}>{story.linkLabel} →</a>
            </div>
          </article>
        ))}
      </div>
    </section>

    <section class="pv4-section" id="products" aria-labelledby="products-title">
      <div class="pv4-section-head">
        <div>
          <span class="pv4-section-index">02 · Products and systems</span>
          <h2 id="products-title">Small tools that solve real problems.</h2>
        </div>
        <p>These projects demonstrate requirements definition, behavioral testing, deployment diagnosis and operational maintenance—not a claim of unaided software engineering.</p>
      </div>

      <div class="pv4-products">
        {H.products.map((product) => (
          <article class="pv4-product">
            <div class="pv4-product-copy">
              <span class="pv4-product-label">{product.label}</span>
              <h3>{product.title}</h3>
              <p>{product.body}</p>
              <a class="pv4-product-link" href={product.href} target="_blank" rel="noopener noreferrer">{product.linkLabel} →</a>
            </div>
            <img src={product.image} alt={product.imageAlt} width="900" height="650" loading="lazy" decoding="async" />
          </article>
        ))}
      </div>
    </section>

    <section class="pv4-section" id="visuals" aria-labelledby="visuals-title">
      <div class="pv4-section-head">
        <div>
          <span class="pv4-section-index">03 · Data visualization</span>
          <h2 id="visuals-title">Interactive analysis and public visual explanation.</h2>
        </div>
        <p>The portfolio now shows Tableau and Flourish alongside the openly licensed Wikimedia work, rather than implying that one SVG represents the entire visualization practice.</p>
      </div>

      <div class="pv4-platforms">
        {H.visualizationPlatforms.map((platform) => (
          <article class="pv4-platform">
            <div class="pv4-platform-media">
              <img src={platform.image} alt={platform.imageAlt} width="1440" height="900" loading="lazy" decoding="async" />
            </div>
            <div class="pv4-platform-copy">
              <span class="pv4-platform-label">{platform.label}</span>
              <h3>{platform.title}</h3>
              <p>{platform.body}</p>
              <a class="pv4-platform-link" href={platform.href} target="_blank" rel="noopener noreferrer">{platform.linkLabel} →</a>
            </div>
          </article>
        ))}
      </div>

      <div class="pv4-gallery-shell">
        <div class="pv4-gallery-head">
          <h3>Selected open visualizations</h3>
          <div class="pv4-gallery-controls" aria-label="Visualization gallery controls">
            <button class="pv4-gallery-control" type="button" data-gallery-prev aria-label="Previous visualization">←</button>
            <button class="pv4-gallery-control" type="button" data-gallery-next aria-label="Next visualization">→</button>
          </div>
        </div>
        <div class="pv4-gallery-track" data-gallery-track tabindex="0">
          {D.visualizations.map((item) => (
            <figure class="pv4-gallery-item">
              <img src={item.src} alt={item.title} width="1000" height="650" loading="lazy" decoding="async" />
              <figcaption>
                <strong>{item.title}</strong>
                <p>{item.caption}</p>
                <a href={item.fileUrl} target="_blank" rel="noopener noreferrer">Open the source ↗</a>
              </figcaption>
            </figure>
          ))}
        </div>
      </div>
    </section>

    <section class="pv4-working-style" id="working-style" aria-labelledby="working-style-title">
      <div class="pv4-section-head">
        <div>
          <span class="pv4-section-index">04 · Operating style</span>
          <h2 id="working-style-title">Useful when the problem is strange, ambiguous or uncomfortable.</h2>
        </div>
        <p>This is the credible signal for unconventional, high-autonomy employers: how I approach difficult work—not a theatrical personality label.</p>
      </div>
      <div class="pv4-style-grid">
        {H.operatingStyle.map((item) => (
          <article class="pv4-style-card">
            <h3>{item.title}</h3>
            <p>{item.body}</p>
          </article>
        ))}
      </div>
    </section>

    <section class="pv4-section" id="experience" aria-labelledby="experience-title">
      <div class="pv4-section-head">
        <div>
          <span class="pv4-section-index">05 · Experience</span>
          <h2 id="experience-title">Different settings, the same pattern of ownership.</h2>
        </div>
        <p>Paid work, independent products, public contribution records and volunteer research are labelled separately rather than made to look equivalent.</p>
      </div>
      <div class="pv4-experience-grid">
        {selectedExperience.map((item) => (
          <>
            <div class="pv4-experience-period">{item.period}</div>
            <article class="pv4-experience-copy">
              <h3>{item.role}</h3>
              <p><strong>{item.org}</strong> · {item.tag}. {item.resumeBullets?.[0] || item.bullets?.[0]}</p>
            </article>
          </>
        ))}
      </div>
    </section>

    <section class="pv4-section" id="fit" aria-labelledby="fit-title" data-testid="human-documents">
      <div class="pv4-section-head">
        <div>
          <span class="pv4-section-index">06 · Target roles</span>
          <h2 id="fit-title">One evidence base. Four high-upside application routes.</h2>
        </div>
        <p>The public portfolio remains broad. Each application document selects the most relevant evidence for a specific role family.</p>
      </div>
      <div class="pv4-fit-grid">
        {H.roleFamilies.map((role) => (
          <article class="pv4-fit-card">
            <h3>{role.title}</h3>
            <p>{role.text}</p>
            <a href={role.href}>{role.label} →</a>
          </article>
        ))}
      </div>
      <div class="pv4-actions">
        <a class="pv4-button" href="/cv.html">Open the master CV and evidence record</a>
        <a class="pv4-button" href="/integrity.html">Knowledge-integrity work samples</a>
        <a class="pv4-button" href="/security.html">Model-behavior record</a>
      </div>
    </section>

    <section class="pv4-contact" id="contact" aria-labelledby="contact-title">
      <div>
        <span class="pv4-section-index">07 · Contact</span>
        <h2 id="contact-title">Bring me the difficult problem.</h2>
      </div>
      <div class="pv4-contact-copy">
        <p>I am based in Italy, authorized to work across the EU/EEA and open to worldwide relocation, international contracting and roles where investigation, operational ownership or evidence quality creates real value.</p>
        <div class="pv4-contact-links">
          <a class="pv4-button pv4-button-primary" href={`mailto:${D.identity.email}`}>Email Mario</a>
          <a class="pv4-button" href={D.identity.linkedin} target="_blank" rel="noopener noreferrer">LinkedIn</a>
          <a class="pv4-button" href={D.identity.github} target="_blank" rel="noopener noreferrer">GitHub</a>
          <a class="pv4-button" href={D.identity.orcidUrl} target="_blank" rel="noopener noreferrer">ORCID</a>
        </div>
      </div>
    </section>
  </main>

  <SiteFooter version={D.identity.buildVersion} />

  <script is:inline>
    (function portfolioInteractions() {
      var track = document.querySelector("[data-gallery-track]");
      var prev = document.querySelector("[data-gallery-prev]");
      var next = document.querySelector("[data-gallery-next]");
      var step = function() { return track ? Math.max(300, track.clientWidth * 0.58) : 420; };
      if (track && prev && next) {
        prev.addEventListener("click", function() { track.scrollBy({ left: -step(), behavior: "smooth" }); });
        next.addEventListener("click", function() { track.scrollBy({ left: step(), behavior: "smooth" }); });
      }
    })();
  </script>
</Layout>
