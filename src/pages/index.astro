  </section>

  <!-- ========================================
       BY THE NUMBERS — IMPACT METRICS
       ======================================== -->
  <section class="section" id="numbers">
    <div class="container">
      <div class="reveal">
        <div class="section-label">Verifiable Impact</div>
        <h2 class="section-title">Evidence across scientific & technical ecosystems.</h2>
      </div>

      <div class="stats-grid reveal-stagger" id="statsGrid">
        <!-- Hydrated from source.js -->
      </div>

      <div class="reveal">
        <div class="wiki-bar-group" id="wikiBreakdown">
          <!-- Wikimedia contribution bars -->
        </div>
      </div>
    </div>
  </section>

  <!-- ========================================
       VISUALIZATIONS
       ======================================== -->
  <section class="section" id="visualizations">
    <div class="container">
      <div class="reveal">
        <div class="section-label">Scientific Visualizations</div>
        <h2 class="section-title">Adopted across Wikipedia & academic publishing.</h2>
        <p class="section-desc">
          Original vector data visualizations published under open licenses on Wikimedia Commons.
        </p>
      </div>

      <div class="reveal">
        <div class="viz-tabs" id="vizTabs">
          <!-- Hydrated from source.js -->
        </div>

        <div class="viz-display">
          <img id="vizImg" src="" alt="" decoding="async" loading="lazy">
        </div>

        <p class="viz-caption" id="vizCaption"></p>

        <div class="viz-btn-row">
          <a id="vizLink" href="" target="_blank" rel="noopener noreferrer" class="btn btn-sm">View on Wikimedia Commons ↗</a>
          <a href="https://public.tableau.com/app/profile/mario.marcolongo/vizzes" target="_blank" rel="noopener noreferrer" class="btn btn-sm">Tableau Portfolio ↗</a>
          <a href="https://app.flourish.studio/@Digressivo" target="_blank" rel="noopener noreferrer" class="btn btn-sm">Flourish Portfolio ↗</a>
