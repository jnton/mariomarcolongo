---
import Layout from "../layouts/Layout.astro";
import SiteNav from "../components/SiteNav.astro";
import SiteFooter from "../components/SiteFooter.astro";
import "../styles/human-portfolio.css";
import D from "../../data/source.js";
import H from "../../data/portfolio-human.js";
import { buildProfileGraph } from "../lib/structured-data.js";

const pageTitle = "Mario Marcolongo — Research, Evidence & Trustworthy Technology";
const pageDescription = "Portfolio of scientific verification, research and editorial operations, knowledge integrity, open science and model-behavior testing.";
const profileJsonLd = buildProfileGraph(D, "https://mariomarcolongo.com/", pageTitle);

const selectedExperience = [
  D.experience.find((item) => item.org?.includes("Wikipedia")),
  D.experience.find((item) => item.role?.includes("Focus-Group")),
  D.experience.find((item) => item.org?.includes("Entropy for Life")),
  D.experience.find((item) => item.org?.includes("Yourself to Science")),
  D.experience.find((item) => item.role?.includes("Model-Behavior"))
].filter(Boolean);

const pencilImage = "https://commons.wikimedia.org/wiki/Special:Redirect/file/Pencil_Fascist_Tuberculosis_Campaign_Italy_Side_A_Angle.jpg?width=1280";
---

<Layout title={pageTitle} description={pageDescription} canonical="https://mariomarcolongo.com/">
  <Fragment slot="head">
    <script is:inline>document.documentElement.classList.add("human-portfolio");</script>
    <script type="application/ld+json" set:html={JSON.stringify(profileJsonLd)}></script>
  </Fragment>

  <SiteNav activePage="home" />

  <main class="human-page" id="content">
    <section class="human-hero" aria-labelledby="human-title">
      <div class="human-hero-copy">
        <div class="human-eyebrow">{H.eyebrow}</div>
        <h1 id="human-title">I make difficult evidence easier to <em>trust</em> and use.</h1>
        <p class="human-intro">{H.introduction}</p>
        <div class="human-actions">
          <a class="human-button human-button-primary" href="#work">See selected work <span aria-hidden="true">↓</span></a>
          <a class="human-button" href="#experience">View experience</a>
          <a class="human-button" href="#fit">Choose a CV</a>
        </div>
        <div class="human-hero-facts" aria-label="Location and working information">
          <span>Based in Italy</span>
          <span>EU work authorization</span>
          <span>English C1 overall</span>
          <span>Open to relocation and international contracting</span>
        </div>
      </div>

      <div class="human-collage" aria-label="Real public work and artifacts">
        <div class="human-paper-note">Real projects, public records and inspectable evidence—not stock illustrations.</div>
        <figure class="human-media human-media-main" data-parallax="7">
          <img src="/media/work/yourself-to-science.png" alt="Screenshot of the Yourself to Science research-participation catalogue" width="1440" height="900" />
          <figcaption>Yourself to Science — public research-participation catalogue</figcaption>
        </figure>
        <figure class="human-media human-media-viz" data-parallax="-5">
          <img src={D.visualizations[0].src} alt={D.visualizations[0].title} width="900" height="900" />
          <figcaption>{D.visualizations[0].title} — original open visualization</figcaption>
        </figure>
        <figure class="human-media human-media-object" data-parallax="4">
          <img src={pencilImage} alt="Fascist-era carpenter pencil documented for Wikimedia Commons" width="1280" height="444" />
          <figcaption>Historical provenance and rights-verification record · photograph by Alessandro Lanzoni, CC BY-SA 4.0</figcaption>
        </figure>
      </div>
    </section>

    <div class="human-marquee" aria-hidden="true">
      <div class="human-marquee-track">
        <span>Scientific verification</span><span>Research operations</span><span>Knowledge integrity</span><span>AI behavior</span><span>Open science</span><span>Community facilitation</span>
        <span>Scientific verification</span><span>Research operations</span><span>Knowledge integrity</span><span>AI behavior</span><span>Open science</span><span>Community facilitation</span>
      </div>
    </div>

    <section class="human-section" id="approach" aria-labelledby="approach-title">
      <div class="human-section-head">
        <div>
          <span class="human-section-index">01 · What I do</span>
          <h2 id="approach-title">Three useful verbs, not one inflated title.</h2>
        </div>
        <p>The work spans different domains, but the underlying pattern is consistent: establish what is true, make the process usable and look for what can fail.</p>
      </div>

      <div class="human-capabilities" data-testid="human-capabilities">
        {H.capabilities.map((capability) => (
          <article class="human-capability">
            <span class="human-capability-verb">{capability.verb}</span>
            <h3>{capability.title}</h3>
            <p>{capability.body}</p>
            <small>{capability.proof}</small>
          </article>
        ))}
      </div>
    </section>

    <section class="human-section" id="work" aria-labelledby="work-title" data-testid="human-work">
      <div class="human-section-head">
        <div>
          <span class="human-section-index">02 · Selected work</span>
          <h2 id="work-title">The process matters as much as the result.</h2>
        </div>
        <p>Each story shows a different working environment: a public research product, a live evidence-monitoring workflow, sensitive participant-facing research and adversarial AI testing.</p>
      </div>

      <div class="human-stories">
        {H.stories.map((story) => (
          <article class={`human-story human-story-${story.id}`}>
            <div class="human-story-visual">
              {story.visual === "protocol" ? (
                <div class="human-story-frame human-protocol" role="img" aria-label="Illustration of a structured two-person focus-group facilitation protocol">
                  <div class="human-protocol-sidebar">
                    <span>Session guide</span>
                    <div>Welcome and expectations</div>
                    <div>Consent and comfort check</div>
                    <div>Structured prompts</div>
                    <div>Handoff and recovery</div>
                    <div>Closing and debrief</div>
                  </div>
                  <div class="human-protocol-page">
                    <h4>Two-person facilitation</h4>
                    <div class="human-protocol-line medium"></div>
                    <div class="human-protocol-line"></div>
                    <div class="human-protocol-line short"></div>
                    <div class="human-handoff">
                      <div class="human-handoff-person">Facilitator A<br />leads and listens</div>
                      <div class="human-handoff-arrow" aria-hidden="true">↔</div>
                      <div class="human-handoff-person">Facilitator B<br />tracks and supports</div>
                    </div>
                  </div>
                </div>
              ) : (
                <figure class="human-story-frame">
                  <img src={story.image} alt={story.imageAlt} width="1440" height="900" loading="lazy" decoding="async" />
                </figure>
              )}
              <span class="human-story-number" aria-hidden="true">{story.number}</span>
            </div>

            <div class="human-story-copy">
              <span class="human-story-label">{story.label}</span>
              <h3>{story.title}</h3>
              <p class="human-story-summary">{story.summary}</p>
              <div class="human-story-role"><strong>My role:</strong> {story.role}</div>
              <ul>{story.process.map((step) => <li>{step}</li>)}</ul>
              <div class="human-story-result"><strong>Result:</strong> {story.result}</div>
              <a class="human-story-link" href={story.href} target={story.href.startsWith("http") ? "_blank" : undefined} rel={story.href.startsWith("http") ? "noopener noreferrer" : undefined}>{story.linkLabel} →</a>
            </div>
          </article>
        ))}
      </div>
    </section>

    <section class="human-section" id="artifacts" aria-labelledby="artifacts-title">
      <div class="human-section-head">
        <div>
          <span class="human-section-index">03 · Public artifacts</span>
          <h2 id="artifacts-title">Work you can inspect, reuse or challenge.</h2>
        </div>
        <p>A small selection from more than 70 public visualizations. The full record also includes Wikimedia contributions, datasets, open-source repositories and published research communication.</p>
      </div>

      <div class="human-artifact-shell">
        <div class="human-artifact-controls" aria-label="Visualization gallery controls">
          <button class="human-artifact-control" type="button" data-artifact-prev aria-label="Previous visualization">←</button>
          <button class="human-artifact-control" type="button" data-artifact-next aria-label="Next visualization">→</button>
        </div>
        <div class="human-artifact-track" data-artifact-track tabindex="0">
          {D.visualizations.map((item) => (
            <figure class="human-artifact">
              <img src={item.src} alt={item.title} width="1000" height="650" loading="lazy" decoding="async" />
              <figcaption>
                <strong>{item.title}</strong>
                <p>{item.caption}</p>
                <a href={item.fileUrl} target="_blank" rel="noopener noreferrer">Open the public source ↗</a>
              </figcaption>
            </figure>
          ))}
        </div>
      </div>
    </section>

    <section class="human-section" id="experience" aria-labelledby="experience-title">
      <div class="human-section-head">
        <div>
          <span class="human-section-index">04 · Experience</span>
          <h2 id="experience-title">A public record built over time.</h2>
        </div>
        <p>The chronology is intentionally mixed: paid work, independent public projects and volunteer research are labelled honestly rather than made to look equivalent.</p>
      </div>

      <div class="human-experience-grid">
        {selectedExperience.map((item) => (
          <>
            <div class="human-experience-year">{item.period}</div>
            <article class="human-experience-copy">
              <h3>{item.role}</h3>
              <p><strong>{item.org}</strong> · {item.tag}. {item.resumeBullets?.[0] || item.bullets?.[0]}</p>
            </article>
          </>
        ))}
      </div>
    </section>

    <section class="human-section" id="fit" aria-labelledby="fit-title" data-testid="human-documents">
      <div class="human-section-head">
        <div>
          <span class="human-section-index">05 · Where I fit</span>
          <h2 id="fit-title">One evidence base. Different application documents.</h2>
        </div>
        <p>The public portfolio stays broad because the work is broad. Applications should not. Each two-page CV selects and orders the same verified facts for a specific role family.</p>
      </div>

      <div class="human-fit-grid">
        {H.roleFamilies.map((role) => (
          <article class="human-fit-card">
            <h3>{role.title}</h3>
            <p>{role.text}</p>
            <a href={role.href}>{role.label} →</a>
          </article>
        ))}
      </div>
      <div class="human-actions">
        <a class="human-button" href="/cv.html">Open the master CV and evidence record</a>
        <a class="human-button" href="/integrity.html">Open knowledge-integrity work samples</a>
        <a class="human-button" href="/security.html">Open model-behavior record</a>
      </div>
    </section>

    <section class="human-contact" id="contact" aria-labelledby="contact-title">
      <div>
        <span class="human-section-index">06 · Contact</span>
        <h2 id="contact-title">Let’s talk about difficult evidence.</h2>
      </div>
      <div class="human-contact-copy">
        <p>I am based in Italy, authorized to work across the EU/EEA and open to relocation, international contracting and roles where careful investigation or research operations create real value.</p>
        <div class="human-contact-links">
          <a class="human-button human-button-primary" href={`mailto:${D.identity.email}`}>Email Mario</a>
          <a class="human-button" href={D.identity.linkedin} target="_blank" rel="noopener noreferrer">LinkedIn</a>
          <a class="human-button" href={D.identity.github} target="_blank" rel="noopener noreferrer">GitHub</a>
          <a class="human-button" href={D.identity.orcidUrl} target="_blank" rel="noopener noreferrer">ORCID</a>
        </div>
      </div>
    </section>
  </main>

  <SiteFooter version={D.identity.buildVersion} />

  <script is:inline>
    (function humanPortfolioInteractions() {
      var track = document.querySelector("[data-artifact-track]");
      var prev = document.querySelector("[data-artifact-prev]");
      var next = document.querySelector("[data-artifact-next]");
      var step = function() { return track ? Math.max(320, track.clientWidth * 0.62) : 420; };
      if (track && prev && next) {
        prev.addEventListener("click", function() { track.scrollBy({ left: -step(), behavior: "smooth" }); });
        next.addEventListener("click", function() { track.scrollBy({ left: step(), behavior: "smooth" }); });
      }

      var reduceMotion = window.matchMedia && window.matchMedia("(prefers-reduced-motion: reduce)").matches;
      var collage = document.querySelector(".human-collage");
      if (!collage || reduceMotion || !window.matchMedia("(pointer: fine)").matches) return;

      var items = Array.from(collage.querySelectorAll("[data-parallax]"));
      var frame = null;
      collage.addEventListener("pointermove", function(event) {
        var rect = collage.getBoundingClientRect();
        var x = ((event.clientX - rect.left) / rect.width - 0.5) * 2;
        var y = ((event.clientY - rect.top) / rect.height - 0.5) * 2;
        if (frame) cancelAnimationFrame(frame);
        frame = requestAnimationFrame(function() {
          items.forEach(function(item) {
            var amount = Number(item.getAttribute("data-parallax")) || 0;
            item.style.translate = (x * amount) + "px " + (y * amount) + "px";
          });
        });
      });
      collage.addEventListener("pointerleave", function() {
        items.forEach(function(item) { item.style.translate = "0 0"; });
      });
    })();
  </script>
</Layout>
