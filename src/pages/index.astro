---
import Layout from '../layouts/Layout.astro';
import SiteNav from '../components/SiteNav.astro';
import SiteFooter from '../components/SiteFooter.astro';
import D from '../../data/source.js';
import { buildProfileGraph } from '../lib/structured-data.js';

const CITATIONS = {
  edits: {
    title: "Auditable Wikimedia Contributions (CentralAuth)",
    href: D.identity.centralAuth || "https://commons.wikimedia.org/wiki/Special:CentralAuth/Digressivo",
    text: "1,592 English Wikipedia edits, 752 Italian Wikipedia edits, 1,249 on Wikidata, 684 on Wikimedia Commons — 4,317 total publicly inspectable contributions under one CentralAuth identity."
  },
  ena: {
    title: "European Nucleotide Archive (ENA Accession)",
    href: D.identity.enaUrl || "https://www.ebi.ac.uk/ena/browser/view/PRJEB109744",
    text: "Designed and iteratively validated a local downstream bioinformatics workflow transforming VCF datasets to Plink2 format and running Nextflow pgsc_calc with ancestry projection against reference panels, along with custom Python VEP extraction scripts under ENA Accession PRJEB109744 (personal genomics workflow and open-data pipeline published on GitHub: jnton/git-nome)."
  },
  registry: {
    title: "Yourself to Science™ Study Directory",
    href: D.projects[0]?.link || "https://yourselftoscience.org",
    text: "Founder & architect of Yourself to Science™ — an open-source research-participation directory indexing 55+ research studies across genomes, clinical trials, and bio-donations, cited across 37 Wikidata entities (P854)."
  },
  grayswan: {
    title: "Gray Swan Proving Ground Verification Profile",
    href: D.identity.grayswanUrl || "https://app.grayswan.ai/arena/user/6a57be70d15e123775a1e9cf",
    text: "Ranked in the top 8% among ranked Gray Swan Proving Ground participants as of July 2026 — 75 platform-confirmed model breaks across chat, image, agentic tool-use and indirect prompt-injection challenges."
  },
  book: {
    title: "Italiani Veri — Mondadori",
    href: "https://www.mondadori.it/libri/italiani-veri-giacomo-moro-mauretto/",
    text: "Giacomo Moro Mauretto's 'Italiani Veri', published by Mondadori in April 2025 — official acknowledgment published on the final page."
  },
  agentready: {
    title: "Live Agent-Readiness Audit Status",
    href: "https://isitagentready.com/mariomarcolongo.com?checks=robotsTxt%2Csitemap%2ClinkHeaders%2CdnsAid%2CmarkdownNegotiation%2CrobotsTxtAiRules%2CcontentSignals%2CwebBotAuth%2CapiCatalog%2CoauthDiscovery%2CoauthProtectedResource%2CauthMd%2CmcpServerCard%2Ca2aAgentCard%2CagentSkills%2CwebMcp%2Cx402%2Cmpp%2Cucp%2Cacp",
    text: "Agent-discovery and machine-readable endpoints implemented; live audit to be rerun after deployment (including live A2A Agent Card, DNS-AID, and llms.txt)."
  }
};

function buildProjectLinks(p) {
  const btns = [];
  const l = p.links || {};
  const t = (p.title || p.org || 'project').replaceAll('"', '&quot;');

  if (p.id === 'yourself-to-science') {
    if (l.website) btns.push({ href: l.website, label: `Catalogue Engine (Live) ↗ (${t})`, primary: true });
    if (l.github) btns.push({ href: l.github, label: `Source Verification (GitHub) ↗ (${t})` });
    if (l.fairsharing) btns.push({ href: l.fairsharing, label: `FAIRsharing ↗ (${t})` });
    return btns;
  }
  if (p.id === 'entropy-for-life') {
    if (l.website) btns.push({ href: l.website, label: `Open Science Platform & Video Archive ↗ (${t})`, primary: true });
    if (l.playlist) btns.push({ href: l.playlist, label: `Videos & Documentaries ↗ (${t})` });
    return btns;
  }
  if (p.id === 'ai-red-teaming') {
    if (l.caseStudy) btns.push({ href: l.caseStudy, label: `Read Model Evaluation Record & Methodology → (${t})`, primary: true });
    if (l.profile) btns.push({ href: l.profile, label: `Proving Ground Profile ↗ (${t})` });
    return btns;
  }
  if (p.id === 'telegram-bot') {
    if (l.bot || l.telegramBot) btns.push({ href: l.bot || l.telegramBot, label: `Production Bot Instance (@en_wiki_bot) ↗ (${t})`, primary: true });
    if (l.chromeStore) btns.push({ href: l.chromeStore, label: `Verified Chrome Extension Architecture ↗ (${t})` });
    if (l.edgeStore) btns.push({ href: l.edgeStore, label: `Edge Add-on Delivery ↗ (${t})` });
    return btns;
  }
  if (p.id === 'author-index') {
    if (l.authorPage) btns.push({ href: l.authorPage, label: `Open Access Author Index & Verification Archive ↗ (${t})`, primary: true });
    if (l.orcidUrl) btns.push({ href: l.orcidUrl, label: `ORCID Profile ↗ (${t})` });
    return btns;
  }
  if (l.caseStudy) btns.push({ href: l.caseStudy, label: `Evaluation Record → (${t})` });
  if (l.profile) btns.push({ href: l.profile, label: `Proving Ground Profile ↗ (${t})` });
  if (l.website) btns.push({ href: l.website, label: `Visit Site ↗ (${t})` });
  if (l.playlist) btns.push({ href: l.playlist, label: `Videos & Documentaries ↗ (${t})` });
  if (l.authorPage) btns.push({ href: l.authorPage, label: `Author Page ↗ (${t})` });
  if (l.chromeStore) btns.push({ href: l.chromeStore, label: `Chrome Store ↗ (${t})` });
  if (l.edgeStore) btns.push({ href: l.edgeStore, label: `Edge Store ↗ (${t})` });
  if (l.youtube) btns.push({ href: l.youtube, label: `YouTube ↗ (${t})` });
  if (l.bot || l.telegramBot) btns.push({ href: l.bot || l.telegramBot, label: `Try Bot ↗ (${t})` });
  if (l.wikimedia) btns.push({ href: l.wikimedia, label: `Wikimedia ↗ (${t})` });
  if (l.github || l.githubOrg) btns.push({ href: l.github || l.githubOrg, label: `GitHub ↗ (${t})` });
  if (l.doi) btns.push({ href: l.doi, label: `DOI ↗ (${t})` });
  if (l.fairsharing) btns.push({ href: l.fairsharing, label: `FAIRsharing ↗ (${t})` });
  if (l.tableau) btns.push({ href: l.tableau, label: `Tableau ↗ (${t})` });
  if (l.flourish) btns.push({ href: l.flourish, label: `Flourish ↗ (${t})` });
  return btns;
}

function buildProjectVisualHtml(p, i) {
  if (p.id === 'mdpi-filter') {
    const imgSrc = (p.links && p.links.screenshots && p.links.screenshots[0])
      ? p.links.screenshots[0]
      : 'https://lh3.googleusercontent.com/1KKa3LqvJ6ayP9Kh6_jmAWXzL3naOfPnnKtWb8vjd25XMn1ELMNFDxGjgtvShNmDhWG4x_uuynunm9lVD7wQ3hAI=s1280-w1280-h800';
    return `<div class="proj-viz-mdpi"><img src="${imgSrc}" alt="${p.title} screenshot" loading="lazy"></div>`;
  }
  if (p.id === 'telegram-bot') {
    return `
      <div class="telegram-mock">
        <div class="tg-header">
          <div class="tg-avatar">
            <img src="/telegram-bot-icon.svg" alt="Wikipedia Link Converter Bot Icon" class="proj-viz-tg-icon">
          </div>
          <div>
            <div class="tg-name">Wikipedia Link Converter</div>
            <div class="tg-status">serverless bot</div>
          </div>
        </div>
        <div class="tg-body">
          <div class="tg-bubble-out">
            <span class="tg-link">https://it.wikipedia.org/wiki/Bianco_e_nero</span>
          </div>
          <div class="tg-bubble-in">
            English canonical page resolved for <strong>Bianco e nero</strong>:<br>
            <span class="tg-link">https://en.wikipedia.org/wiki/Black_and_white</span>
          </div>
        </div>
      </div>
    `;
  }
  if (p.id === 'referendum-map') {
    return `<img src="/referendum-turnout-threshold-by-country.svg" alt="Referendum Turnout Threshold World Map" loading="lazy" class="proj-viz-map">`;
  }
  if (p.id === 'entropy-for-life') {
    return `
      <div class="mock-visual-box proj-viz-entropy">
        <div class="proj-viz-entropy-top">
          <div class="proj-viz-entropy-play">▶</div>
          <div>
            <div class="proj-viz-entropy-handle">@EntropyforLife</div>
            <div class="proj-viz-entropy-bio">Giacomo Moro Mauretto · Evolutionary Biology</div>
          </div>
        </div>
        <div class="proj-viz-entropy-mid">
          <div class="proj-viz-entropy-num">480,000+</div>
          <div class="proj-viz-entropy-label">Total Cross-Platform Community</div>
        </div>
        <div class="proj-viz-entropy-grid">
          <div class="proj-viz-entropy-stat">
            <div class="proj-viz-entropy-stat-val">245K+</div>
            <div class="proj-viz-entropy-stat-title">YouTube Subs</div>
          </div>
          <div class="proj-viz-entropy-stat">
            <div class="proj-viz-entropy-stat-val">36.2M+</div>
            <div class="proj-viz-entropy-stat-title">Total Views</div>
          </div>
          <div class="proj-viz-entropy-stat">
            <div class="proj-viz-entropy-stat-val">55+</div>
            <div class="proj-viz-entropy-stat-title">Videos Checked</div>
          </div>
        </div>
        <div class="proj-viz-entropy-context">Entropy for Life project context — not individual authorship claims</div>
        <div class="proj-viz-entropy-tags">
          <span class="proj-viz-entropy-tag">📚 2 Mondadori Books</span>
          <span class="proj-viz-entropy-tag">🔬 AIRC Partner</span>
          <span class="proj-viz-entropy-tag">📺 Rai 3 Kilimangiaro</span>
          <span class="proj-viz-entropy-tag">📸 IG: 158K+ · TikTok: 54K+</span>
        </div>
      </div>
    `;
  }
  if (p.id === 'yourself-to-science') {
    return `
      <div class="mock-visual-box proj-viz-y2s">
        <div class="proj-viz-y2s-hdr">
          <div class="proj-viz-y2s-logos">
            <img src="/y2s-logo.svg" alt="Yourself to Science Logo" class="proj-viz-y2s-logo-icon">
            <img src="/y2s-title.svg" alt="Yourself to Science™" class="proj-viz-y2s-logo-title">
          </div>
          <div class="proj-viz-y2s-nav">
            <span>Stats</span>
            <span>Our Mission</span>
            <span class="proj-viz-y2s-btn">Get Involved</span>
          </div>
        </div>
        <div class="proj-viz-y2s-hero">
          <div class="proj-viz-y2s-title">Contribute to Research</div>
          <div class="proj-viz-y2s-sub">
            A comprehensive open-source catalogue for contributing to scientific research across clinical studies, biobanks, donation programs and registries. Browse opportunities to share your data, genome, biological samples, and more.
          </div>
        </div>
        <div class="proj-viz-y2s-bar">
          <div><strong>CATEGORY</strong>Any type</div>
          <div class="proj-viz-y2s-sep"></div>
          <div><strong>AVAILABLE IN</strong>Anywhere</div>
          <div class="proj-viz-y2s-sep"></div>
          <div><strong>DATA TYPE</strong>All</div>
          <div class="proj-viz-y2s-sep"></div>
          <div class="proj-viz-y2s-nav">
            <span>🔍</span><span>Search</span>
          </div>
        </div>
        <div class="proj-viz-y2s-grid">
          <div class="proj-viz-y2s-card">
            <div>
              <div class="proj-viz-y2s-card-top">
                <div class="proj-viz-y2s-logos">
                  <span class="proj-viz-y2s-badge-purple">BIOLOGICAL SAMPLES</span>
                  <span class="proj-viz-y2s-badge-green">HEALTH DATA</span>
                </div>
              </div>
              <div class="proj-viz-y2s-card-title">23andMe Research Participation</div>
              <div class="proj-viz-y2s-card-inst">🏢 23andMe Holding Co.</div>
              <div class="proj-viz-y2s-card-loc">• Based in United States</div>
            </div>
          </div>
          <div class="proj-viz-y2s-card">
            <div>
              <div class="proj-viz-y2s-card-top">
                <div class="proj-viz-y2s-logos">
                  <span class="proj-viz-y2s-badge-purple">BIOLOGICAL SAMPLES</span>
                </div>
              </div>
              <div class="proj-viz-y2s-card-title">AATB Accredited Bank Search</div>
              <div class="proj-viz-y2s-card-inst">🏢 American Association of Tissue Banks (AATB)</div>
              <div class="proj-viz-y2s-card-loc">• Based in United States</div>
            </div>
          </div>
        </div>
      </div>
    `;
  }
  if (p.id === 'emergent-humanity') {
    return `
      <div class="mock-visual-box node-viz-wrap proj-viz-node-wrap">
        <canvas id="nodeCanvas" aria-label="Interactive network simulation of human nodes and connections" role="img" class="proj-viz-node-canvas"></canvas>
        <div class="proj-viz-node-pill-wrap">
          <span class="proj-viz-node-pill">INTERACTIVE NARRATION · ACTIVE ALPHA</span>
        </div>
      </div>
    `;
  }
  if (p.id === 'ai-red-teaming') {
    return `
      <div class="mock-visual-box proj-viz-redteam">
        <div>
          <div class="proj-viz-redteam-top">
            <span class="proj-viz-redteam-dot"></span>
            <span class="proj-viz-redteam-hdr">Adversarial Evaluation Record</span>
          </div>
          <div class="proj-viz-redteam-val">75 Platform-Confirmed Breaks</div>
          <div class="proj-viz-redteam-sub">Top 8% Among Ranked Participants · 156 Submissions across 26 Waves</div>
        </div>
        <div class="proj-viz-redteam-box">
          <div class="proj-viz-redteam-lbl">// Target Modalities Evaluated</div>
          <div class="proj-viz-redteam-desc">> [Chat & Alignment Policies] : COMPLETED<br>> [Multimodal / Image Safety] : COMPLETED<br>> [Agentic Tool-Use Auth]   : COMPLETED<br>> [Indirect Prompt Injection]: COMPLETED</div>
        </div>
      </div>
    `;
  }
  return `<div class="mock-visual-box"><div class="proj-viz-entropy-num">⚡</div></div>`;
}

const maxWikiEdits = Math.max(...(D.wikimedia?.breakdown || []).map(b => Number.parseInt(b.edits.replaceAll(',', ''), 10) || 1));
const firstViz = D.visualizations?.[0] || { src: '', title: '', caption: '', fileUrl: '' };
const pageTitle = `Mario Marcolongo — ${D.identity.jobTitle}`;
const pageDescription = `AI evaluation and research verification specialist focused on ${D.identity.secondaryTitle.toLowerCase().replaceAll(' · ', ', ')}.`;
const profileJsonLd = buildProfileGraph(D, 'https://mariomarcolongo.com/', pageTitle);
---

<Layout
  title={pageTitle}
  description={pageDescription}
  canonical="https://mariomarcolongo.com/"
>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(profileJsonLd)}></script>
  </Fragment>

  <!-- ========================================
       NAVIGATION
       ======================================== -->
  <SiteNav activePage="home" />

  <!-- ========================================
       HERO
       ======================================== -->
  <section class="hero">
    <div class="container">
      <div>
        <div class="hero-animate hero-animate-1">
          <div class="badge-pill">
            <span class="badge-dot"></span>
            <span>Italian Citizen · Unrestricted EU Work Authorization · International B2B Contracting Available</span>
          </div>
        </div>
        <h1 class="hero-headline hero-animate hero-animate-2" id="heroHeadline">{D.identity.headline}</h1>
        <p class="hero-sub hero-animate hero-animate-3" id="heroSub">Eight years of auditable Wikimedia contributions<a href={CITATIONS.edits.href} class="cite-btn" data-cite="edits" aria-expanded="false" title="Click to inspect source" target="_blank" rel="noopener noreferrer">1</a> holding up under scrutiny. A personal genome<a href={CITATIONS.ena.href} class="cite-btn" data-cite="ena" aria-expanded="false" title="Click to inspect source" target="_blank" rel="noopener noreferrer">2</a> released to the public domain under a real ENA accession number. An open-source research-participation directory<a href={CITATIONS.registry.href} class="cite-btn" data-cite="registry" aria-expanded="false" title="Click to inspect platform" target="_blank" rel="noopener noreferrer">3</a> indexing more than 55 clinical studies, biobanks, donation programs, registries and other research initiatives cited across 37 Wikidata entities. And ranked in the top 8% among ranked Gray Swan Proving Ground participants as of July 2026<a href={CITATIONS.grayswan.href} class="cite-btn" data-cite="grayswan" aria-expanded="false" title="Click to inspect profile" target="_blank" rel="noopener noreferrer">4</a>, with 75 platform-confirmed model breaks across chat, image, agentic tool-use and indirect prompt-injection challenges.</p>
        <div class="hero-meta hero-animate hero-animate-4">
          <span id="heroLocation">{D.identity.location}</span>
          <span>·</span>
          <span id="heroLanguages">Italian (Native) & English (C1 Overall)</span>
          <span>·</span>
          <a href="/cv.html">Full CV</a>
          <span>·</span>
          <a href={D.identity.orcidUrl} target="_blank" rel="noopener noreferrer" id="heroOrcid">ORCID ↗</a>
          <span>·</span>
          <a href={D.identity.enaUrl} target="_blank" rel="noopener noreferrer">ENA ↗</a>
        </div>
        <div class="hero-actions hero-animate hero-animate-5">
          <a href="/cv-resume.html" class="btn btn-primary">2-Page Résumé (Application CTA) →</a>
          <a href="/security.html" class="btn">Model Evaluation Record</a>
          <a href="#work" class="btn">Explore Work ↓</a>
        </div>
      </div>
    </div>
  </section>

  <!-- ========================================
       VERIFIED PROOF STRIP
       ======================================== -->
  <section class="section section-proof" id="proof">
    <div class="container">
      <div class="reveal">
        <div class="section-label">Publicly Auditable Evidence</div>
        <h2 class="section-title">Primary sources you can inspect directly.</h2>
        <p class="section-desc">The highlighted claims link to public identities, accessions, project records or publisher pages. Open the citations to inspect the available evidence and its scope.</p>
      </div>

      <div class="proof-grid reveal">
        <div class="proof-row">
          <span class="proof-tag">In Print</span>
          <p class="proof-text">Named in the acknowledgments of <b>Italiani Veri</b> (Mondadori, 2025) as a collaborator "excellent at digging into the scientific literature and catching errors."<a href={CITATIONS.book.href} class="cite-btn" data-cite="book" aria-expanded="false" title="Click to inspect verification source" target="_blank" rel="noopener noreferrer">1</a></p>
        </div>
        <div class="proof-row">
          <span class="proof-tag">On the Record</span>
          <p class="proof-text">4,317 publicly inspectable contributions across Wikipedia, Wikidata and Wikimedia Commons under one public CentralAuth account.<a href={CITATIONS.edits.href} class="cite-btn" data-cite="edits" aria-expanded="false" title="Click to inspect verification source" target="_blank" rel="noopener noreferrer">2</a></p>
        </div>
        <div class="proof-row">
          <span class="proof-tag">Open Research Directory</span>
          <p class="proof-text">Founder & Technical Product Builder of <b>Yourself to Science™</b> (yourselftoscience.org), an open-source research-participation directory indexing more than 55 clinical studies, biobanks, donation programs, registries and other initiatives — cited across 37 Wikidata entities (P854).<a href={CITATIONS.registry.href} class="cite-btn" data-cite="registry" aria-expanded="false" title="Click to inspect verification source" target="_blank" rel="noopener noreferrer">3</a></p>
        </div>
        <div class="proof-row">
          <span class="proof-tag">Open Genomic Donor & Pipeline</span>
          <p class="proof-text">Donated personal 41× Whole Genome Sequencing raw paired-end FASTQ reads (DNBSEQ-T7) to the public domain (CC0) under ENA BioSample SAMEA121950568, with complete local personal genomics workflow and open-data pipeline open-sourced on GitHub (<code>git-nome</code>).<a href={CITATIONS.ena.href} class="cite-btn" data-cite="ena" aria-expanded="false" title="Click to inspect verification source" target="_blank" rel="noopener noreferrer">4</a></p>
        </div>
        <div class="proof-row">
          <span class="proof-tag">Model Behavior Evaluation</span>
          <p class="proof-text">Ranked in the top 8% among ranked participants on Gray Swan AI's Proving Ground — 75 platform-confirmed model breaks across chat, image, agentic tool-use, and indirect prompt-injection categories (as of July 2026). <a href="/security.html" class="inline-proof-link">View Model Evaluation Record & Methodology →</a><a href={CITATIONS.grayswan.href} class="cite-btn" data-cite="grayswan" aria-expanded="false" title="Click to inspect profile" target="_blank" rel="noopener noreferrer">5</a></p>
        </div>
        <div class="proof-row">
          <span class="proof-tag">Agent-Ready Architecture</span>
          <p class="proof-text">Agent-discovery and machine-readable endpoints implemented; live audit to be rerun after deployment.<a href={CITATIONS.agentready.href} class="cite-btn" data-cite="agentready" aria-expanded="false" title="Click to inspect live benchmark" target="_blank" rel="noopener noreferrer">6</a></p>
        </div>
      </div>

      <details class="citation-raw-list reveal" style="margin-top: 24px;">
        <summary class="btn btn-sm" style="cursor: pointer;">Verifiable Citations & Source Accessions (No-JS Disclosure)</summary>
        <div style="padding-top: 16px; display: grid; gap: 12px; font-size: 13px;">
          {Object.entries(CITATIONS).map(([key, data]) => (
            <div class="citation-item">
              <strong>[{key.toUpperCase()}]:</strong> {data.text} — <a href={data.href} target="_blank" rel="noopener noreferrer">{data.title} ↗</a>
            </div>
          ))}
        </div>
      </details>
    </div>
  </section>

  <!-- ========================================
       CORE FOCUS / BENTO PILLARS
       ======================================== -->
  <section class="section" id="about">
    <div class="container">
      <div class="reveal">
        <div class="section-label">Core Focus</div>
        <h2 class="section-title">Where AI-assisted delivery meets scientific rigor.</h2>
        <p class="section-desc">Bridging AI-assisted technical delivery, open biomedical data infrastructure and evidence synthesis.</p>
      </div>

      <div class="pillars reveal-stagger" id="pillarGrid" data-testid="homepage-pillars">
        {D.pillars.map((p) => (
          <div class="pillar reveal">
            <div class="pillar-header">
              <div class="pillar-icon-box" aria-hidden="true" set:html={p.icon}></div>
              {p.category && <span class="pillar-category">{p.category}</span>}
            </div>
            <h3 class="pillar-title">{p.title}</h3>
            <p class="pillar-lead">{p.lead || p.desc}</p>
            {p.highlights && (
              <div class="pillar-highlights">
                {p.highlights.map((h) => (
                  <div class="pillar-highlight-item">
                    <span class="pillar-highlight-dot"></span>
                    <div class="pillar-highlight-text">
                      <strong>{h.label}:</strong> {h.detail}
                    </div>
                  </div>
                ))}
              </div>
            )}
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ========================================
       FEATURED WORK — BENTO GRID SHOWCASE
       ======================================== -->
  <section class="section" id="work">
    <div class="container">
      <div class="reveal">
        <div class="section-label">Featured Work</div>
        <h2 class="section-title">Deployed systems & open research.</h2>
        <p class="section-desc">Public tools, automated workflows and research-participation infrastructure with inspectable implementation records.</p>
      </div>

      <div class="project-list" id="projectList" data-testid="homepage-projects">
        {D.projects.map((p, i) => {
          const isEven = i % 2 === 0;
          const links = buildProjectLinks(p);
          const visualHtml = buildProjectVisualHtml(p, i);
          return (
            <article class={`project-card reveal ${!isEven ? 'project-card-reverse' : ''}`}>
              <div class="project-info">
                <div class="project-tag">{p.role}</div>
                <h3 class="project-title">{p.title}</h3>
                <p class="project-one-liner">{p.oneLiner}</p>
                {p.highlights && (
                  <ul class="project-highlights">
