---
import Layout from "../layouts/Layout.astro";
import SiteNav from "../components/SiteNav.astro";
import SiteFooter from "../components/SiteFooter.astro";
import "../styles/career-v2.css";
import D from "../../data/source.js";
import P from "../../data/application-profiles.js";
import { buildProfileGraph } from "../lib/structured-data.js";

const primary = P.aiSafety;
const secondary = P.researchQuality;
const graySwan = D.projects.find((project) => project.id === "ai-red-teaming");
const entropy = D.projects.find((project) => project.id === "entropy-for-life");
const yourselfToScience = D.projects.find((project) => project.id === "yourself-to-science");

const pageTitle = "Mario Marcolongo — AI Safety Evaluation & Research Verification";
const pageDescription = "Portfolio of Mario Marcolongo, focused on AI safety evaluation, adversarial model testing, scientific evidence verification, research operations and data quality.";
const profileJsonLd = buildProfileGraph(D, "https://mariomarcolongo.com/", pageTitle);

const proof = [
  { value: "75", label: "Platform-confirmed breaks", detail: "Gray Swan Proving Ground · 156 submissions" },
  { value: "Top 8%", label: "Rank band", detail: "Among listed participants · July 2026" },
  { value: "55+", label: "Scientific videos checked", detail: "Paid primary-source verification" },
  { value: "4,317", label: "Public contributions", detail: "Eight years of auditable source work" }
];

const evidence = [
  {
    index: "01",
    title: "Model-behavior evaluation",
    body: graySwan?.oneLiner || "Self-directed adversarial evaluation across chat, multimodal, agentic tool-use and indirect prompt-injection challenges.",
    metric: "75 platform-confirmed breaks across 26 listed waves",
    href: "/security.html",
    label: "Open evaluation record"
  },
  {
    index: "02",
    title: "Paid scientific verification",
    body: entropy?.oneLiner || "Primary-source research and fact-checking for scientific media.",
    metric: "55+ videos and documentaries · 4 articles",
    href: "https://entropyforlife.it/autore/mario-marcolongo/",
    label: "Open author record"
  },
  {
    index: "03",
    title: "Research-workflow ownership",
    body: yourselfToScience?.oneLiner || "Open research-participation directory with structured verification and metadata workflows.",
    metric: "55+ research initiatives indexed",
    href: "https://yourselftoscience.org",
    label: "Open project"
  }
];
---

<Layout title={pageTitle} description={pageDescription} canonical="https://mariomarcolongo.com/">
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(profileJsonLd)}></script>
  </Fragment>

  <SiteNav activePage="home" />

  <div class="career-page">
    <section class="career-hero" aria-labelledby="portfolio-title">
      <div>
        <div class="career-kicker">AI safety evaluation · research verification</div>
        <h1 class="career-title" id="portfolio-title">
          I test model behavior.
          <em>I document what holds up.</em>
        </h1>
        <p class="career-lede">
          I combine <strong>adversarial AI evaluation</strong>, scientific evidence review and auditable research workflows. My strongest current fit is model-behavior testing, safeguards evaluation, trust & safety, evaluation operations and research-quality work—not independent software engineering.
        </p>
        <div class="career-actions">
          <a class="btn btn-primary" href="/cv-resume.html">AI Safety Application CV →</a>
          <a class="btn" href="/security.html">Evaluation Record</a>
          <a class="btn" href="#documents">Choose another CV</a>
        </div>
        <div class="career-meta">
          <span>Italy · EU work authorization</span>
          <span>Open to worldwide relocation</span>
          <span>English: C1 overall</span>
          <span>International B2B contracting</span>
        </div>
      </div>

      <aside class="career-proof-stack" aria-label="Selected verified evidence">
        <div class="career-proof-heading">
          <span>Evidence snapshot</span>
          <strong>Public records, not generic claims.</strong>
        </div>
        {proof.map((item) => (
          <div class="career-proof-item">
            <div class="career-proof-value">{item.value}</div>
            <div class="career-proof-copy">
              <strong>{item.label}</strong>
              <span>{item.detail}</span>
            </div>
          </div>
        ))}
      </aside>
    </section>

    <section class="career-section" id="focus" data-testid="career-focus">
      <div class="career-section-heading">
        <div>
          <div class="career-section-kicker">Positioning</div>
          <h2 class="career-section-title">Two credible application lanes. One high-upside direction.</h2>
        </div>
        <p class="career-section-copy">
          The primary lane uses the model-evaluation record as the differentiator. The secondary lane monetizes the deeper, longer-standing evidence-verification and data-quality record. Both can lead toward higher-revenue AI evaluation, safeguards and technical program roles as new skills and paid experience accumulate.
        </p>
      </div>

      <div class="career-role-grid">
        <article class="career-role-card primary">
          <div class="career-role-label">Primary application lane</div>
          <h3>{primary.title}</h3>
          <p>{primary.subtitle}</p>
          <ul class="career-role-list">
            {primary.fit.map((role) => <li>{role}</li>)}
          </ul>
        </article>

        <article class="career-role-card secondary">
          <div class="career-role-label">Secondary application lane</div>
          <h3>{secondary.title}</h3>
          <p>{secondary.subtitle}</p>
          <ul class="career-role-list">
            {secondary.fit.map((role) => <li>{role}</li>)}
          </ul>
        </article>
      </div>
    </section>

    <section class="career-section" id="evidence" data-testid="career-evidence">
      <div class="career-section-heading">
        <div>
          <div class="career-section-kicker">Selected evidence</div>
          <h2 class="career-section-title">Three records that explain the profile quickly.</h2>
        </div>
        <p class="career-section-copy">
          The portfolio is intentionally selective. The comprehensive history remains available in the master CV, while applications use only the evidence relevant to the target role.
        </p>
      </div>

      <div class="career-evidence-grid">
        {evidence.map((item) => (
          <article class="career-evidence-card">
            <div class="career-evidence-index">{item.index}</div>
            <h3>{item.title}</h3>
            <p>{item.body}</p>
            <div class="career-evidence-metric">{item.metric}</div>
            <a class="career-card-link" href={item.href} target={item.href.startsWith("http") ? "_blank" : undefined} rel={item.href.startsWith("http") ? "noopener noreferrer" : undefined}>{item.label} →</a>
          </article>
        ))}
      </div>
    </section>

    <section class="career-section" id="documents" data-testid="career-documents">
      <div class="career-section-heading">
        <div>
          <div class="career-section-kicker">Application documents</div>
          <h2 class="career-section-title">The full CV is an archive. Applications use specialized CVs.</h2>
        </div>
        <p class="career-section-copy">
          A recruiter normally receives one concise, targeted document. The master CV preserves complete evidence for due diligence and custom applications; it is not the default attachment.
        </p>
      </div>

      <div class="career-document-grid">
        <article class="career-document-card recommended">
          <span class="career-document-badge">Recommended for AI roles</span>
          <h3>AI Safety Evaluation CV</h3>
          <p>Two pages focused on adversarial testing, safeguards evaluation, model behavior, trust & safety and evaluation operations.</p>
          <a class="career-card-link" href="/cv-resume.html">Open specialized CV →</a>
        </article>

        <article class="career-document-card">
          <span class="career-document-badge">Research and data roles</span>
          <h3>Research Verification & Data Quality CV</h3>
          <p>Two pages focused on scientific evidence review, research operations, provenance, metadata and human-data quality.</p>
          <a class="career-card-link" href="/cv-research.html">Open specialized CV →</a>
        </article>

        <article class="career-document-card">
          <span class="career-document-badge">Reference archive</span>
          <h3>Master CV & Evidence Record</h3>
          <p>Comprehensive history, projects, research, credentials and links. Use when a detailed dossier is requested or to build a new tailored version.</p>
          <a class="career-card-link" href="/cv.html">Open master CV →</a>
        </article>

        <article class="career-document-card">
          <span class="career-document-badge">Public work sample</span>
          <h3>Model Evaluation Record</h3>
          <p>Concise scope, methodology, aggregate platform activity, testing areas and explicit evidence limitations.</p>
          <a class="career-card-link" href="/security.html">Open evaluation record →</a>
        </article>
      </div>
    </section>

    <section class="career-section" id="contact">
      <div class="career-contact-panel">
        <div>
          <h2>Open to ambitious roles—and to building the missing proof.</h2>
          <p>Current applications should focus on evaluation, adversarial QA, safeguards operations, research verification and data quality. The long-term direction is AI red-team and automated-evaluation engineering through verifiable study, projects and paid team experience.</p>
        </div>
        <div class="career-contact-links">
          <a href={`mailto:${D.identity.email}`}><span>Email</span><span>{D.identity.email}</span></a>
          <a href={D.identity.linkedin} target="_blank" rel="noopener noreferrer"><span>LinkedIn</span><span>Open ↗</span></a>
          <a href={D.identity.github} target="_blank" rel="noopener noreferrer"><span>GitHub</span><span>Open ↗</span></a>
          <a href={D.identity.orcidUrl} target="_blank" rel="noopener noreferrer"><span>ORCID</span><span>Open ↗</span></a>
        </div>
      </div>
    </section>
  </div>

  <SiteFooter version={D.identity.buildVersion} />
</Layout>
