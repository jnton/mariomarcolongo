    function initCitations() {
      document.querySelectorAll('button.cite-btn').forEach(btn => {
        btn.addEventListener('click', (e) => {
          e.stopPropagation();
          const key = btn.dataset.cite;
          if (activePopover && activePopover.key === key) {
            closePopover();
            return;
          }
          openPopover(btn, CITATIONS[key], key);
        });
      });

      document.addEventListener('click', closePopover);
      document.addEventListener('keydown', (e) => { if (e.key === 'Escape') closePopover(); });
      window.addEventListener('scroll', closePopover, { passive: true });
    }

    function openPopover(btn, data, key) {
      closePopover();
      if (!data) return;
      const pop = document.createElement('div');
      pop.className = 'cite-popover';
      pop.setAttribute('role', 'tooltip');
      pop.innerHTML = `<p>${data.text}</p><a href="${data.href}" target="_blank" rel="noopener noreferrer">${data.label}</a>`;
      pop.addEventListener('click', (e) => e.stopPropagation());
      document.body.appendChild(pop);

      const rect = btn.getBoundingClientRect();
      const popRect = pop.getBoundingClientRect();
      let left = rect.left + window.scrollX - popRect.width / 2 + rect.width / 2;
      left = Math.max(16, Math.min(left, window.innerWidth - popRect.width - 16));
      const top = rect.bottom + window.scrollY + 10;
      pop.style.left = left + 'px';
      pop.style.top = top + 'px';

      btn.setAttribute('aria-expanded', 'true');
      activePopover = { el: pop, key, btn };
    }

    function closePopover() {
      if (activePopover) {
        activePopover.el.remove();
        activePopover.btn.setAttribute('aria-expanded', 'false');
        activePopover = null;
      }
    }

    // ---- NODE NETWORK VISUALIZATION (Emergent Humanity Simulation) ----
    // ---- NODE NETWORK VISUALIZATION (Emergent Humanity Interactive Simulation) ----
    function initNodeNetwork() {
      const canvas = document.getElementById('nodeCanvas');
      if (!canvas) return;
      const ctx = canvas.getContext('2d');
      const reduceMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

      let mouse = { x: null, y: null, active: false };
      let draggedNode = null;
      let pulses = [];

      function resizeCanvas() {
        const rect = canvas.parentElement.getBoundingClientRect();
        canvas.width = rect.width * 2;
        canvas.height = rect.height * 2;
        ctx.setTransform(2, 0, 0, 2, 0, 0);
      }

      const NODE_COUNT = 18;
      let nodes = [];

      function initNodes() {
        const rect = canvas.parentElement.getBoundingClientRect();
        nodes = Array.from({ length: NODE_COUNT }, () => ({
          x: Math.random() * rect.width,
          y: Math.random() * rect.height,
          vx: (Math.random() - 0.5) * 0.22,
          vy: (Math.random() - 0.5) * 0.22,
          r: 2.8 + Math.random() * 2.2,
          signal: 0
        }));
      }

      canvas.addEventListener('mousemove', (e) => {
        const rect = canvas.getBoundingClientRect();
        mouse.x = e.clientX - rect.left;
        mouse.y = e.clientY - rect.top;
        mouse.active = true;

        if (draggedNode) {
          draggedNode.x = mouse.x;
          draggedNode.y = mouse.y;
          canvas.style.cursor = 'grabbing';
        } else {
          const hovered = nodes.some(n => Math.hypot(n.x - mouse.x, n.y - mouse.y) < 14);
          canvas.style.cursor = hovered ? 'pointer' : 'default';
        }
      });

      canvas.addEventListener('mouseleave', () => {
        mouse.active = false;
        draggedNode = null;
        canvas.style.cursor = 'default';
      });

      canvas.addEventListener('mousedown', (e) => {
        const rect = canvas.getBoundingClientRect();
        const mx = e.clientX - rect.left;
        const my = e.clientY - rect.top;
        const target = nodes.find(n => Math.hypot(n.x - mx, n.y - my) < 16);
        if (target) {
          draggedNode = target;
          target.signal = 1;
        }
      });

      canvas.addEventListener('mouseup', () => {
        draggedNode = null;
      });

      canvas.addEventListener('click', (e) => {
        const rect = canvas.getBoundingClientRect();
        const mx = e.clientX - rect.left;
        const my = e.clientY - rect.top;
        pulses.push({ x: mx, y: my, radius: 0, maxRadius: Math.max(rect.width, rect.height) * 0.75 });
      });

      function drawFrame() {
        const rect = canvas.parentElement.getBoundingClientRect();
        ctx.clearRect(0, 0, rect.width, rect.height);

        // Update pulses
        pulses = pulses.filter(p => p.radius < p.maxRadius);
        pulses.forEach(p => {
          p.radius += 3.5;
          ctx.strokeStyle = `rgba(245, 158, 11, ${0.45 * (1 - p.radius / p.maxRadius)})`;
          ctx.lineWidth = 1.5;
          ctx.beginPath();
          ctx.arc(p.x, p.y, p.radius, 0, Math.PI * 2);
          ctx.stroke();

          // Energize nodes touched by pulse wave
          nodes.forEach(n => {
            if (Math.abs(Math.hypot(n.x - p.x, n.y - p.y) - p.radius) < 10) {
              n.signal = 1;
            }
          });
        });

        if (!reduceMotion) {
          nodes.forEach(n => {
            if (n !== draggedNode) {
              n.x += n.vx;
              n.y += n.vy;
              if (n.x < 0 || n.x > rect.width) n.vx *= -1;
              if (n.y < 0 || n.y > rect.height) n.vy *= -1;
            }
            if (n.signal > 0) n.signal = Math.max(0, n.signal - 0.02);
          });
        }

        // Draw connections
        for (let i = 0; i < nodes.length; i++) {
          for (let j = i + 1; j < nodes.length; j++) {
            const a = nodes[i], b = nodes[j];
            const d = Math.hypot(a.x - b.x, a.y - b.y);
            const maxD = rect.width * 0.38;
            if (d < maxD) {
              const alpha = 0.65 * (1 - d / maxD);
              const isSignal = a.signal > 0.2 || b.signal > 0.2;
              ctx.strokeStyle = isSignal
                ? `rgba(245, 158, 11, ${Math.min(1, alpha * 2)})`
                : `rgba(154, 91, 19, ${alpha})`;
              ctx.lineWidth = isSignal ? 1.5 : 1;
              ctx.beginPath();
              ctx.moveTo(a.x, a.y);
              ctx.lineTo(b.x, b.y);
              ctx.stroke();
            }
          }
        }

        // Draw interactive mouse bridge lines
        if (mouse.active && mouse.x !== null) {
          nodes.forEach(n => {
            const d = Math.hypot(n.x - mouse.x, n.y - mouse.y);
            const maxD = rect.width * 0.32;
            if (d < maxD) {
              ctx.strokeStyle = `rgba(245, 158, 11, ${0.75 * (1 - d / maxD)})`;
              ctx.lineWidth = 1.2;
              ctx.beginPath();
              ctx.moveTo(mouse.x, mouse.y);
              ctx.lineTo(n.x, n.y);
              ctx.stroke();
            }
          });
        }

        // Draw nodes
        nodes.forEach(n => {
          ctx.fillStyle = n.signal > 0.1 ? '#F59E0B' : '#EFEEE6';
          ctx.beginPath();
          ctx.arc(n.x, n.y, n.r + (n.signal * 2), 0, Math.PI * 2);
          ctx.fill();
        });

        if (!reduceMotion) requestAnimationFrame(drawFrame);
      }

      function setup() {
        resizeCanvas();
        initNodes();
        drawFrame();
      }

      setup();
      window.addEventListener('resize', () => {
        ctx.setTransform(1, 0, 0, 1, 0, 0);
        setup();
      });
    }

