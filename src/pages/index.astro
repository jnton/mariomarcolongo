---
import Layout from "../layouts/Layout.astro";
import SiteNav from "../components/SiteNav.astro";
import SiteFooter from "../components/SiteFooter.astro";
import "../styles/portfolio-v5.css";
import "../styles/portfolio-v6-overrides.css";
import D from "../../data/source.js";
import H from "../../data/portfolio-human.js";
import { buildProfileGraph } from "../lib/structured-data.js";

const pageTitle = "Mario Marcolongo — AI Evaluation, Scientific Evidence & Research Operations";
const pageDescription = "AI model-behavior evaluation, paid scientific verification, research and product operations, knowledge integrity and public data quality.";
const profileJsonLd = buildProfileGraph(D, "https://mariomarcolongo.com/", pageTitle);

const responsiveSource = (src) => src.endsWith("-800.webp")
  ? `${src.replace("-800.webp", "-400.webp")} 400w, ${src} 800w`
  : undefined;

const selectedExperience = [
  D.experience.find((item) => item.role?.includes("Model-Behavior")),
  D.experience.find((item) => item.org?.includes("Entropy for Life")),
  D.experience.find((item) => item.org?.includes("Yourself to Science")),
  D.experience.find((item) => item.role?.includes("Focus-Group")),
  D.experience.find((item) => item.org?.includes("Wikipedia"))
].filter(Boolean);
---

<Layout title={pageTitle} description={pageDescription} canonical="https://mariomarcolongo.com/">
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(profileJsonLd)}></script>
  </Fragment>

  <SiteNav activePage="home" />

  <main class="portfolio-v5" id="content">
    <section class="p5-hero" aria-labelledby="portfolio-title">
      <div class="p5-hero-copy">
        <div class="p5-kicker">{H.eyebrow}</div>
        <h1 id="portfolio-title">{H.headline}</h1>
        <p>{H.introduction}</p>
        <div class="p5-actions">
          <a class="p5-button p5-button-primary" href="#selected-work">View selected work</a>
          <a class="p5-button" href="#applications">Choose a targeted CV</a>
        </div>
        <p class="p5-availability">Based in Italy · EU work authorization · open to worldwide relocation and international contracting</p>
      </div>

      <div class="p5-work-mosaic" aria-label="Selected public work and link destinations">
        {H.heroWork.map((item, index) => (
          <a
            class={`p5-work-tile p5-work-tile-${item.theme}`}
            href={item.href}
            target={item.href.startsWith("http") ? "_blank" : undefined}
            rel={item.href.startsWith("http") ? "noopener noreferrer" : undefined}
          >
            <div class="p5-work-visual" aria-hidden="true">
              <span class="p5-work-index">{String(index + 1).padStart(2, "0")}</span>
              <span class="p5-work-domain">{item.domain}</span>
              <strong class="p5-work-metric">{item.metric}</strong>
              <span class="p5-work-metric-label">{item.metricLabel}</span>
              <div class="p5-work-tags">
                {item.tags.map((tag) => <span>{tag}</span>)}
              </div>
            </div>
            <div class="p5-work-caption">
              <strong>{item.title}</strong>
              <span>{item.label}</span>
              <small>{item.linkLabel} →</small>
            </div>
          </a>
        ))}
      </div>
    </section>

    <section class="p5-proof-grid" aria-label="Selected evidence">
      {H.proofs.map((item) => (
        <a class="p5-proof" href={item.href} target={item.href.startsWith("http") ? "_blank" : undefined} rel={item.href.startsWith("http") ? "noopener noreferrer" : undefined}>
          <strong>{item.value}</strong>
          <span>{item.label}</span>
          <small>{item.detail}</small>
        </a>
      ))}
    </section>

    <section class="p5-section" id="selected-work" data-testid="human-work" aria-labelledby="selected-work-title">
      <div class="p5-section-head">
        <div>
          <div class="p5-kicker">Selected work</div>
          <h2 id="selected-work-title">Evidence for the next role—and the path after it.</h2>
        </div>
        <p>AI evaluation and model behavior lead the portfolio, followed by paid scientific verification and research/product operations. Senior red-team engineering remains a longer-term path requiring stronger independent coding and security evidence.</p>
      </div>

      <div class="p5-flagship-grid" data-testid="human-capabilities">
        {H.flagships.map((item) => (
          <article class="p5-flagship">
            <div class="p5-flagship-media">
              <div class={`p5-case-cover p5-case-cover-${item.theme}`}>
                <span class="p5-case-eyebrow">{item.visualEyebrow}</span>
                <strong>{item.metric}</strong>
                <span>{item.metricLabel}</span>
                <div class="p5-case-details">
                  {item.details.map((detail) => <span class="p5-case-detail">{detail}</span>)}
                </div>
                <span class="p5-case-destination">{item.destination}</span>
              </div>
            </div>
            <div class="p5-flagship-body">
              <div class="p5-card-label">{item.label}</div>
              <h3>{item.title}</h3>
              <p>{item.summary}</p>
              <p class="p5-proof-line">{item.proof}</p>
              <a class="p5-link" href={item.href} target={item.href.startsWith("http") ? "_blank" : undefined} rel={item.href.startsWith("http") ? "noopener noreferrer" : undefined}>{item.linkLabel}</a>
            </div>
          </article>
        ))}
      </div>
    </section>

    <section class="p5-section" id="products" aria-labelledby="products-title">
      <div class="p5-section-head">
        <div>
          <div class="p5-kicker">Products and systems</div>
          <h2 id="products-title">Public tools with a clear job to do.</h2>
        </div>
        <p>These projects show requirements definition, functional testing, deployment diagnosis and operational maintenance. They do not imply unaided software development.</p>
      </div>
      <div class="p5-products">
        {H.products.map((item) => (
          <article class={`p5-product ${item.title.includes("Wikipedia") ? "p5-product-bot" : ""}`}>
            <img src={item.image} srcset={responsiveSource(item.image)} sizes="(max-width: 680px) 86vw, (max-width: 980px) 48vw, 380px" alt={item.alt} width="760" height="480" loading="lazy" decoding="async" />
            <div class="p5-product-body">
              <div class="p5-product-label">{item.label}</div>
              <h3>{item.title}</h3>
              <p>{item.body}</p>
              <a class="p5-link" href={item.href} target="_blank" rel="noopener noreferrer">Open official project</a>
            </div>
          </article>
        ))}
      </div>
    </section>

    <section class="p5-section" id="visuals" aria-labelledby="visuals-title">
      <div class="p5-section-head">
        <div>
          <div class="p5-kicker">Data and visual analysis</div>
          <h2 id="visuals-title">Three inspectable public artifacts.</h2>
        </div>
        <p>Each card opens a specific work or a deliberately curated portfolio. The Wikimedia link now points to the strongest autism-related visualization rather than an undifferentiated upload history.</p>
      </div>
      <div class="p5-visuals">
        {H.visualization.map((item) => (
          <article class="p5-visual">
            <img src={item.image} srcset={responsiveSource(item.image)} sizes="(max-width: 680px) 86vw, (max-width: 980px) 48vw, 380px" alt={item.alt} width="760" height="480" loading="lazy" decoding="async" />
            <div class="p5-visual-body">
              <h3>{item.title}</h3>
              <p>{item.body}</p>
              <a class="p5-link" href={item.href} target="_blank" rel="noopener noreferrer">View the public artifact</a>
            </div>
          </article>
        ))}
      </div>
    </section>

    <section class="p5-section" id="operating-style" aria-labelledby="operating-style-title">
      <div class="p5-section-head">
        <div>
          <div class="p5-kicker">Operating profile</div>
          <h2 id="operating-style-title">Built for teams that reward independent judgment.</h2>
        </div>
        <p>This is the defensible version of the “unusual person” signal: direct reasoning, low deference to weak consensus, comfort with sensitive or ambiguous problems and explicit ownership of outcomes.</p>
      </div>
      <div class="p5-operating-layout">
        <article class="p5-operating-disclosure">
          <span>{H.workingStyle.label}</span>
          <h3>{H.workingStyle.title}</h3>
          <p>{H.workingStyle.body}</p>
        </article>
        <div class="p5-principles" aria-label="Working principles">
          {H.workingPrinciples.map((item) => (
            <article class="p5-principle">
              <h3>{item.title}</h3>
              <p>{item.body}</p>
            </article>
          ))}
        </div>
      </div>
    </section>

    <section class="p5-section" id="experience" aria-labelledby="experience-title">
      <div class="p5-section-head">
        <div>
          <div class="p5-kicker">Experience</div>
          <h2 id="experience-title">A concise record, with deeper evidence available.</h2>
        </div>
        <p>The focus-group collaboration is named and verifiable here, but kept proportional to its role as supporting evidence for participant-facing research and trust-and-safety work.</p>
      </div>
      <div class="p5-experience-list">
        {selectedExperience.map((item) => (
          <article class="p5-experience">
            <time>{item.period}</time>
            <div>
              <h3>{item.role}</h3>
              <p><strong>{item.org}</strong> · {item.tag}. {item.resumeBullets?.[0] || item.bullets?.[0]}</p>
            </div>
          </article>
        ))}
      </div>
    </section>

    <section class="p5-section" id="applications" data-testid="human-documents" aria-labelledby="applications-title">
      <div class="p5-section-head">
        <div>
          <div class="p5-kicker">Application documents</div>
          <h2 id="applications-title">Use the version matched to the role.</h2>
        </div>
        <p>The first document targets the strongest immediate high-upside lane. Scientific-AI quality and knowledge integrity are parallel routes; editorial/community operations remains a bridge option.</p>
      </div>
      <div class="p5-documents">
        {H.applicationDocuments.map((item) => (
          <a class="p5-document" href={item.href}>
            <h3>{item.title}</h3>
            <p>{item.description}</p>
            <span class="p5-link">Open CV →</span>
          </a>
        ))}
      </div>
    </section>

    <section class="p5-contact" id="contact" aria-labelledby="contact-title">
      <div>
        <h2 id="contact-title">Discuss a difficult problem.</h2>
        <p>Open to AI evaluation, model-quality and safety operations, scientific AI quality, research operations and knowledge-integrity roles where evidence, direct judgment and operational ownership matter.</p>
      </div>
      <div class="p5-actions">
        <a class="p5-button" href={`mailto:${D.identity.email}`}>Email Mario</a>
        <a class="p5-button" href={D.identity.linkedin} target="_blank" rel="noopener noreferrer">LinkedIn</a>
      </div>
    </section>
  </main>

  <SiteFooter version={D.identity.buildVersion} />
</Layout>
