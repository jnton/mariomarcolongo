    <div class="container">
      <div class="reveal">
        <div class="section-label">Core Focus</div>
        <h2 class="section-title">Where AI execution meets scientific rigor.</h2>
        <p class="section-desc">Bridging rapid AI-native prototyping, open biomedical data infrastructure, and evidence synthesis.</p>
      </div>

      <div class="pillars reveal-stagger" id="pillarGrid">
        <!-- Hydrated from source.js -->
      </div>
    </div>
  </section>

  <!-- ========================================
       FEATURED WORK — BENTO GRID SHOWCASE
       ======================================== -->
