          `\n\n## Links\n- Website: ${d.identity.domain}\n- Full profile: ${d.identity.domain}/llms-full.txt\n- Full CV: ${d.identity.domain}/cv-llm.txt\n- Email: ${d.identity.email}\n`;
      }
      if (type === 'llms-full.txt' || type === 'unified') {
        let out = `# ${d.identity.name} — Comprehensive Profile & Technical Dossier\n\n## Overview\n${d.summary}\n\n## Core Pillars\n\n`;
        (d.pillars || []).forEach((p, i) => {
          out += `### ${i + 1}. ${p.title}\n${p.lead}\n\n` +
            (p.highlights || []).map(h => `- **${h.label}**: ${h.detail}`).join('\n') + `\n\n`;
        });
        out += `## Key Projects\n\n`;
        (d.projects || []).forEach(p => {
          const linkUrl = p.links && (p.links.website || p.links.bot || p.links.github || p.links.chromeStore) ? (p.links.website || p.links.bot || p.links.github || p.links.chromeStore) : '';
          out += `### ${p.title} (${linkUrl})\n**Role**: ${p.role}\n\n${p.description}\n\n` +
            (p.highlights || []).map(im => `- ${im}`).join('\n') + `\n\n`;
        });
        out += `## Experience & Leadership\n\n`;
        (d.experience || []).forEach(e => {
          out += `### ${e.role} — ${e.org} (${e.period})\n` + (e.bullets || []).map(b => `- ${b}`).join('\n') + `\n\n`;
        });
        if (type === 'unified') {
          out += `---\n# CURRICULUM VITAE\n\n## Education & Training\n\n` +
            (d.education || []).map(ed => `- **${ed.title}** (${ed.period || ''}): ${ed.detail}`).join('\n') + `\n\n`;
        }
        return out;
      }
      if (type === 'cv-llm.txt') {
        let out = `# ${d.identity.name} — Curriculum Vitae (AI / LLM Markdown)\n> ${d.identity.headline}\n> Location: ${d.identity.location} · ${d.identity.relocation}\n\n## Executive Summary\n${d.summary}\n\n## Core Competencies\n` +
          (d.skills || []).map(s => `- ${s}`).join('\n') + `\n\n## Professional Experience\n\n`;
        (d.experience || []).forEach(e => {
          out += `### ${e.role} — ${e.org} (${e.period})\n` + (e.bullets || []).map(b => `- ${b}`).join('\n') + `\n\n`;
        });
        return out;
      }
      return null;
    }

    async function copyAiContent(fileType, btnEl) {
      const origText = btnEl.textContent;
      btnEl.textContent = 'Copying...';
      let content = generateLiveMarkdown(window.MARIO_DOSSIER, fileType);

      if (!content) {
        try {
          if (fileType === 'unified') {
            const [pRes, cRes] = await Promise.all([
              fetch('llms-full.txt'),
              fetch('cv-llm.txt')
            ]);
            const pText = pRes.ok ? await pRes.text() : '';
            const cText = cRes.ok ? await cRes.text() : '';
            content = `# MARIO MARCOLONGO — UNIFIED AI TECHNICAL DOSSIER & CV\n\n${pText}\n\n---\n\n${cText}`;
          } else {
            const res = await fetch(fileType);
            if (res.ok) content = await res.text();
          }
        } catch (err) {
          console.warn('Fetch fallback triggered for AI copy:', err);
        }
      }

      if (!content) {
        content = `# Mario Marcolongo — AI Technical Dossier\nAI-Native Systems Builder, Open Science Technologist & Empirical Data Synthesizer.\n4,317 verified Wikimedia contributions. Founder of Yourself to Science™ (yourselftoscience.org).\nView full profile online at https://mariomarcolongo.com/llms-full.txt`;
      }

      try {
        await navigator.clipboard.writeText(content);
        btnEl.textContent = '✓ Copied Markdown!';
        btnEl.style.background = 'var(--emerald)';
        btnEl.style.color = '#fff';
        setTimeout(() => {
          btnEl.textContent = origText;
          btnEl.style.background = '';
          btnEl.style.color = '';
        }, 2200);
      } catch (err) {
        btnEl.textContent = 'Failed to copy';
      }
    }
  </script>

</Layout>
