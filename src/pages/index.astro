    // ---- HYDRATE STATS ----
    function hydrateStats() {
      const grid = document.getElementById('statsGrid');
      if (!D.stats || !grid) return;

      grid.innerHTML = D.stats.map(s => `
        <div class="stat-card reveal">
          <div class="stat-value">${s.value}</div>
          <div class="stat-label">${s.label}</div>
          <div class="stat-detail">${s.detail}</div>
        </div>
      `).join('');

      grid.querySelectorAll('.reveal').forEach(el => revealObserver.observe(el));

      // Wikimedia breakdown bars
      const breakdown = document.getElementById('wikiBreakdown');
      if (D.wikimedia && D.wikimedia.breakdown && breakdown) {
        const max = Math.max(...D.wikimedia.breakdown.map(b => parseInt(b.edits.replace(/,/g, ''))));
        breakdown.innerHTML = D.wikimedia.breakdown.map(b => {
          const count = parseInt(b.edits.replace(/,/g, ''));
          const pct = (count / max * 100).toFixed(1);
          return `
            <div class="wiki-bar-item">
              <span class="wiki-bar-label">${b.platform}</span>
              <div class="wiki-bar-track">
                <div class="wiki-bar-fill" data-width="${pct}%"></div>
              </div>
              <span class="wiki-bar-count">${b.edits}</span>
            </div>
          `;
        }).join('');

        // Animate bars on scroll
        const barObserver = new IntersectionObserver((entries) => {
          entries.forEach(entry => {
            if (entry.isIntersecting) {
              entry.target.querySelectorAll('.wiki-bar-fill').forEach(bar => {
                bar.style.width = bar.dataset.width;
              });
              barObserver.unobserve(entry.target);
            }
          });
        }, { threshold: 0.3 });
        barObserver.observe(breakdown);
      }
    }

