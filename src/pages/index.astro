---
import Layout from "../layouts/Layout.astro";
import SiteNav from "../components/SiteNav.astro";
import SiteFooter from "../components/SiteFooter.astro";
import "../styles/portfolio-v8.css";
import D from "../../data/source.js";
import H from "../../data/portfolio-human.js";
import { buildProfileGraph } from "../lib/structured-data.js";

const pageTitle = "Mario Marcolongo — AI Evaluation & Scientific Fact-Checking";
const pageDescription = "Portfolio focused on AI model-behavior evaluation, scientific fact-checking and supporting research-information systems.";
const profileJsonLd = buildProfileGraph(D, "https://mariomarcolongo.com/", pageTitle);

const selectedExperience = [
  D.experience.find((item) => item.role?.includes("Model-Behavior")),
  D.experience.find((item) => item.org?.includes("Entropy for Life")),
  D.experience.find((item) => item.org?.includes("Yourself to Science"))
].filter(Boolean);

const isExternal = (href) => href.startsWith("http");
---

<Layout title={pageTitle} description={pageDescription} canonical="https://mariomarcolongo.com/">
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(profileJsonLd)}></script>
  </Fragment>

  <SiteNav activePage="home" />

  <main class="portfolio-v8" id="content">
    <section class="v8-hero" aria-labelledby="portfolio-title">
      <div class="v8-hero-copy" data-reveal>
        <div class="v8-kicker">{H.eyebrow}</div>
        <h1 id="portfolio-title">{H.headline}</h1>
        <p class="v8-hero-lede">{H.introduction}</p>
        <div class="v8-actions">
          <a class="v8-button v8-button-primary" href="#selected-work">See the work</a>
          <a class="v8-button" href="/cv-resume.html">Open the AI evaluation CV</a>
        </div>
        <p class="v8-availability">Italy · EU work authorization · worldwide relocation · international contracting</p>

        <div class="v8-proof-strip" aria-label="Selected public evidence">
          {H.proofMoments.map((item) => (
            <a
              href={item.href}
              target={isExternal(item.href) ? "_blank" : undefined}
              rel={isExternal(item.href) ? "noopener noreferrer" : undefined}
            >
              <strong>{item.value}</strong>
              <span>{item.label}</span>
              <small>{item.detail}</small>
            </a>
          ))}
        </div>
      </div>

      <div class="v8-hero-gallery" data-hero-gallery data-reveal aria-label="Selected work previews">
        {H.heroMedia.map((item, index) => (
          <a
            class={`v8-hero-shot v8-hero-shot-${index + 1}`}
            href={item.href}
            target={isExternal(item.href) ? "_blank" : undefined}
            rel={isExternal(item.href) ? "noopener noreferrer" : undefined}
            style={`--shot-index:${index}`}
          >
            <picture>
              {item.imageSet && <source srcset={item.imageSet} sizes="(max-width: 760px) 78vw, 520px" />}
              <img
                src={item.image}
                alt={item.alt}
                width="800"
                height="520"
                loading={index === 0 ? "eager" : "lazy"}
                decoding="async"
              />
            </picture>
            <span class="v8-shot-caption">
              <small>{item.label}</small>
              <strong>{item.title}</strong>
            </span>
          </a>
        ))}
      </div>
    </section>

    <section class="v8-scope-band" aria-labelledby="scope-title" data-reveal>
      <header>
        <div class="v8-kicker">Professional scope</div>
        <h2 id="scope-title">Two primary areas. One supporting capability.</h2>
      </header>
      <div class="v8-scope-grid">
        {H.scopes.map((scope) => (
          <article class={scope.label === "Supporting" ? "is-supporting" : ""}>
            <span>{scope.number} · {scope.label}</span>
            <h3>{scope.title}</h3>
            <p>{scope.body}</p>
          </article>
        ))}
      </div>
    </section>

    <section class="v8-section v8-work" id="selected-work" data-testid="human-work" aria-labelledby="selected-work-title">
      <header class="v8-section-head" data-reveal>
        <div>
          <div class="v8-kicker">Selected work</div>
          <h2 id="selected-work-title">Real artifacts, not portfolio illustrations.</h2>
        </div>
        <p>Each case shows the actual public output, my contribution and the boundary of what that work demonstrates.</p>
      </header>

      <div class="v8-case-stack" data-testid="human-capabilities">
        {H.cases.map((item, index) => (
          <article class={`v8-case v8-case-${item.tone} ${index % 2 ? "is-reversed" : ""}`} data-case={item.id} data-reveal>
            <a
              class="v8-case-media"
              href={item.href}
              target={isExternal(item.href) ? "_blank" : undefined}
              rel={isExternal(item.href) ? "noopener noreferrer" : undefined}
              aria-label={item.linkLabel}
            >
              <picture>
                {item.imageSet && <source srcset={item.imageSet} sizes="(max-width: 760px) 92vw, 720px" />}
                <img src={item.image} alt={item.alt} width="1200" height="760" loading="lazy" decoding="async" />
              </picture>
              <span>{item.imageCaption}</span>
            </a>

            <div class="v8-case-copy">
              <div class="v8-case-index">
                <span>{item.number}</span>
                <strong>{item.label}</strong>
              </div>
              <h3>{item.title}</h3>
              <p class="v8-case-lead">{item.lead}</p>

              <dl class="v8-case-details">
                <div>
                  <dt>What I did</dt>
                  <dd>{item.action}</dd>
                </div>
                <div>
                  <dt>Result</dt>
                  <dd>{item.result}</dd>
                </div>
              </dl>

              <p class="v8-scope-note"><strong>Scope:</strong> {item.boundary}</p>
              <a
                class="v8-text-link"
                href={item.href}
                target={isExternal(item.href) ? "_blank" : undefined}
                rel={isExternal(item.href) ? "noopener noreferrer" : undefined}
              >
                {item.linkLabel}<span aria-hidden="true">↗</span>
              </a>
            </div>
          </article>
        ))}
      </div>
    </section>

    <section class="v8-product" id="lab" aria-labelledby="product-title" data-reveal>
      <div class="v8-product-copy">
        <div class="v8-kicker">{H.mdpiFilter.label}</div>
        <h2 id="product-title">{H.mdpiFilter.title}</h2>
        <p>{H.mdpiFilter.body}</p>
        <small>{H.mdpiFilter.meta}</small>
        <div class="v8-actions">
          <a class="v8-button v8-button-invert" href={H.mdpiFilter.storeHref} target="_blank" rel="noopener noreferrer">{H.mdpiFilter.storeLabel}</a>
          <a class="v8-button v8-button-ghost" href={H.mdpiFilter.href} target="_blank" rel="noopener noreferrer">{H.mdpiFilter.linkLabel}</a>
        </div>
      </div>
      <div class="v8-product-gallery" aria-label="MDPI Filter screenshots">
        {H.mdpiFilter.images.map((image, index) => (
          <figure class={`v8-product-shot v8-product-shot-${index + 1}`}>
            <picture>
              <source srcset={image.srcset} sizes="(max-width: 760px) 86vw, 580px" />
              <img src={image.src} alt={image.alt} width="800" height="500" loading="lazy" decoding="async" />
            </picture>
          </figure>
        ))}
      </div>
    </section>

    <section class="v8-artifact" aria-labelledby="artifact-title" data-reveal>
      <div class="v8-artifact-copy">
        <div class="v8-kicker">{H.featuredArtifact.label}</div>
        <h2 id="artifact-title">{H.featuredArtifact.title}</h2>
        <p>{H.featuredArtifact.body}</p>
        <a class="v8-text-link v8-text-link-light" href={H.featuredArtifact.href} target="_blank" rel="noopener noreferrer">
          {H.featuredArtifact.linkLabel}<span aria-hidden="true">↗</span>
        </a>
      </div>
      <a class="v8-artifact-main" href={H.featuredArtifact.href} target="_blank" rel="noopener noreferrer" aria-label={H.featuredArtifact.linkLabel}>
        <img src={H.featuredArtifact.image} alt={H.featuredArtifact.alt} width="1100" height="720" loading="lazy" decoding="async" />
      </a>
      <div class="v8-artifact-rail" aria-label="Additional public visualizations">
        {H.visualArtifacts.map((item) => (
          <a href={item.href} target="_blank" rel="noopener noreferrer">
            <picture>
              {item.imageSet && <source srcset={item.imageSet} sizes="(max-width: 760px) 70vw, 320px" />}
              <img src={item.image} alt={item.alt} width="500" height="330" loading="lazy" decoding="async" />
            </picture>
            <span><small>{item.label}</small><strong>{item.title}</strong></span>
          </a>
        ))}
      </div>
    </section>

    <section class="v8-more" aria-labelledby="more-title" data-reveal>
      <div>
        <div class="v8-kicker">More public work</div>
        <h2 id="more-title">Useful breadth, kept out of the main story.</h2>
      </div>
      <nav aria-label="More public projects">
        {H.moreWork.map((item) => (
          <a href={item.href} target="_blank" rel="noopener noreferrer">{item.title}<span aria-hidden="true">↗</span></a>
        ))}
      </nav>
    </section>

    <section class="v8-section v8-profile" id="operating-style" aria-labelledby="profile-title">
      <header class="v8-profile-head" data-reveal>
        <div class="v8-kicker">{H.workingStyle.label}</div>
        <h2 id="profile-title">{H.workingStyle.title}</h2>
        <p>{H.workingStyle.body}</p>
      </header>
      <div class="v8-principles">
        {H.workingPrinciples.map((item, index) => (
          <article data-reveal>
            <span>{String(index + 1).padStart(2, "0")}</span>
            <h3>{item.title}</h3>
            <p>{item.body}</p>
          </article>
        ))}
      </div>
    </section>

    <section class="v8-section v8-experience" id="experience" aria-labelledby="experience-title">
      <header class="v8-section-head" data-reveal>
        <div>
          <div class="v8-kicker">Experience</div>
          <h2 id="experience-title">Relevant experience.</h2>
        </div>
        <p>The targeted CVs carry the full application detail.</p>
      </header>
      <div class="v8-experience-list">
        {selectedExperience.map((item) => (
          <article data-reveal>
            <time>{item.period}</time>
            <div>
              <h3>{item.role}</h3>
              <p><strong>{item.org}</strong> · {item.resumeBullets?.[0] || item.bullets?.[0]}</p>
            </div>
          </article>
        ))}
      </div>
    </section>

    <section class="v8-section v8-applications" id="applications" data-testid="human-documents" aria-labelledby="applications-title">
      <header class="v8-section-head" data-reveal>
        <div>
          <div class="v8-kicker">Application documents</div>
          <h2 id="applications-title">Start with the role you are hiring for.</h2>
        </div>
        <p>The AI evaluation CV is the recommended default. The others are deliberately tailored alternatives.</p>
      </header>

      <div class="v8-documents">
        {H.applicationDocuments.map((item, index) => (
          <a class={`v8-document ${index === 0 ? "is-recommended" : ""}`} href={item.href} data-reveal>
            <span>{item.recommendedFor}</span>
            <h3>{item.title}</h3>
            <p>{item.description}</p>
            <small>Open CV <i aria-hidden="true">→</i></small>
          </a>
        ))}
      </div>
    </section>

    <section class="v8-contact" id="contact" aria-labelledby="contact-title" data-reveal>
      <div>
        <span>Current focus</span>
        <h2 id="contact-title">AI evaluation and scientific evidence roles.</h2>
        <p>Especially model-behavior evaluation, scientific fact-checking, research-data quality and knowledge-integrity work.</p>
      </div>
      <div class="v8-actions">
        <a class="v8-button v8-button-light" href={`mailto:${D.identity.email}`}>Email Mario</a>
        <a class="v8-button v8-button-ghost" href={D.identity.linkedin} target="_blank" rel="noopener noreferrer">LinkedIn</a>
      </div>
    </section>
  </main>

  <SiteFooter version={D.identity.buildVersion} />

  <script is:inline>
    (() => {
      document.documentElement.classList.add("v8-js");

      const gallery = document.querySelector("[data-hero-gallery]");
      if (gallery && !window.matchMedia("(prefers-reduced-motion: reduce)").matches) {
        let frame = 0;
        gallery.addEventListener("pointermove", (event) => {
          cancelAnimationFrame(frame);
          frame = requestAnimationFrame(() => {
            const rect = gallery.getBoundingClientRect();
            const x = ((event.clientX - rect.left) / rect.width - 0.5) * 2;
            const y = ((event.clientY - rect.top) / rect.height - 0.5) * 2;
            gallery.style.setProperty("--gallery-x", x.toFixed(3));
            gallery.style.setProperty("--gallery-y", y.toFixed(3));
          });
        });
        gallery.addEventListener("pointerleave", () => {
          gallery.style.setProperty("--gallery-x", "0");
          gallery.style.setProperty("--gallery-y", "0");
        });
      }

      if (!window.matchMedia("(prefers-reduced-motion: reduce)").matches) {
        const observer = new IntersectionObserver((entries) => {
          entries.forEach((entry) => {
            if (entry.isIntersecting) {
              entry.target.classList.add("is-visible");
              observer.unobserve(entry.target);
            }
          });
        }, { threshold: 0.08 });
        document.querySelectorAll("[data-reveal]").forEach((element) => observer.observe(element));
      } else {
        document.querySelectorAll("[data-reveal]").forEach((element) => element.classList.add("is-visible"));
      }
    })();
  </script>
</Layout>
