            "operatingSystem": "Browser Extension / Node.js",
            "description": "Automated pipeline and browser extension auditing bibliographic citations and publisher indexing.",
            "author": { "@id": "https://mariomarcolongo.com/#person" }
          },
          {
            "@type": "CreativeWork",
            "@id": "https://emergent-humanity.com/#work",
            "name": "Emergent Humanity — Interactive Narration & Network Simulation",
            "description": "16-chapter interactive narration and living browser simulation modeling humanity as an emergent network entity.",
            "url": "https://emergent-humanity.com",
            "author": { "@id": "https://mariomarcolongo.com/#person" }
          },
          {
            "@type": "CreativeWork",
            "@id": "https://mariomarcolongo.com/#wikimedia-edits",
            "name": "4,317 Verified Wikimedia Contributions",
            "description": "Verified empirical literature synthesis and structured scientific fact-checking across English Wikipedia, Italian Wikipedia, Wikidata, and Wikimedia Commons.",
            "url": "https://commons.wikimedia.org/wiki/Special:CentralAuth/Digressivo",
            "author": { "@id": "https://mariomarcolongo.com/#person" }
          },
          {
            "@type": "Dataset",
            "@id": "https://mariomarcolongo.com/#genomic-dataset",
            "name": "41× Whole Genome Sequencing Raw Paired-End FASTQ Reads (DNBSEQ-T7)",
            "description": "Personal 41× Whole Genome Sequencing raw paired-end FASTQ reads (DNBSEQ-T7) and high-coverage GRCh38 BAM alignments released to the public domain (CC0) under ENA BioSample SAMEA121950568 and Study PRJEB109744.",
            "license": "https://creativecommons.org/publicdomain/zero/1.0/",
            "creator": { "@id": "https://mariomarcolongo.com/#person" },
            "url": "https://www.ebi.ac.uk/ena/browser/view/PRJEB109744"
          },
          {
            "@type": "SoftwareSourceCode",
            "@id": "https://mariomarcolongo.com/#genomic-pipeline",
            "name": "Polygenic Risk Scoring & Genomic Extraction Pipeline (git-nome)",
            "description": "Personal genomics workflow and open-data pipeline processing raw FASTQ reads via Terra.bio cloud bioinformatics platform to extract high-coverage GRCh38 BAM alignments and VCF variant call files, transforming VCF datasets to Plink2 format and executing Nextflow pgsc_calc with ancestry projection against reference panels, along with custom Python VEP extraction scripts calculating multi-trait Polygenic Risk Scores mapped to HPO/MONDO ontologies.",
