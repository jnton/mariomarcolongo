  <script is:inline>
    const D = window.MARIO_DOSSIER || {};

    function toggleTheme() {
      const html = document.documentElement;
      const next =
        html.getAttribute("data-theme") === "dark" ? "light" : "dark";
      html.setAttribute("data-theme", next);
      document.getElementById("themeBtn").textContent =
        next === "dark" ? "Light Mode" : "Dark Mode";
      try {
        localStorage.setItem("mm-theme", next);
      } catch (e) {}
    }

    try {
      const saved = localStorage.getItem("mm-theme");
      if (saved) {
        document.documentElement.setAttribute("data-theme", saved);
        document.getElementById("themeBtn").textContent =
          saved === "dark" ? "Light Mode" : "Dark Mode";
      }
    } catch (e) {}

    function printCV() {
      injectPrivateData();
      setTimeout(() => window.print(), 100);
    }

    function injectPrivateData() {
      const priv = window.MARIO_PRIVATE || {};
      const phoneSlot = document.getElementById("cvPhoneSlot");

      if (priv.phone && phoneSlot) {
        phoneSlot.innerHTML = `· <a href="tel:${priv.phone.replace(/\\s/g, "")}">${priv.phone}</a>`;
        phoneSlot.classList.add("has-phone");
      }
    }

    function renderLinksHtml(links) {
      if (!links) return "";
      const items = [];
      if (links.website)
        items.push(
          `<a href="${links.website}" target="_blank" rel="noopener noreferrer">Website</a>`,
        );
      if (links.github)
        items.push(
          `<a href="${links.github}" target="_blank" rel="noopener noreferrer">GitHub</a>`,
        );
      if (links.chromeStore)
        items.push(
          `<a href="${links.chromeStore}" target="_blank" rel="noopener noreferrer">Chrome Web Store</a>`,
        );
      if (links.edgeStore)
        items.push(
          `<a href="${links.edgeStore}" target="_blank" rel="noopener noreferrer">Edge Add-ons</a>`,
        );
      if (links.bot)
        items.push(
          `<a href="${links.bot}" target="_blank" rel="noopener noreferrer">Telegram Bot</a>`,
        );
      if (links.youtube)
        items.push(
          `<a href="${links.youtube}" target="_blank" rel="noopener noreferrer">YouTube</a>`,
        );
      if (links.playlist)
        items.push(
          `<a href="${links.playlist}" target="_blank" rel="noopener noreferrer">Videos & Documentaries</a>`,
        );
      if (links.authorPage)
        items.push(
          `<a href="${links.authorPage}" target="_blank" rel="noopener noreferrer">Author Page</a>`,
        );
      if (links.tableau)
        items.push(
          `<a href="${links.tableau}" target="_blank" rel="noopener noreferrer">Tableau Portfolio</a>`,
        );
      if (links.flourish)
        items.push(
          `<a href="${links.flourish}" target="_blank" rel="noopener noreferrer">Flourish Portfolio</a>`,
        );
      if (items.length === 0) return "";
      return ` · ` + items.join(" · ");
    }

    function linkifyUrls(text) {
      if (!text) return "";
      return text.replace(/(https?:\/\/[^\s<)]+)/g, '<a href="$1" target="_blank" rel="noopener noreferrer">$1</a>');
    }

    window.addEventListener("DOMContentLoaded", () => {
      if (D.summary) {
        const sumEl = document.getElementById("cvSummary");
        if (sumEl) sumEl.textContent = D.summary;
      }

      if (D.skills && Array.isArray(D.skills)) {
        const list = document.getElementById("skillsList");
        if (list) {
          list.innerHTML = D.skills
            .map((s) => {
              const colonIdx = s.indexOf(":");
              const title = colonIdx !== -1 ? s.slice(0, colonIdx).trim() : "Skill";
              let detail = colonIdx !== -1 ? s.slice(colonIdx + 1).trim() : s;
              detail = linkifyUrls(detail);
              return `<div class="skill-category">
                <strong class="skill-category-title">${title}</strong>
                <span class="skill-category-detail">${detail}</span>
              </div>`;
            })
            .join("");
        }
      }

      if (D.projects && Array.isArray(D.projects)) {
        const projList = document.getElementById("projectsList");
        if (projList) {
          projList.innerHTML = D.projects
            .map(
              (p) => `
          <div class="cv-item">
            <div class="cv-item-header">
              <span class="cv-item-title">${p.title}</span>
              ${p.period ? `<span class="cv-item-date">${p.period}</span>` : ""}
            </div>
            ${p.role ? `<div class="cv-item-org">${p.role}${renderLinksHtml(p.links)}</div>` : ""}
            ${
              p.highlights && p.highlights.length
                ? `
              <ul class="cv-item-bullets">
                ${p.highlights.map((h) => `<li>${linkifyUrls(h)}</li>`).join("")}
              </ul>
            `
                : ""
            }
          </div>
        `,
            )
            .join("");
        }
      }

      if (D.experience && Array.isArray(D.experience)) {
        const expList = document.getElementById("experienceList");
        if (expList) {
          expList.innerHTML = D.experience
            .map(
              (e) => `
          <div class="cv-item">
            <div class="cv-item-header">
              <span class="cv-item-title">${e.role}</span>
              ${e.tag ? `<span class="cv-role-tag">${e.tag}</span>` : ""}
              ${e.period ? `<span class="cv-item-date">${e.period}</span>` : ""}
            </div>
            ${e.org ? `<div class="cv-item-org">${e.org}${renderLinksHtml(e.links)}</div>` : ""}
            ${
              e.bullets && e.bullets.length
                ? `
              <ul class="cv-item-bullets">
                ${e.bullets.map((b) => `<li>${linkifyUrls(b)}</li>`).join("")}
              </ul>
            `
                : ""
            }
          </div>
        `,
            )
            .join("");
        }
      }

      if (D.research && Array.isArray(D.research)) {
        const resList = document.getElementById("researchList");
        if (resList) {
          resList.innerHTML = D.research
            .map(
              (r) => `
          <div class="cv-item">
            <div class="cv-item-header">
              <span class="cv-item-title">${r.role}</span>
              ${r.tag ? `<span class="cv-role-tag">${r.tag}</span>` : ""}
              ${r.period ? `<span class="cv-item-date">${r.period}</span>` : ""}
            </div>
            ${r.org ? `<div class="cv-item-org">${r.org}${renderLinksHtml(r.links)}</div>` : ""}
            ${
              r.bullets && r.bullets.length
                ? `
              <ul class="cv-item-bullets">
                ${r.bullets.map((b) => `<li>${linkifyUrls(b)}</li>`).join("")}
              </ul>
            `
                : ""
            }
          </div>
        `,
            )
            .join("");
        }
      }

      if (D.education && Array.isArray(D.education)) {
        const edList = document.getElementById("educationList");
        if (edList) {
          edList.innerHTML = D.education
            .map(
              (e) => `
          <div class="edu-item">
            <span class="edu-title">${e.title}</span>
            ${e.detail ? ` — <span class="edu-detail">${linkifyUrls(e.detail)}</span>` : ""}
            ${e.period ? ` <span class="edu-period">(${e.period})</span>` : ""}
          </div>
        `,
            )
            .join("");
        }
      }

      injectPrivateData();

      // ---- SCROLL PROGRESS FALLBACK ----
      if (!CSS.supports("animation-timeline", "scroll()")) {
        const prog = document.getElementById("scrollProgress");
        if (prog) {
          window.addEventListener(
            "scroll",
            () => {
              const scrollable =
                document.documentElement.scrollHeight - window.innerHeight;
              prog.style.transform = `scaleX(${scrollable > 0 ? window.scrollY / scrollable : 0})`;
            },
            { passive: true },
          );
        }
      }
    });

    async function copyCvForAI(btnEl) {
      const origText = btnEl.textContent;
      btnEl.textContent = "Copying...";
      let content = "";

      const d = window.MARIO_DOSSIER;
      if (d) {
        content =
          `# ${d.identity.name} — Curriculum Vitae (AI / LLM Markdown)\n> ${d.identity.headline}\n> Location: ${d.identity.location} · ${d.identity.relocation}\n\n## Executive Summary\n${d.summary}\n\n## Core Competencies\n` +
          (d.skills || []).map((s) => `- ${s}`).join("\n") +
          `\n\n## Professional Experience\n\n`;
        (d.experience || []).forEach((e) => {
          content +=
            `### ${e.role} — ${e.org} (${e.period})\n` +
            (e.bullets || []).map((b) => `- ${b}`).join("\n") +
            `\n\n`;
        });
      }

      if (!content) {
        try {
          const res = await fetch("cv-llm.txt");
          if (res.ok) content = await res.text();
        } catch (err) {
          console.warn("Fetch fallback for CV AI Copy:", err);
        }
      }

      if (!content) {
        content = `# Mario Marcolongo — Scientific AI Evaluation & Research Data Specialist (AI / LLM Compatible Markdown)
> Scientific AI Evaluation & Research Data Specialist
> Work Authorization: Italy (Italian Citizen) · Unrestricted EU Work Authorization & Global B2B Partita IVA

## Executive Summary
4,317 verified Wikimedia contributions. Founder of Yourself to Science™ (yourselftoscience.org). Creator of Emergent Humanity. Primary source verification, open science infrastructure, and high-agency execution.
View full CV online: https://mariomarcolongo.com/cv.html or profile at https://mariomarcolongo.com/llms-full.txt`;
      }

      try {
        await navigator.clipboard.writeText(content);
        btnEl.textContent = "✓ Copied AI CV!";
        btnEl.style.background = "var(--emerald, #10B981)";
        btnEl.style.color = "#fff";
        setTimeout(() => {
          btnEl.textContent = origText;
          btnEl.style.background = "";
          btnEl.style.color = "";
        }, 2200);
      } catch (err) {
        btnEl.textContent = "Failed to copy";
        setTimeout(() => (btnEl.textContent = origText), 2000);
      }
    }
  </script>

