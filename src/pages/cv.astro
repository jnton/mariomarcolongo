            "author": { "@id": "https://mariomarcolongo.com/#person" }
          }
        ]
      }
    </script>
  </Fragment>

  <SiteNav activePage="cv" />

  <div class="wrap" style="padding-top: 60px;">
    <!-- Toolbar — web only, hidden on print -->
    <div class="toolbar print-hide">
      <div class="toolbar-left">
        <span>Machine-Actionable Curriculum Vitae</span>
      </div>
      <div class="toolbar-right">
        <a href="/cv-resume.html" class="btn">2-Page Résumé</a>
        <button
          class="btn btn-ai"
          onclick="copyCvForAI(this)"
          title="Copy complete CV in AI-compatible Markdown format"
          >✨ Copy for AI (Markdown)</button
        >
        <button class="btn btn-primary" onclick="printCV()"
          >Print / Save PDF</button
        >
      </div>
    </div>

    <!-- CV Document -->
    <article class="cv" id="cvDocument">
      <header class="cv-header">
        <div class="cv-header-top">
          <h1 class="cv-name" id="cvName">{D.identity.name}</h1>
          <span class="cv-version-pill print-hide"
            >Curriculum Vitae v2026.07.21 · Updated: July 2026</span
          >
        </div>
        <p class="cv-tagline" id="cvTagline">
          {D.identity.jobTitle} | {D.identity.secondaryTitle}
        </p>

        <div class="cv-contact" id="cvContact">
          <span id="cvLocation">{D.identity.relocationVisible}</span>
          <span>·</span>
          <a href="https://mariomarcolongo.com">mariomarcolongo.com</a>
          <span>·</span>
          <a href={`mailto:${D.identity.email}`}>{D.identity.email}</a>
          <span>·</span>
          <a
            href={D.identity.orcidUrl}
            target="_blank"
            rel="noopener noreferrer">ORCID: {D.identity.orcid}</a
          >
          <span>·</span>
          <a
            href={D.identity.linkedin}
            target="_blank"
            rel="noopener noreferrer">LinkedIn</a
          >
          <span>·</span>
          <a
            href={D.identity.github}
            target="_blank"
            rel="noopener noreferrer">GitHub</a
          >
          <span class="cv-phone" id="cvPhoneSlot"></span>
        </div>
      </header>

      <!-- SUMMARY -->
      <section class="cv-section">
        <h2 class="cv-section-heading">Executive Summary</h2>
        <p class="cv-summary" id="cvSummary">
          {D.summary}
        </p>
      </section>

      <!-- EXPERIENCE -->
      <section class="cv-section" id="sectionExperience">
        <h2 class="cv-section-heading">
          Professional Experience & Open Science Leadership
        </h2>
        <div id="experienceList">
          {D.experience.map((item) => {
            const linksList = renderLinksJsx(item.links);
            return (
              <div class="cv-item">
                <div class="cv-item-header">
                  <span class="cv-item-title">{item.role}</span>
                  {item.tag && <span class="cv-role-tag">{item.tag}</span>}
                  {item.period && <span class="cv-item-date">{item.period}</span>}
                </div>
                {item.org && (
                  <div class="cv-item-org">
                    {item.org}
                    {linksList.map((lk) => (
                      lk && lk.url ? <> · <a href={lk.url} target="_blank" rel="noopener noreferrer">{lk.label}</a></> : null
                    ))}
                  </div>
                )}
                {item.bullets && item.bullets.length > 0 && (
                  <ul class="cv-item-bullets">
                    {item.bullets.map((b) => (
                      <li set:html={b} />
                    ))}
                  </ul>
                )}
              </div>
            );
          })}
        </div>
      </section>

      <!-- RESEARCH -->
      <section class="cv-section" id="sectionResearch">
        <h2 class="cv-section-heading">
          Genomic & Computational Science Contributions
        </h2>
        <div id="researchList">
          {D.research.map((item) => {
            const linksList = renderLinksJsx(item.links);
            return (
              <div class="cv-item">
                <div class="cv-item-header">
                  <span class="cv-item-title">{item.role}</span>
                  {item.tag && <span class="cv-role-tag">{item.tag}</span>}
                  {item.period && <span class="cv-item-date">{item.period}</span>}
                </div>
                {item.org && (
                  <div class="cv-item-org">
                    {item.org}
                    {linksList.map((lk) => (
                      lk && lk.url ? <> · <a href={lk.url} target="_blank" rel="noopener noreferrer">{lk.label}</a></> : null
                    ))}
                  </div>
                )}
                {item.bullets && item.bullets.length > 0 && (
                  <ul class="cv-item-bullets">
                    {item.bullets.map((b) => (
                      <li set:html={b} />
                    ))}
                  </ul>
                )}
              </div>
            );
          })}
        </div>
      </section>

      <!-- WHAT I'VE BUILT -->
      <section class="cv-section" id="sectionProjects">
        <h2 class="cv-section-heading">
          Deployed Systems & Open-Source Projects
        </h2>
        <div id="projectsList">
          {D.projects.map((item) => {
            const linksList = renderLinksJsx(item.links);
            return (
              <div class="cv-item">
                <div class="cv-item-header">
                  <span class="cv-item-title">{item.title}</span>
                  {item.period && <span class="cv-item-date">{item.period}</span>}
                </div>
                {item.role && (
                  <div class="cv-item-org">
                    {item.role}
                    {linksList.map((lk) => (
                      lk && lk.url ? <> · <a href={lk.url} target="_blank" rel="noopener noreferrer">{lk.label}</a></> : null
                    ))}
                  </div>
                )}
                {item.highlights && item.highlights.length > 0 && (
                  <ul class="cv-item-bullets">
                    {item.highlights.map((h) => (
                      <li set:html={h} />
                    ))}
                  </ul>
                )}
              </div>
            );
          })}
        </div>
      </section>

      <!-- SKILLS -->
      <section class="cv-section">
        <h2 class="cv-section-heading">
          Core Technical & Scientific Competencies
        </h2>
        <div class="skills-list" id="skillsList">
          {D.skills.map((skill) => {
            const colonIdx = skill.indexOf(":");
            const title = colonIdx !== -1 ? skill.slice(0, colonIdx).trim() : "Skill";
            const detail = colonIdx !== -1 ? skill.slice(colonIdx + 1).trim() : skill;
            return (
              <div class="skill-category">
                <strong class="skill-category-title">{title}</strong>
                <span class="skill-category-detail" set:html={detail} />
              </div>
            );
          })}
        </div>
      </section>

      <!-- EDUCATION & LANGUAGES -->
      <section class="cv-section">
        <h2 class="cv-section-heading">
          Education, Languages & Certifications
        </h2>
        <div id="educationList">
          {D.education.map((edu) => (
            <div class="edu-item">
              <span class="edu-title">{edu.title}</span>
              {edu.detail && <> — <span class="edu-detail" set:html={edu.detail} /></>}
              {edu.period && <> <span class="edu-period">({edu.period})</span></>}
            </div>
          ))}
        </div>
      </section>
    </article>
  </div>

  <script is:inline>
    function toggleTheme() {
      const html = document.documentElement;
      const next = html.dataset.theme === "dark" ? "light" : "dark";
      html.dataset.theme = next;
      const btn = document.getElementById("themeBtn");
      if (btn) btn.textContent = next === "dark" ? "Light Mode" : "Dark Mode";
      try {
        localStorage.setItem("mm-theme", next);
      } catch (err) {}
    }

    try {
      const saved = localStorage.getItem("mm-theme");
      if (saved) {
        document.documentElement.dataset.theme = saved;
        const btn = document.getElementById("themeBtn");
        if (btn) btn.textContent = saved === "dark" ? "Light Mode" : "Dark Mode";
      }
    } catch (err) {}

    function printCV() {
      injectPrivateData();
      setTimeout(() => window.print(), 100);
    }

    function injectPrivateData() {
      const priv = (typeof window !== "undefined" && window._privateData) ? window._privateData : {};
      const phoneSlot = document.getElementById("cvPhoneSlot");

      if (priv.phone && phoneSlot) {
        phoneSlot.innerHTML = `· <a href="tel:${priv.phone.replaceAll(/\s+/g, "")}">${priv.phone}</a>`;
        phoneSlot.classList.add("has-phone");
      }
    }

    window.addEventListener("DOMContentLoaded", () => {
      injectPrivateData();

      // ---- SCROLL PROGRESS FALLBACK ----
      if (!CSS.supports("animation-timeline", "scroll()")) {
        const prog = document.getElementById("scrollProgress");
        if (prog) {
          window.addEventListener(
            "scroll",
            () => {
              const scrollable =
                document.documentElement.scrollHeight - window.innerHeight;
              prog.style.transform = `scaleX(${scrollable > 0 ? window.scrollY / scrollable : 0})`;
            },
            { passive: true },
          );
        }
      }
    });

    async function copyCvForAI(btnEl) {
      const origText = btnEl.textContent;
      btnEl.textContent = "Copying...";
      let content = null;

      try {
        const res = await fetch("/cv-llm.txt");
        if (res.ok) {
          content = await res.text();
        } else {
          console.error("Failed to fetch /cv-llm.txt:", res.status, res.statusText);
        }
      } catch (err) {
        console.error("Fetch error for CV AI Copy:", err);
      }

      if (!content) {
        btnEl.textContent = "Unable to copy";
        setTimeout(() => (btnEl.textContent = origText), 2000);
        return;
      }

      try {
        await navigator.clipboard.writeText(content);
        btnEl.textContent = "✓ Copied AI CV!";
        btnEl.style.background = "var(--emerald, #10B981)";
        btnEl.style.color = "#fff";
        setTimeout(() => {
          btnEl.textContent = origText;
          btnEl.style.background = "";
          btnEl.style.color = "";
        }, 2200);
      } catch (err) {
        console.error("Copy error:", err);
        btnEl.textContent = "Unable to copy";
        setTimeout(() => (btnEl.textContent = origText), 2000);
      }
    }
  </script>

  <SiteFooter version="v2026.07.21" />
</Layout>
