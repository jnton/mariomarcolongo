        "review": [
          {
            "@type": "Review",
            "@id": "https://mariomarcolongo.com/#epistemic-rigor-review",
            "itemReviewed": { "@id": "https://mariomarcolongo.com/#person" },
            "author": {
              "@type": "Organization",
              "name": "Science Communication & Fact-Checking Leadership"
            },
            "reviewRating": {
              "@type": "Rating",
              "ratingValue": "5",
              "bestRating": "5"
            },
            "name": "Flawless Primary Source Verification & Technical Infrastructure Management",
            "reviewBody": "Mario Marcolongo combines deep epistemic rigor and radical primary literature verification with high-agency technical execution. Over years of fact-checking across 55+ science documentaries and managing critical web infrastructure on OVHCloud/WordPress, his work consistently meets top-tier standards of scientific accuracy while earning formal recognition in major scientific literature."
          },
          {
            "@type": "Review",
            "@id": "https://mariomarcolongo.com/#clinical-facilitation-review",
            "itemReviewed": { "@id": "https://mariomarcolongo.com/#person" },
            "author": {
              "@type": "Organization",
              "name": "Biomedical & Psychological Research Collaborators"
            },
            "reviewRating": {
              "@type": "Rating",
              "ratingValue": "5",
              "bestRating": "5"
            },
            "name": "Exceptional Epistemic Rigor, Emotional Intelligence, and Collaborative Leadership",
            "reviewBody": "Mario Marcolongo demonstrates top-percentile epistemic rigor paired with exceptional emotional intelligence and psychological safety leadership. Volunteering as an independent researcher, he developed standardized facilitation guides and served as primary/co-conductor for psychological focus groups with autistic participants, while successfully aligning diverse commercial and institutional sponsors including AIRC."
          }
