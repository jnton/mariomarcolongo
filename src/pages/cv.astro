            "identifier": "https://orcid.org/0000-0003-2846-7115",
            "sameAs": [
              "https://github.com/jnton",
              "https://orcid.org/0000-0003-2846-7115",
              "https://www.linkedin.com/in/mario-marcolongo",
              "https://commons.wikimedia.org/wiki/Special:CentralAuth/Digressivo",
              "https://app.grayswan.ai/arena/user/6a57be70d15e123775a1e9cf",
              "https://public.tableau.com/app/profile/mario.marcolongo/vizzes"
            ],
            "hasCredential": [
              {
                "@type": "EducationalOccupationalCredential",
                "name": "GALENOS Crowd Evidence Synthesis Training",
                "credentialCategory": "Cochrane Crowd & GALENOS Systematic Review Screening Certification"
              },
              {
                "@type": "EducationalOccupationalCredential",
                "name": "EF SET English Certificate 68/100 (C1 Advanced Overall · C2 Reading/Listening · B2 Writing/Speaking)",
                "credentialCategory": "EF Standard English Test (EF SET)"
              },
              {
                "@type": "EducationalOccupationalCredential",
                "name": "Career Essentials in Generative AI",
                "credentialCategory": "Microsoft and LinkedIn Certificate"
              }
            ],
            "knowsAbout": [
              "Serverless Systems Architecture & Technical Product Delivery",
              "41× Whole Genome Sequencing Bioinformatics (Terra.bio BAM/VCF Extraction & Nextflow pgsc_calc / Local Hardware)",
              "Polygenic Risk Score (PRS) Computation & HPO/MONDO Disease Ontologies",
              "Epistemic Rigor & Primary Literature Fact-Checking",
              "FAIR Open Biobanking & Citizen Science Stewardship",
              "Psychological Focus Group Facilitation & Autistic Community Recruitment",
              "Bridging Epistemic Rigor with Public Comprehension & Institutional Collaborations (AIRC)"
            ]
          },
          {
            "@type": "SoftwareApplication",
            "@id": "https://yourselftoscience.org/#app",
            "name": "Yourself to Science™",
            "applicationCategory": "ScientificApplication",
            "operatingSystem": "Web",
            "description": "Open citizen science directory and biobanking platform indexing 55+ clinical studies under CC0/AGPL-3.0, verified in FAIRsharing and Zenodo.",
            "url": "https://yourselftoscience.org",
            "author": { "@id": "https://mariomarcolongo.com/#person" }
          },
          {
            "@type": "SoftwareApplication",
            "@id": "https://mariomarcolongo.com/#telegram-bot",
            "name": "Wikipedia Link Converter Bot",
