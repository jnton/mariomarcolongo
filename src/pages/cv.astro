---
import Layout from "../layouts/Layout.astro";
import SiteNav from "../components/SiteNav.astro";
import SiteFooter from "../components/SiteFooter.astro";
import "../styles/cv.css";
import D from "../../data/source.js";
import { buildProfileGraph } from "../lib/structured-data.js";

const pageTitle = "Mario Marcolongo — CV / Curriculum Vitae";
const pageDescription = `Curriculum Vitae of ${D.identity.name} — ${D.identity.jobTitle}.`;
const profileJsonLd = buildProfileGraph(D, "https://mariomarcolongo.com/cv.html", pageTitle);

function renderLinksJsx(links) {
  if (!links) return [];
  const entries = [
    links.website ? { label: "Website", url: links.website } : null,
    links.caseStudy ? { label: "Evaluation Record", url: links.caseStudy } : null,
    links.profile ? { label: "Profile", url: links.profile } : null,
    links.github ? { label: "GitHub", url: links.github } : null,
    links.chromeStore ? { label: "Chrome Web Store", url: links.chromeStore } : null,
    links.edgeStore ? { label: "Edge Add-ons", url: links.edgeStore } : null,
    links.bot ? { label: "Telegram Bot", url: links.bot } : null,
    links.youtube ? { label: "YouTube", url: links.youtube } : null,
    links.playlist ? { label: "Videos & Documentaries", url: links.playlist } : null,
    links.authorPage ? { label: "Author Page", url: links.authorPage } : null,
    links.tableau ? { label: "Tableau Portfolio", url: links.tableau } : null,
    links.flourish ? { label: "Flourish Portfolio", url: links.flourish } : null,
  ];
  return entries.filter((x) => x !== null && typeof x.url === "string" && typeof x.label === "string");
}
---

<Layout
  title={pageTitle}
  description={pageDescription}
  canonical="https://mariomarcolongo.com/cv.html"
>
  <Fragment slot="head">
    <script is:inline src="/data/source.js"></script>
    <script type="application/ld+json" set:html={JSON.stringify(profileJsonLd)} />
  </Fragment>

  <SiteNav activePage="cv" />

  <div class="wrap" style="padding-top: 60px;">
    <!-- Toolbar — web only, hidden on print -->
    <div class="toolbar print-hide">
      <div class="toolbar-left">
        <span>Machine-Actionable Curriculum Vitae</span>
      </div>
      <div class="toolbar-right">
        <a href="/cv-resume.html" class="btn">2-Page Résumé</a>
        <button
          class="btn btn-ai"
          onclick="copyCanonicalText('/cv-llm.txt', this, '✓ Copied AI CV!')"
          title="Copy complete CV in AI-compatible Markdown format"
          >✨ Copy for AI (Markdown)</button
        >
        <button class="btn btn-primary" onclick="printCV()"
          >Print / Save PDF</button
        >
      </div>
    </div>

    <!-- CV Document -->
    <article class="cv" id="cvDocument">
      <header class="cv-header">
        <div class="cv-header-top">
          <h1 class="cv-name" id="cvName">{D.identity.name}</h1>
          <span class="cv-version-pill print-hide"
            >{D.identity.buildVersion} · Updated: {D.identity.evaluationAsOf}</span
          >
        </div>
        <p class="cv-tagline" id="cvTagline">
          {D.identity.jobTitle} | {D.identity.secondaryTitle}
        </p>

        <div class="cv-contact" id="cvContact">
          <span id="cvLocation">{D.identity.relocationVisible}</span>
          <span>·</span>
          <a href="https://mariomarcolongo.com">mariomarcolongo.com</a>
          <span>·</span>
          <a href={`mailto:${D.identity.email}`}>{D.identity.email}</a>
          <span>·</span>
          <a
            href={D.identity.orcidUrl}
            target="_blank"
            rel="noopener noreferrer">ORCID: {D.identity.orcid}</a
          >
          <span>·</span>
          <a
            href={D.identity.linkedin}
            target="_blank"
            rel="noopener noreferrer">LinkedIn</a
          >
          <span>·</span>
          <a
            href={D.identity.github}
            target="_blank"
            rel="noopener noreferrer">GitHub</a
          >
          <span class="cv-phone" id="cvPhoneSlot"></span>
        </div>
      </header>

      <!-- SUMMARY -->
      <section class="cv-section">
        <h2 class="cv-section-heading">Executive Summary</h2>
        <p class="cv-summary" id="cvSummary">
          {D.summary}
        </p>
      </section>

      <!-- EXPERIENCE -->
      <section class="cv-section" id="sectionExperience">
        <h2 class="cv-section-heading">
          Professional Experience & Open Science Leadership
        </h2>
        <div id="experienceList">
          {D.experience.map((item) => {
            const linksList = renderLinksJsx(item.links);
            return (
              <div class="cv-item">
                <div class="cv-item-header">
                  <span class="cv-item-title">{item.role}</span>
                  {item.tag && <span class="cv-role-tag">{item.tag}</span>}
                  {item.period && <span class="cv-item-date">{item.period}</span>}
                </div>
                {item.org && (
                  <div class="cv-item-org">
                    {item.org}
                    {linksList.map((lk) => (
                      lk && lk.url ? <> · <a href={lk.url} target="_blank" rel="noopener noreferrer">{lk.label}</a></> : null
                    ))}
                  </div>
                )}
                {item.bullets && item.bullets.length > 0 && (
                  <ul class="cv-item-bullets">
                    {item.bullets.map((b) => (
                      <li set:html={b} />
                    ))}
                  </ul>
                )}
              </div>
            );
          })}
        </div>
      </section>

      <!-- RESEARCH -->
      <section class="cv-section" id="sectionResearch">
        <h2 class="cv-section-heading">
          Genomic & Computational Science Contributions
        </h2>
        <div id="researchList">
          {D.research.map((item) => {
            const linksList = renderLinksJsx(item.links);
            return (
              <div class="cv-item">
                <div class="cv-item-header">
                  <span class="cv-item-title">{item.role}</span>
                  {item.tag && <span class="cv-role-tag">{item.tag}</span>}
                  {item.period && <span class="cv-item-date">{item.period}</span>}
                </div>
                {item.org && (
                  <div class="cv-item-org">
                    {item.org}
                    {linksList.map((lk) => (
                      lk && lk.url ? <> · <a href={lk.url} target="_blank" rel="noopener noreferrer">{lk.label}</a></> : null
                    ))}
                  </div>
                )}
                {item.bullets && item.bullets.length > 0 && (
                  <ul class="cv-item-bullets">
                    {item.bullets.map((b) => (
                      <li set:html={b} />
                    ))}
                  </ul>
                )}
              </div>
            );
          })}
        </div>
      </section>

      <!-- WHAT I'VE BUILT -->
      <section class="cv-section" id="sectionProjects">
        <h2 class="cv-section-heading">
          Deployed Systems & Open-Source Projects
        </h2>
        <div id="projectsList">
          {D.projects.map((item) => {
            const linksList = renderLinksJsx(item.links);
            return (
              <div class="cv-item">
                <div class="cv-item-header">
                  <span class="cv-item-title">{item.title}</span>
                  {item.period && <span class="cv-item-date">{item.period}</span>}
                </div>
                {item.role && (
                  <div class="cv-item-org">
                    {item.role}
                    {linksList.map((lk) => (
                      lk && lk.url ? <> · <a href={lk.url} target="_blank" rel="noopener noreferrer">{lk.label}</a></> : null
                    ))}
                  </div>
                )}
                {item.highlights && item.highlights.length > 0 && (
                  <ul class="cv-item-bullets">
                    {item.highlights.map((h) => (
                      <li set:html={h} />
                    ))}
                  </ul>
                )}
              </div>
            );
          })}
        </div>
      </section>

      <!-- SKILLS -->
      <section class="cv-section">
        <h2 class="cv-section-heading">
          Core Technical & Scientific Competencies
        </h2>
        <div class="skills-list" id="skillsList">
          {D.skills.map((skill) => {
            const colonIdx = skill.indexOf(":");
            const title = colonIdx !== -1 ? skill.slice(0, colonIdx).trim() : "Skill";
            const detail = colonIdx !== -1 ? skill.slice(colonIdx + 1).trim() : skill;
            return (
              <div class="skill-category">
                <strong class="skill-category-title">{title}</strong>
                <span class="skill-category-detail" set:html={detail} />
              </div>
            );
          })}
        </div>
      </section>

      <!-- EDUCATION & LANGUAGES -->
      <section class="cv-section">
        <h2 class="cv-section-heading">
          Education, Languages & Certifications
        </h2>
        <div id="educationList">
          {D.education.map((edu) => (
            <div class="edu-item">
              <span class="edu-title">{edu.title}</span>
              {edu.period && <> <span class="edu-period">({edu.period})</span></>}
              {edu.institution && <> — <span class="edu-detail">{edu.institution}</span></>}
              {edu.status && <> · <span class="edu-status">{edu.status}</span></>}
              {edu.credentialUrl && <> · <a class="edu-credential" href={edu.credentialUrl} target="_blank" rel="noopener noreferrer">Credential</a></>}
            </div>
          ))}
        </div>
      </section>
    </article>
  </div>

  <script is:inline>
    function injectPrivateData() {
      const priv = (typeof window !== "undefined" && window._privateData) ? window._privateData : {};
      const phoneSlot = document.getElementById("cvPhoneSlot");
      if (priv.phone && phoneSlot) {
        phoneSlot.innerHTML = `· <a href="tel:${priv.phone.replaceAll(/\s+/g, "")}">${priv.phone}</a>`;
        phoneSlot.classList.add("has-phone");
      }
    }

    function printCV() {
      injectPrivateData();
      window.setTimeout(() => window.print(), 100);
    }

    window.addEventListener("DOMContentLoaded", injectPrivateData);
  </script>

  <SiteFooter version={D.identity.buildVersion} />
</Layout>
