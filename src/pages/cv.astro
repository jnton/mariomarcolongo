---
import Layout from "../layouts/Layout.astro";
import SiteNav from "../components/SiteNav.astro";
import SiteFooter from "../components/SiteFooter.astro";
import "../styles/career-v2.css";
import D from "../../data/source.js";
import P from "../../data/application-profiles.js";
import { buildProfileGraph } from "../lib/structured-data.js";

const pageTitle = "Mario Marcolongo — Master CV & Evidence Record";
const pageDescription = "Comprehensive master CV and evidence record for Mario Marcolongo. Use the specialized two-page CVs for most applications.";
const profileJsonLd = buildProfileGraph(D, "https://mariomarcolongo.com/cv.html", pageTitle);

const roleAliases = {
  "Founder & Technical Product Builder": "Founder & Research-Workflow Owner",
  "Independent Model-Behavior Evaluator": "Model-Behavior Evaluator",
  "Product Owner & Technical Builder": "Product Owner & AI-Assisted Technical Operator",
  "Creator & Systems Builder": "Creator & Technical Operator",
  "Creator & Systems Designer": "Creator & Concept and Requirements Designer"
};

const tagAliases = {
  "Independent / Self-Funded": "Independent project",
  "Independent Practitioner": "Independent practice",
  "Volunteer, unpaid": "Research or public contribution",
  "Independent / Personal Project, unpaid": "Personal open-data project",
  "VAT-Registered Independent Contractor — Italy": "Independent contractor"
};

function cleanRole(role) {
  return roleAliases[role] || role;
}

function cleanTag(tag) {
  return tagAliases[tag] || tag;
}

function cleanText(value) {
  return String(value || "")
    .replaceAll("Founder and technical builder", "Founder and research-workflow owner")
    .replaceAll("Founder & Technical Product Builder", "Founder & Research-Workflow Owner")
    .replaceAll("Product Owner & Technical Builder", "Product Owner & AI-Assisted Technical Operator")
    .replaceAll("Creator & Systems Builder", "Creator & Technical Operator")
    .replaceAll("Designed and iteratively validated a local downstream bioinformatics workflow", "Specified requirements for and iteratively validated a local downstream bioinformatics workflow")
    .replaceAll("custom Python VEP extraction scripts", "AI-assisted Python VEP extraction scripts")
    .replaceAll("Designed the analytical requirements and processed", "Defined the analytical requirements and used Terra.bio workflows to process")
    .replaceAll("codebase navigation and modification", "codebase reading and behavior inspection")
    .replaceAll("generated-code review", "code structure and behavior inspection")
    .replaceAll("debugging", "functional issue diagnosis")
    .replaceAll("technical builder", "research-workflow owner");
}

function linksFor(item) {
  if (!item.links) return [];
  const labels = {
    website: "Website",
    caseStudy: "Evaluation record",
    profile: "Public profile",
    github: "Repository",
    chromeStore: "Chrome Web Store",
    edgeStore: "Edge Add-ons",
    bot: "Telegram bot",
    playlist: "Videos & documentaries",
    authorPage: "Author page",
    tableau: "Tableau",
    flourish: "Flourish",
    doi: "Zenodo DOI",
    fairsharing: "FAIRsharing"
  };
  return Object.entries(item.links)
    .filter(([, url]) => typeof url === "string")
    .map(([key, url]) => ({ label: labels[key] || key, url }));
}
---

<Layout title={pageTitle} description={pageDescription} canonical="https://mariomarcolongo.com/cv.html">
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(profileJsonLd)}></script>
  </Fragment>

  <SiteNav activePage="cv" />

  <div class="master-shell">
    <section class="master-guidance print-hide">
      <div>
        <div class="master-eyebrow">Master source document</div>
        <h2>Comprehensive CV & evidence archive</h2>
        <p>This preserves the complete record used to create tailored applications. For most jobs, send one of the four specialized two-page CVs instead.</p>
      </div>
      <div class="application-guide-actions">
        <a class="btn btn-primary" href="/cv-resume.html">AI Safety CV</a>
        <a class="btn" href="/cv-editorial.html">Editorial & Community CV</a>
        <a class="btn" href="/cv-integrity.html">Trust & Knowledge Integrity CV</a>
        <a class="btn" href="/cv-research.html">Research & Data Quality CV</a>
        <button class="btn" type="button" onclick="window.print()">Print / Save PDF</button>
      </div>
    </section>

    <article class="master-document" id="cvDocument">
      <header class="master-header">
        <div>
          <div class="master-eyebrow">Master CV · updated July 2026</div>
          <h1 class="master-name">{P.shared.name}</h1>
          <div class="master-title">Research · Evidence · Knowledge Integrity · AI Operations</div>
          <p class="master-summary">
            Evidence-focused specialist combining paid scientific fact-checking and writing, editorial and research operations, public-source and provenance work, open research workflows, structured-data quality and adversarial model testing. Code-literate and able to inspect structure and behavior, define requirements, test implementations and guide AI-assisted technical iteration; not presented as an independent software developer.
          </p>
        </div>
        <div class="master-contact">
          <strong>Contact and mobility</strong><br />
          {P.shared.location}<br />
          <a href={`mailto:${P.shared.email}`}>{P.shared.email}</a><br />
          <a id="cvPhoneSlot" hidden></a>
          <a href={P.shared.website}>mariomarcolongo.com</a><br />
          <a href={P.shared.linkedin} target="_blank" rel="noopener noreferrer">LinkedIn ↗</a> ·
          <a href={P.shared.github} target="_blank" rel="noopener noreferrer">GitHub ↗</a><br />
          <a href={P.shared.orcid} target="_blank" rel="noopener noreferrer">ORCID ↗</a><br /><br />
          <strong>Languages</strong><br />
          Italian — native<br />
          English — C1 overall; advanced technical reading and professional/technical writing
        </div>
      </header>

      <section class="master-section">
        <h2 class="master-section-title">Professional and public experience</h2>
        {D.experience.map((item) => {
          const links = linksFor(item);
          return (
            <article class="master-entry">
              <div class="master-entry-head">
                <div>
                  <h3>{cleanRole(item.role)} {item.tag && <span class="master-tag">{cleanTag(item.tag)}</span>}</h3>
                  <div class="master-organization">{item.org}</div>
                  {links.length > 0 && (
                    <div class="application-links">
                      {links.map((link) => <a href={link.url} target={link.url.startsWith("http") ? "_blank" : undefined} rel={link.url.startsWith("http") ? "noopener noreferrer" : undefined}>{link.label} ↗</a>)}
                    </div>
                  )}
                </div>
                <span class="master-period">{item.period}</span>
              </div>
              <ul class="master-list">
                {item.bullets.map((bullet) => <li>{cleanText(bullet)}</li>)}
              </ul>
            </article>
          );
        })}
      </section>

      <section class="master-section">
        <h2 class="master-section-title">Research, datasets and visual evidence</h2>
        {D.research.map((item) => {
          const links = linksFor(item);
          return (
            <article class="master-entry">
              <div class="master-entry-head">
                <div>
                  <h3>{cleanRole(item.role)} {item.tag && <span class="master-tag">{cleanTag(item.tag)}</span>}</h3>
                  <div class="master-organization">{item.org}</div>
                  {links.length > 0 && (
                    <div class="application-links">
                      {links.map((link) => <a href={link.url} target="_blank" rel="noopener noreferrer">{link.label} ↗</a>)}
                    </div>
                  )}
                </div>
                <span class="master-period">{item.period}</span>
              </div>
              <ul class="master-list">
                {item.bullets.map((bullet) => <li>{cleanText(bullet)}</li>)}
              </ul>
            </article>
          );
        })}
      </section>

      <section class="master-section">
        <h2 class="master-section-title">Selected systems and open-source projects</h2>
        {D.projects.map((item) => {
          const links = linksFor(item);
          return (
            <article class="master-entry">
              <div class="master-entry-head">
                <div>
                  <h3>{item.title}</h3>
                  <div class="master-organization">{cleanRole(item.role)}</div>
                  {links.length > 0 && (
                    <div class="application-links">
                      {links.map((link) => <a href={link.url} target={link.url.startsWith("http") ? "_blank" : undefined} rel={link.url.startsWith("http") ? "noopener noreferrer" : undefined}>{link.label} ↗</a>)}
                    </div>
                  )}
                </div>
              </div>
              <p class="master-summary" style="margin-top: 8px;">{cleanText(item.description)}</p>
              <ul class="master-list">
                {item.highlights.map((highlight) => <li>{cleanText(highlight)}</li>)}
              </ul>
            </article>
          );
        })}
      </section>

      <section class="master-section">
        <h2 class="master-section-title">Capabilities</h2>
        {[...P.aiSafety.skills, ...P.researchQuality.skills]
          .filter((item, index, array) => array.findIndex((candidate) => candidate[0] === item[0]) === index)
          .map(([title, detail]) => (
            <div class="application-skill">
              <strong>{title}</strong>
              <span>{detail}</span>
            </div>
          ))}
      </section>

      <section class="master-section">
        <h2 class="master-section-title">Education, training and credentials</h2>
        <ul class="master-list">
          {P.shared.education.map((item) => <li>{item}</li>)}
          <li>{P.shared.language}</li>
        </ul>
      </section>
    </article>
  </div>

  <SiteFooter version={D.identity.buildVersion} />
</Layout>
