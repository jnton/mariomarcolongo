---
import Layout from "../layouts/Layout.astro";
import "../styles/cv.css";
---

<Layout
  title="Mario Marcolongo — CV / Curriculum Vitae"
  description="Curriculum Vitae of Mario Marcolongo — Primary source verification, open science infrastructure (Yourself to Science™), and empirical data synthesis."
  canonical="https://mariomarcolongo.com/cv.html"
>
  <Fragment slot="head">
    <script is:inline src="/data/source.js"></script>
    <script type="application/ld+json">
      {
        "@context": "https://schema.org",
        "@graph": [
          {
            "@type": "ProfilePage",
            "@id": "https://mariomarcolongo.com/cv.html#webpage",
            "name": "Mario Marcolongo — CV / Curriculum Vitae",
            "url": "https://mariomarcolongo.com/cv.html",
            "mainEntity": { "@id": "https://mariomarcolongo.com/#person" }
          },
          {
            "@type": "Person",
            "@id": "https://mariomarcolongo.com/#person",
            "name": "Mario Marcolongo",
            "jobTitle": "Scientific Fact-Checker & Open Science Technologist",
            "description": "Scientific fact-checker, systems developer, and open science technologist specializing in rapid empirical data synthesis, autonomous infrastructure, primary source verification, and FAIRsharing data curation.",
