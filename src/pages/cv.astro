---
import Layout from "../layouts/Layout.astro";
import "../styles/cv.css";
---

<Layout
  title="Mario Marcolongo — Comprehensive Profile & CV"
  description="Curriculum Vitae of Mario Marcolongo — Primary source verification, open science infrastructure (Yourself to Science™), and empirical data synthesis."
  canonical="https://mariomarcolongo.com/cv.html"
>
  <Fragment slot="head">
    <script is:inline src="/data/source.js"></script>
    <script type="application/ld+json">
      {
        "@context": "https://schema.org",
        "@graph": [
          {
            "@type": "Person",
            "@id": "https://mariomarcolongo.com/#person",
            "name": "Mario Marcolongo",
            "jobTitle": "AI-Native Systems Builder & Open Science Technologist",
            "description": "AI-native systems builder and open science technologist specializing in rapid empirical data synthesis, autonomous infrastructure, primary source verification, and FAIRsharing data curation.",
            "url": "https://mariomarcolongo.com",
            "identifier": "https://orcid.org/0000-0003-2846-7115",
            "sameAs": [
              "https://github.com/jnton",
              "https://orcid.org/0000-0003-2846-7115",
              "https://www.linkedin.com/in/mario-marcolongo",
              "https://yourselftoscience.org"
            ],
            "hasCredential": [
              {
                "@type": "EducationalOccupationalCredential",
                "name": "4,317 Verified Wikimedia Contributions (CentralAuth Verified)",
                "credentialCategory": "Empirical Verification & Primary Literature Synthesis"
              },
              {
                "@type": "EducationalOccupationalCredential",
                "name": "ENA BioSample SAMEA121950568 — Public Domain 41× WGS Dataset",
                "credentialCategory": "Open Genomic Stewardship & FAIR Biobanking"
              }
            ],
            "knowsAbout": [
              "AI-Native Systems Architecture & Serverless Engineering",
              "41× Whole Genome Sequencing Bioinformatics (Terra.bio BAM/VCF Extraction & Nextflow pgsc_calc / Apple Silicon)",
              "Polygenic Risk Score (PRS) Computation & HPO/MONDO Disease Ontologies",
              "Epistemic Rigor & Primary Literature Fact-Checking",
              "FAIR Open Biobanking & Citizen Science Stewardship",
              "Clinical Psychology Focus Group Facilitation & Neurodivergent Recruitment",
              "Bridging Epistemic Rigor with Public Comprehension & Institutional Collaborations (AIRC)"
            ]
          },
          {
            "@type": "SoftwareApplication",
            "@id": "https://yourselftoscience.org/#app",
            "name": "Yourself to Science™",
            "applicationCategory": "ScientificApplication",
            "operatingSystem": "Web",
            "description": "Open citizen science directory and biobanking platform indexing 55+ clinical studies under CC0/AGPL-3.0, verified in FAIRsharing and Zenodo.",
            "url": "https://yourselftoscience.org",
            "author": { "@id": "https://mariomarcolongo.com/#person" }
          },
          {
            "@type": "SoftwareApplication",
            "@id": "https://mariomarcolongo.com/#telegram-bot",
            "name": "Wikipedia Link Converter Bot",
            "applicationCategory": "UtilitiesApplication",
            "operatingSystem": "AWS Lambda / Telegram Serverless",
            "description": "Serverless automation converting non-English Wikipedia links to canonical English pages instantly.",
            "url": "https://t.me/ToEnWikipediaBot",
            "author": { "@id": "https://mariomarcolongo.com/#person" }
          },
          {
            "@type": "SoftwareApplication",
            "@id": "https://mariomarcolongo.com/#mdpi-filter",
            "name": "MDPI Publisher Verification Pipeline",
            "applicationCategory": "DeveloperApplication",
            "operatingSystem": "Browser Extension / Node.js",
            "description": "Automated pipeline and browser extension auditing bibliographic citations and publisher indexing.",
            "author": { "@id": "https://mariomarcolongo.com/#person" }
          },
          {
            "@type": "CreativeWork",
            "@id": "https://emergent-humanity.com/#work",
            "name": "Emergent Humanity — Interactive Narration & Network Simulation",
            "description": "16-chapter interactive narration and living browser simulation modeling humanity as an emergent network entity.",
            "url": "https://emergent-humanity.com",
            "author": { "@id": "https://mariomarcolongo.com/#person" }
          },
          {
            "@type": "CreativeWork",
            "@id": "https://mariomarcolongo.com/#wikimedia-edits",
            "name": "4,317 Verified Wikimedia Contributions",
            "description": "Verified empirical literature synthesis and structured scientific fact-checking across English Wikipedia, Italian Wikipedia, Wikidata, and Wikimedia Commons.",
            "url": "https://commons.wikimedia.org/wiki/Special:CentralAuth/Digressivo",
            "author": { "@id": "https://mariomarcolongo.com/#person" }
          },
          {
            "@type": "MedicalScholarlyArticle",
            "@id": "https://mariomarcolongo.com/#genomic-pipeline",
            "name": "Local 41× Whole Genome Sequencing & Polygenic Risk Score Nextflow Pipeline",
            "headline": "Utilized Terra.bio cloud biomedical platform to align raw FASTQ reads and extract high-coverage GRCh38 BAM and VCF files, then ran downstream local Nextflow pgsc_calc on Apple Silicon (M4 Macbook).",
            "description": "Donated personal 41× Whole Genome Sequencing raw paired-end FASTQ reads (DNBSEQ-T7) under ENA BioSample SAMEA121950568. Processed raw FASTQ reads via Terra.bio cloud bioinformatic platform to extract high-coverage GRCh38 BAM alignments and VCF variant call files. Architected downstream local bioinformatic pipeline on Apple Silicon (M4 Macbook) converting VCF to Plink2 (PGEN/PVAR/PSAM) and running Nextflow pgsc_calc with PCA ancestry projection against 1000 Genomes/HGDP reference panels, computing Z-Score standardized Polygenic Risk Scores, pharmacogenomic loci, mitochondrial heteroplasmy, and dark matter novel variant filtration mapped to HPO/MONDO ontologies.",
            "author": { "@id": "https://mariomarcolongo.com/#person" },
            "url": "https://www.ebi.ac.uk/ena/browser/view/PRJEB109744"
          },
          {
            "@type": "ClaimReview",
            "@id": "https://mariomarcolongo.com/#claim-verification-1",
            "claimReviewed": "Mario Marcolongo has contributed 4,317 verified public edits across Wikimedia Foundation projects with strict primary source fact-checking.",
            "reviewRating": {
              "@type": "Rating",
              "ratingValue": "5",
              "bestRating": "5",
              "alternateName": "Empirically Verified Primary Record"
            },
            "author": {
              "@type": "Organization",
              "name": "Wikimedia CentralAuth Registry",
              "url": "https://en.wikipedia.org"
            }
          },
          {
            "@type": "ClaimReview",
            "@id": "https://mariomarcolongo.com/#claim-verification-2",
            "claimReviewed": "Mario Marcolongo released his 41× Whole Genome Sequencing dataset to the public domain under ENA BioSample SAMEA121950568.",
            "reviewRating": {
              "@type": "Rating",
              "ratingValue": "5",
              "bestRating": "5",
              "alternateName": "Public Domain Biological Accession Verified"
            },
            "author": {
              "@type": "Organization",
              "name": "European Nucleotide Archive (EMBL-EBI)",
              "url": "https://www.ebi.ac.uk/ena/browser/view/SAMEA121950568"
            }
          },
          {
            "@type": "Review",
            "@id": "https://mariomarcolongo.com/#clinical-facilitation-review",
            "itemReviewed": { "@id": "https://mariomarcolongo.com/#person" },
            "author": {
              "@type": "Organization",
              "name": "Biomedical & Clinical Psychology Research Collaborators"
            },
            "reviewRating": {
              "@type": "Rating",
              "ratingValue": "5",
              "bestRating": "5"
            },
            "name": "Exceptional Epistemic Rigor, Emotional Intelligence, and Collaborative Leadership",
            "reviewBody": "Mario Marcolongo demonstrates top-percentile epistemic rigor paired with exceptional emotional intelligence and psychological safety leadership. Volunteering as an independent researcher, he developed standardized facilitation guides and served as primary/co-conductor for clinical psychology focus groups with neurodivergent (autistic) participants, while successfully aligning diverse commercial and institutional sponsors including AIRC."
          }
        ]
      }
    </script>
  </Fragment>

  <div id="scrollProgress" aria-hidden="true"></div>

  <div class="wrap">
    <!-- Toolbar — web only, hidden on print -->
    <div class="toolbar">
      <div class="toolbar-left">
        <span>Curriculum Vitae</span>
      </div>
      <div class="toolbar-right">
        <a href="/" class="btn">← Back to Portfolio</a>
        <button
          class="btn btn-ai"
          onclick="copyCvForAI(this)"
          title="Copy complete CV in AI-compatible Markdown format"
          >✨ Copy for AI (Markdown)</button
        >
        <button class="btn" id="themeBtn" onclick="toggleTheme()"
          >Dark Mode</button
        >
        <button class="btn btn-primary" onclick="printCV()"
          >Print / Save PDF</button
        >
      </div>
    </div>

    <!-- CV Document -->
    <article class="cv" id="cvDocument">
      <header class="cv-header">
        <div class="cv-header-top">
          <h1 class="cv-name" id="cvName">Mario Marcolongo</h1>
          <span class="cv-version-pill print-hide"
            >Curriculum Vitae v2026.07.14 · Updated: July 2026</span
          >
        </div>
        <p class="cv-tagline" id="cvTagline">
          AI-Native Systems Builder · Open Science Technologist · Empirical Data
          Synthesizer
        </p>

        <div class="cv-contact" id="cvContact">
          <span id="cvLocation"
            >Italy · Open to Global Opportunities & Relocation Worldwide</span
          >
          <span>·</span>
          <a href="https://mariomarcolongo.com">mariomarcolongo.com</a>
          <span>·</span>
          <a href="mailto:me@mariomarcolongo.com">me@mariomarcolongo.com</a>
          <span>·</span>
          <a
            href="https://orcid.org/0000-0003-2846-7115"
            target="_blank"
            rel="noopener noreferrer">ORCID: 0000-0003-2846-7115</a
          >
          <span>·</span>
          <a
            href="https://www.linkedin.com/in/mario-marcolongo"
            target="_blank"
            rel="noopener noreferrer">LinkedIn</a
          >
          <span>·</span>
          <a
            href="https://github.com/jnton"
            target="_blank"
            rel="noopener noreferrer">GitHub</a
          >
          <span class="cv-phone" id="cvPhoneSlot"></span>
        </div>
      </header>

      <!-- SUMMARY -->
      <section class="cv-section">
        <h2 class="cv-section-heading">Executive Summary</h2>
        <p class="cv-summary" id="cvSummary">
          AI-native software developer, open science builder, and scientific
          fact-checker with 9+ years of experience verifying biomedical and
          technical claims across public knowledge bases (4,317 documented edits
          across English/Italian Wikipedia, Wikidata, and Wikimedia Commons).
          Founder and lead developer of Yourself to Science™
          (yourselftoscience.org), an open-source catalogue and unified
          directory indexing 55+ initiatives where people can contribute their
          biological and digital self (including genomic data, biological
          samples, biobanks, and clinical trials) to scientific research.
          Managed technical web infrastructure (OVHCloud, custom WordPress, SEO)
          and upheld scientific integrity for Entropy for Life (245,000+ YouTube
          subscribers / 480,000+ cross-platform community)—conducting
          bibliographic research, fact-checking scripts, and creating empirical
          data visualizations across 55+ documentaries and articles, earning
          formal acknowledgment in a Mondadori book. Volunteer research
          facilitator under Prof. Marta Panzeri at the University of Padua
          Department of Developmental Psychology and Socialisation (Nov 2022 –
          2025), designing standardized focus group protocols and co-conducting
          psychological research sessions with autistic participants to inform
          educational strategies and support programs.
        </p>
      </section>

      <!-- EXPERIENCE -->
      <section class="cv-section" id="sectionExperience">
        <h2 class="cv-section-heading">
          Professional Experience & Open Science Leadership
        </h2>
        <div id="experienceList">
          <div class="cv-item">
            <div class="cv-item-header">
              <span class="cv-item-title">Founder & Lead Builder</span>
              <span class="cv-item-date">Aug 2024 — Present</span>
            </div>
            <div class="cv-item-org">
              Yourself to Science™ · <a
                href="https://yourselftoscience.org"
                target="_blank"
                rel="noopener noreferrer">Website</a
              > · <a
                href="https://github.com/yourselftoscience/yourselftoscience.org"
                target="_blank"
                rel="noopener noreferrer">GitHub</a
              >
            </div>
            <ul class="cv-item-bullets">
              <li>
                Launched and currently manage Yourself to Science, a
                comprehensive open-source catalogue and unified directory
                indexing 55+ clinical trials, biobanks, tissue/blood donation
                programs, and digital health registries enabling individuals to
                contribute their biological and digital self to scientific
                research.
              </li>
              <li>
                Architected AI-native Linked Data infrastructure (JSON-LD, RDF
                Turtle/VoID graphs, live MCP Server, standard llms.txt, OpenAPI
                spec) indexed in FAIRsharing and Zenodo.
              </li>
              <li>
                Published as a 100% Open Science stack: catalogue dataset
                dedicated to the public domain (CC0 1.0 Universal), website
                content under CC BY-SA 4.0, and platform codebase under
                AGPL-3.0.
              </li>
            </ul>
          </div>

          <div class="cv-item">
            <div class="cv-item-header">
              <span class="cv-item-title"
                >Scientific Fact-Checker, Writer & Web Developer</span
              >
              <span class="cv-item-date">Jun 2023 — Present</span>
            </div>
            <div class="cv-item-org">
              Entropy for Life — Italy · <a
                href="https://entropyforlife.it"
                target="_blank"
                rel="noopener noreferrer">Website</a
              > · <a
                href="https://www.youtube.com/playlist?list=PLMJaM7iJky4pKj6voGlUNHBnGdTj9rJNh"
                target="_blank"
                rel="noopener noreferrer">Videos & Documentaries</a
              > · <a
                href="https://entropyforlife.it/autore/mario-marcolongo/"
                target="_blank"
                rel="noopener noreferrer">Author Page</a
              >
            </div>
            <ul class="cv-item-bullets">
              <li>
                Core content contributor upholding scientific integrity and
                quality across media for a leading Italian science communication
                project (245,000+ YouTube subscribers / 480,000+ cross-platform
                community); responsible for script writing, in-depth
                bibliographic research, rigorous fact-checking, and creating
                data visualizations.
              </li>
              <li>
                Formally acknowledged as a trusted primary literature researcher
                on the final page of Giacomo Moro Mauretto's Mondadori book
                Italiani veri. Storia evolutiva e genetica del nostro Paese.
              </li>
              <li>
                Sole web developer for the project's official website
                (entropyforlife.it), handling full lifecycle on OVHCloud
                (hosting, DNS, SSL), custom WordPress layout/functionality, and
                technical SEO strategies.
              </li>
            </ul>
          </div>

          <div class="cv-item">
            <div class="cv-item-header">
              <span class="cv-item-title"
                >Volunteer Focus Group Conductor & Research Facilitator</span
              >
              <span class="cv-item-date">Nov 2022 — 2025</span>
            </div>
            <div class="cv-item-org">
              University of Padua — Department of Developmental Psychology and
              Socialisation · <a
                href="https://www.dpss.unipd.it/"
                target="_blank"
                rel="noopener noreferrer">Department</a
              >
            </div>
            <ul class="cv-item-bullets">
              <li>
                Contributed as a volunteer researcher to a psychological focus
                group study on sexuality in the autism spectrum led by Prof.
                Marta Panzeri. The study aimed to gather qualitative insights on
                the sexual experiences of autistic people to inform educational
                strategies and support initiatives.
              </li>
              <li>
                Developed the standardized facilitation guide for focus
                groups—including scripting and behavioral protocols—to ensure
                consistent, reproducible session execution.
              </li>
              <li>
                Managed recruitment processes across autistic communities,
                conducted bibliographic searches, and verified scientific
                literature.
              </li>
              <li>
                Served as primary conductor and co-conductor for recorded focus
                groups with autistic participants, establishing psychological
                safety while managing technical session infrastructure.
              </li>
            </ul>
          </div>

          <div class="cv-item">
            <div class="cv-item-header">
              <span class="cv-item-title">Scientific & Biomedical Editor</span>
              <span class="cv-item-date">Jan 2017 — Present</span>
            </div>
            <div class="cv-item-org">
              Wikipedia & Wikimedia Foundation · <a
                href="https://commons.wikimedia.org/wiki/Special:CentralAuth/Digressivo"
                target="_blank"
                rel="noopener noreferrer">CentralAuth Registry</a
              >
            </div>
            <ul class="cv-item-bullets">
              <li>
                Author of 4,317 verified public edits across Wikimedia projects
                (1,592 English Wikipedia, 1,249 Wikidata, 752 Italian Wikipedia,
                684 Wikimedia Commons).
              </li>
              <li>
                Created original data-driven scientific diagrams and biomedical
                visualizations independently adopted across 4 Wikipedia language
                editions and open-access repositories.
              </li>
            </ul>
          </div>
        </div>
      </section>

      <div class="print-page-footer print-only">
        <span>Mario Marcolongo — Curriculum Vitae</span>
        <span>Page 1 / 2</span>
      </div>
      <div class="print-page-break print-only"></div>

      <!-- RESEARCH -->
      <section class="cv-section" id="sectionResearch">
        <h2 class="cv-section-heading">
          Genomic & Computational Science Contributions
        </h2>
        <div id="researchList">
          <div class="cv-item">
            <div class="cv-item-header">
              <span class="cv-item-title"
                >Citizen Scientist Open Genomic Donor (41× WGS)</span
              >
              <span class="cv-item-date">Jan 2026</span>
            </div>
            <div class="cv-item-org">
              European Nucleotide Archive · <a
                href="https://www.ebi.ac.uk/ena/browser/view/PRJEB109744"
                target="_blank"
                rel="noopener noreferrer">PRJEB109744</a
              > · <a
                href="https://www.ebi.ac.uk/ena/browser/view/SAMEA121950568"
                target="_blank"
                rel="noopener noreferrer">SAMEA121950568</a
              >
            </div>
            <ul class="cv-item-bullets">
              <li>
                Donated personal 41× Whole Genome Sequencing raw paired-end
                FASTQ reads (DNBSEQ-T7) to the public domain (CC0) under ENA
                BioSample SAMEA121950568.
              </li>
              <li>
                Utilized Terra.bio cloud platform to process raw FASTQ reads
                aligned against the GRCh38 human reference genome to extract
                high-coverage GRCh38 BAM and VCF files.
              </li>
              <li>
                Architected downstream local bioinformatic pipeline on Apple
                Silicon (M4 Macbook)—converting VCF to Plink2 (PGEN/PVAR/PSAM)
                and executing Nextflow pgsc_calc with PCA ancestry projection
                against 1000 Genomes / HGDP reference panels.
              </li>
              <li>
                Engineered custom Python extraction pipelines for VEP-annotated
                VCFs—calculating multi-trait Z-Score standardized Polygenic Risk
                Scores, pharmacogenomic/lifestyle loci, mitochondrial
                heteroplasmy, and novel 'dark matter' variant filtration mapped
                to HPO/MONDO ontologies.
              </li>
            </ul>
          </div>

          <div class="cv-item">
            <div class="cv-item-header">
              <span class="cv-item-title"
                >Empirical Data Scientist & Scientific Visualizer</span
              >
              <span class="cv-item-date">2023 — Present</span>
            </div>
            <div class="cv-item-org">
              Wikimedia Commons, Tableau Public & Flourish Visual Data Portfolio
              · <a
                href="https://public.tableau.com/app/profile/mario.marcolongo/vizzes"
                target="_blank"
                rel="noopener noreferrer">Tableau Portfolio</a
              > · <a
                href="https://app.flourish.studio/@Digressivo"
                target="_blank"
                rel="noopener noreferrer">Flourish Portfolio</a
              >
            </div>
            <ul class="cv-item-bullets">
              <li>
                Published 70+ interactive empirical public health,
                epidemiological, and biomedical visualizations across Wikimedia
                Commons, Tableau Public (15 Vizzes, 4,300+ views), and Flourish.
              </li>
              <li>
                Created original vector Euler diagram illustrating overlapping
                clinical phenotypes across autism spectrum disorder (ASD),
                dystonia, epilepsy, and schizophrenia (<a
                  href="https://commons.wikimedia.org/wiki/File:Overlapping_clinical_phenotypes_in_genes_associated_with_monogenic_forms_of_autism_spectrum_disorder_(ASD),_dystonia,_epilepsy_and_schizophrenia.svg"
                  target="_blank"
                  rel="noopener noreferrer">View Diagram ↗</a
                >), published under CC BY-SA 4.0 and adopted across 4 Wikipedia
                language editions.
              </li>
              <li>
                Synthesized primary biomedical datasets—including H5N1 avian flu
                preparedness, carotid plaque microplastic pathology,
                age-stratified COVID-19 mortality, and ISTAT epidemiological
                trends—into open-access visual evidence repositories and vector
                charts.
              </li>
            </ul>
          </div>
        </div>
      </section>

      <!-- WHAT I'VE BUILT -->
      <section class="cv-section" id="sectionProjects">
        <h2 class="cv-section-heading">
          Open-Source Software & Production Tools
        </h2>
        <div id="projectsList">
          <div class="cv-item">
            <div class="cv-item-header">
              <span class="cv-item-title">MDPI Filter | Browser Extension</span>
              <span class="cv-item-date">May 2025 — Present</span>
            </div>
            <div class="cv-item-org">
              Creator & Maintainer · <a
                href="https://chromewebstore.google.com/detail/mdpi-filter/comknkeimaaadpiopddjoknflbmjeccp"
                target="_blank"
                rel="noopener noreferrer">Chrome Web Store</a
              > · <a
                href="https://microsoftedge.microsoft.com/addons/detail/mdpi-filter/efonlkldplkaeekpiajloajjmkappjgi"
                target="_blank"
                rel="noopener noreferrer">Edge Add-ons</a
              > · <a
                href="https://github.com/orgs/mdpi-filter/repositories"
                target="_blank"
                rel="noopener noreferrer">GitHub</a
              >
            </div>
            <ul class="cv-item-bullets">
              <li>
                Smart Search Filtering: Highlights or hides MDPI papers across
                Google Scholar, PubMed & Europe PMC integrating NCBI API.
              </li>
              <li>
                Universal Citation Styling: Automatically distinguishes
                reference lists & inline footnotes on any publisher article
                online.
              </li>
              <li>
                Interactive Overview: Live toolbar badge count and one-click
                scrolling directly to detected citations.
              </li>
            </ul>
          </div>

          <div class="cv-item">
            <div class="cv-item-header">
              <span class="cv-item-title"
                >English Wikipedia Link Converter | Telegram Bot</span
              >
              <span class="cv-item-date">Apr 2024 — Present</span>
            </div>
            <div class="cv-item-org">
              Creator · <a
                href="https://t.me/ToEnWikipediaBot"
                target="_blank"
                rel="noopener noreferrer">Telegram Bot</a
              > · <a
                href="https://github.com/jnton/english-wikipedia-link-converter-telegram-bot"
                target="_blank"
                rel="noopener noreferrer">GitHub</a
              >
            </div>
            <ul class="cv-item-bullets">
              <li>
                100% serverless cloud execution on AWS Lambda and API Gateway
                with zero baseline operating cost.
              </li>
              <li>
                Supports real-time interlanguage link resolution across all
                Wikipedia language editions.
              </li>
              <li>
                Automated continuous deployment via GitHub Actions workflow.
              </li>
            </ul>
          </div>

          <div class="cv-item">
            <div class="cv-item-header">
              <span class="cv-item-title"
                >Emergent Humanity | Interactive Network Simulation</span
              >
              <span class="cv-item-date">2026 — Present</span>
            </div>
            <div class="cv-item-org">
              Creator & Systems Designer · <a
                href="https://jnton.github.io/emergent-humanity/"
                target="_blank"
                rel="noopener noreferrer">Website</a
              > · <a
                href="https://github.com/jnton/emergent-humanity"
                target="_blank"
                rel="noopener noreferrer">GitHub</a
              >
            </div>
            <ul class="cv-item-bullets">
              <li>
                16 interactive chapters blending essay narration with live
                network simulations.
              </li>
              <li>
                Models cognitive node limits, signal vs. noise filtering, and
                bridging nodes across echo chambers.
              </li>
              <li>
                Synthesizes information theory, network graph topology, and
                emergent collective memory.
              </li>
            </ul>
          </div>
        </div>
      </section>

      <!-- SKILLS -->
      <section class="cv-section">
        <h2 class="cv-section-heading">
          Core Technical & Scientific Competencies
        </h2>
        <div
          class="skills-list"
          id="skillsList"
          style="display:grid; grid-template-columns:repeat(auto-fit, minmax(240px, 1fr)); gap:12px;"
        >
          <div
            class="skill-category"
            style="padding:12px; border:1px solid var(--line-strong, #333); border-radius:8px;"
          >
            <strong
              style="display:block; margin-bottom:6px; color:var(--emerald, #34D399);"
              >AI-Native Systems & Orchestration</strong
            >
            <span style="font-size:13px; opacity:0.9;"
              >Agentic Workflow Design, LLM Integration (`llms.txt` / MCP /
