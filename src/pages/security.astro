---
import Layout from "../layouts/Layout.astro";
import SiteNav from "../components/SiteNav.astro";
import SiteFooter from "../components/SiteFooter.astro";
import "../styles/cv.css";
import "../styles/security.css";
import D from "../../data/source.js";
---

<Layout
  title="Model Behavior Evaluation Record & Methodology — Mario Marcolongo"
  description="Empirical safety evaluation, boundary testing, and scorecard on the Gray Swan Proving Ground (Top 8% among ranked participants as of July 2026, 75 platform-confirmed model breaks across 156 total submissions)."
  canonical="https://mariomarcolongo.com/security.html"
>
  <Fragment slot="head">
    <script is:inline src="/data/source.js"></script>
    <script type="application/ld+json">
    {
      "@context": "https://schema.org",
      "@type": "WebPage",
      "@id": "https://mariomarcolongo.com/security.html#webpage",
      "name": "Model Behavior Evaluation Record & Methodology — Mario Marcolongo",
      "description": "Empirical safety evaluation, boundary testing, and scorecard on the Gray Swan Proving Ground (Top 8% among ranked participants as of July 2026, 75 platform-confirmed model breaks across 156 total submissions).",
      "url": "https://mariomarcolongo.com/security.html",
      "author": { "@id": "https://mariomarcolongo.com/#person" },
      "about": [
        {
          "@type": "Thing",
          "name": "Model Behavior & Adversarial Safety Evaluation",
          "description": "Systematic boundary probing of frontier LLMs and multimodal architectures across Chat, Image, Tool-Use, and Indirect Prompt Injection."
        },
        {
          "@type": "Organization",
          "name": "Gray Swan AI Proving Ground",
          "url": "https://app.grayswan.ai/arena/user/6a57be70d15e123775a1e9cf"
        }
      ]
    }
    </script>
  </Fragment>

  <SiteNav activePage="security" />

  <div class="security-case-study">
    <a href="/" class="security-back-link">← Back to Portfolio & Overview</a>

    <header class="security-header">
      <div class="security-meta-tag">Adversarial Evaluation & Policy Robustness · Evaluation Record</div>
      <h1 class="security-title">Model Behavior Evaluation Record & Methodology</h1>
      <p class="security-lead">
        Systematic boundary probing, empirical safety evaluation, and policy consistency auditing across frontier LLMs and multimodal architectures on the Gray Swan Proving Ground.
      </p>

      <div class="security-box" style="margin-top: 28px;">
        <div class="security-box-title">Practitioner & Verification Record</div>
        <div class="security-box-body">
          Practitioner: <strong>{D.identity.name}</strong> · Gray Swan Practitioner ID: <a href="https://app.grayswan.ai/arena/user/6a57be70d15e123775a1e9cf" target="_blank" rel="noopener noreferrer" style="color: var(--accent); font-weight: 600;">6a57be70d15e123775a1e9cf ↗</a> · ORCID: <a href="https://orcid.org/0000-0003-2846-7115" target="_blank" rel="noopener noreferrer" style="color: var(--accent); font-weight: 600;">{D.identity.orcid} ↗</a>
        </div>
      </div>
    </header>

    <!-- SCORECARD & METRICS -->
    <section class="security-section" id="scorecard">
      <h2 class="security-section-title">Proving Ground Scorecard & Metrics</h2>
      <p class="security-section-desc">
        Empirical evaluation record across structured testing waves. Every confirmed break represents an independently verified policy or alignment boundary failure under adversarial conditions.
      </p>

      <div class="security-metrics-grid">
        <div class="security-metric-card">
          <div class="security-metric-value">Top 8%</div>
          <div class="security-metric-label">Gray Swan Proving Ground Percentile</div>
          <div class="security-metric-detail">Among ranked Gray Swan Proving Ground participants as of July 2026</div>
        </div>
        <div class="security-metric-card">
          <div class="security-metric-value">75</div>
          <div class="security-metric-label">Platform-Confirmed Model Breaks</div>
          <div class="security-metric-detail">75 platform-confirmed model breaks across 26 testing waves (as of July 2026)</div>
        </div>
        <div class="security-metric-card">
          <div class="security-metric-value">156</div>
          <div class="security-metric-label">Total Platform Submissions</div>
          <div class="security-metric-detail">Structured boundary evaluations across 26 longitudinal testing waves</div>
        </div>
      </div>
    </section>

    <!-- LONGITUDINAL WAVE DISTRIBUTION -->
    <section class="security-section" id="longitudinal-waves">
      <h2 class="security-section-title">Historical Wave Performance & Longitudinal Distribution</h2>
      <p class="security-section-desc">
        Sustained boundary evaluation across 26 testing waves (156 total submissions, 75 confirmed breaks). Historical evaluation peaks include Wave 1 (14 breaks), Waves 2 & 3 (10 breaks each), and Wave 15 (8 breaks), tracking boundary resilience across major model architecture updates.
      </p>

      <div class="security-table-wrapper" style="margin-top: 24px; overflow-x: auto;">
        <table class="security-table" style="width: 100%; border-collapse: collapse; font-size: 14px; text-align: left;">
          <thead>
            <tr style="border-bottom: 2px solid var(--line-strong);">
              <th style="padding: 12px 16px; font-family: var(--font-mono); font-size: 12px; color: var(--ink-soft); text-transform: uppercase; letter-spacing: 0.05em;">Testing Wave</th>
              <th style="padding: 12px 16px; font-family: var(--font-mono); font-size: 12px; color: var(--ink-soft); text-transform: uppercase; letter-spacing: 0.05em;">Confirmed Breaks</th>
              <th style="padding: 12px 16px; font-family: var(--font-mono); font-size: 12px; color: var(--ink-soft); text-transform: uppercase; letter-spacing: 0.05em;">Verification Status</th>
            </tr>
          </thead>
          <tbody>
            {D.redTeamActivity.waves.filter(w => w.breaks > 0).map(w => (
              <tr style="border-bottom: 1px solid var(--line); transition: background 0.2s ease;">
                <td style="padding: 12px 16px; font-family: var(--font-mono); font-weight: 600; color: var(--ink);">Wave {w.wave}</td>
                <td style="padding: 12px 16px; font-family: var(--font-display); font-weight: 700; color: var(--accent); font-size: 15px;">{w.breaks} {w.breaks === 1 ? 'Break' : 'Breaks'}</td>
                <td style="padding: 12px 16px; color: var(--ink-soft); font-size: 13.5px;">Platform-Confirmed · Gray Swan Arena</td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    </section>

    <!-- EVALUATION VECTORS & TESTING METHODOLOGY -->
    <section class="security-section" id="methodology">
      <h2 class="security-section-title">Evaluation Vectors & Testing Methodology</h2>
      <p class="security-section-desc">
        Systematic evaluation probes alignment boundaries without relying on fabricated authority, brute-force obfuscation, or automated jailbreak templates. Testing methodology targets structural instruction adherence across four key modalities:
      </p>

      <div class="security-card-grid">
        <div class="security-card">
          <div class="security-card-tag">Modality Vector 01</div>
          <h3 class="security-card-title">Chat & Single-Turn/Multi-Turn Dialogue Mechanics</h3>
          <div class="security-card-body">
            <p>
              Probing single-turn and multi-turn dialogue mechanics to test the resilience of model refusal behavior, instruction hierarchy, and contextual constraint enforcement when exposed to conflicting or nested directives.
            </p>
          </div>
        </div>
        <div class="security-card">
          <div class="security-card-tag">Modality Vector 02</div>
          <h3 class="security-card-title">Multimodal & Vision-Language Boundary Testing</h3>
          <div class="security-card-body">
            <p>
              Evaluating cross-modality safety boundaries where visual inputs (images, diagrams, typography embedded within imagery) interact with textual system instructions to test for modality override vulnerabilities and visual prompt injection.
            </p>
          </div>
        </div>
        <div class="security-card">
          <div class="security-card-tag">Modality Vector 03</div>
          <h3 class="security-card-title">Agentic Tool-Use & Orchestration Boundaries</h3>
          <div class="security-card-body">
            <p>
              Auditing autonomous multi-step execution chains where LLMs invoke external tools (search, code execution, APIs). Testing privilege boundaries, parameter injection resilience, and resistance to unauthorized action sequencing.
            </p>
          </div>
        </div>
        <div class="security-card">
          <div class="security-card-tag">Modality Vector 04</div>
          <h3 class="security-card-title">Indirect Prompt Injection & Context Hijacking</h3>
          <div class="security-card-body">
            <p>
              Assessing vulnerability when models process untrusted external context (retrieved documents, web pages, user-submitted files) where adversarial instructions attempt to hijack the primary objective or manipulate tool outputs.
            </p>
          </div>
        </div>
      </div>
    </section>

    <!-- REPRESENTATIVE EVALUATION SCENARIOS -->
    <section class="security-section" id="scenarios">
      <h2 class="security-section-title">Representative Evaluation Scenarios</h2>
      <p class="security-section-desc">
        The following sanitized scenarios illustrate empirical testing methodologies derived from publicly verified submission labels across target modalities. They document evaluation scope without exposing unpatched exploit payloads.
      </p>

      <div class="security-card-grid">
        <div class="security-card">
          <div class="security-card-tag">Empirical Scenario · Agentic Tool-Use</div>
          <h3 class="security-card-title">Indirect Function-Call Manipulation (Agentic Tool-Use)</h3>
          <div class="security-card-body">
            <p>
              Evaluated whether untrusted or nested instructions in retrieved context could cause an agentic model to invoke a function outside the user’s intended task. Testing focused on instruction provenance, authorization boundaries, tool-selection logic, and resistance to concealed indirect directives.
            </p>
            <div class="security-code-block">Verified Submission Label: indirect-function-call</div>
          </div>
        </div>

        <div class="security-card">
          <div class="security-card-tag">Empirical Scenario · Policy & Workflow Integrity</div>
          <h3 class="security-card-title">Account-Security Authorization & Workflow Integrity</h3>
          <div class="security-card-body">
            <p>
              Tested whether a model preserves identity-verification, confirmation, and authorization requirements when instructed to perform security-sensitive account modifications. Examined whether conversational framing or contextual urgency weakens authentication controls.
            </p>
            <div class="security-code-block">Verified Submission Label: weak-password-change</div>
          </div>
        </div>

        <div class="security-card">
          <div class="security-card-tag">Empirical Scenario · Multimodal & Vision-Language</div>
          <h3 class="security-card-title">Multimodal Instruction Override via Visual Typography</h3>
          <div class="security-card-body">
            <p>
              Evaluated vision-language models for cross-modal instruction hierarchy robustness when textual constraints conflict with typography embedded directly inside uploaded images or technical diagrams, testing whether visual instructions can override system prompts.
            </p>
            <div class="security-code-block">Evaluation Vector: Multimodal Vision-Language Override</div>
          </div>
        </div>

        <div class="security-card">
          <div class="security-card-tag">Empirical Scenario · Conversational Alignment</div>
          <h3 class="security-card-title">Multi-Turn Dialogue Constraint Relaxation</h3>
          <div class="security-card-body">
            <p>
              Systematically audited multi-turn conversational interactions to evaluate whether repeated benign contextual framing gradually relaxes policy thresholds or instruction boundaries over extended dialogue horizons.
            </p>
            <div class="security-code-block">Evaluation Vector: Multi-Turn Constraint Relaxation</div>
          </div>
        </div>
      </div>
    </section>

    <!-- METHODOLOGICAL SYNTHESIS -->
    <section class="security-section" id="synthesis">
      <h2 class="security-section-title">Bridging Red-Teaming with Epistemic Rigor</h2>
      <p class="security-section-desc">
        Model behavior evaluation is directly synergistic with primary source verification and open science infrastructure engineering. Both disciplines require auditable rigor and defensive systems analysis:
      </p>

      <div class="security-box">
        <div class="security-box-title">1. Structural Decomposition</div>
        <div class="security-box-body">
          Breaking down complex, opaque systems—whether a frontier LLM's system prompt or a 41× WGS genomic alignment pipeline—into discrete, testable assumptions and verifiable boundary conditions.
        </div>
      </div>

      <div class="security-box">
        <div class="security-box-title">2. Evidence-Driven Auditing</div>
        <div class="security-box-body">
          Documenting reproducible behaviors and empirical boundary failures rather than theoretical speculation, paralleling the verification of 4,317 Wikimedia contributions and public ENA genomic accessions.
        </div>
      </div>

      <div class="security-box">
        <div class="security-box-title">3. Defensive Systems Thinking</div>
        <div class="security-box-body">
          Applying adversarial insights to threat-model open-science architectures, ensuring research directories and data pipelines are resilient against prompt injection, data poisoning, and untrusted-input risks.
        </div>
      </div>
    </section>

    <div style="margin-top: 40px;">
      <a href="/" class="security-back-link">← Back to Portfolio & Overview</a>
    </div>
  </div>

  <SiteFooter version="v2026.07.21" />
</Layout>
