---
import Layout from "../layouts/Layout.astro";
import SiteNav from "../components/SiteNav.astro";
import SiteFooter from "../components/SiteFooter.astro";
import "../styles/cv.css";
import D from "../../data/source.js";
---

<Layout
  title="Mario Marcolongo — 2-Page Application Résumé"
  description={`Concise two-page application résumé of ${D.identity.name} — ${D.identity.jobTitle}.`}
  canonical="https://mariomarcolongo.com/cv-resume.html"
>
  <Fragment slot="head">
    <script is:inline src="/data/source.js"></script>
    <script type="application/ld+json">
      {
        "@context": "https://schema.org",
        "@type": "ProfilePage",
        "@id": "https://mariomarcolongo.com/cv-resume.html#webpage",
        "name": "Mario Marcolongo — 2-Page Application Résumé",
        "url": "https://mariomarcolongo.com/cv-resume.html",
        "mainEntity": { "@id": "https://mariomarcolongo.com/#person" }
      }
    </script>
  </Fragment>

  <SiteNav activePage="resume" />

  <div class="wrap" style="padding-top: 60px;">
    <!-- Toolbar — web only, hidden on print -->
    <div class="toolbar print-hide">
      <div class="toolbar-left">
        <span>2-Page Application Résumé</span>
      </div>
      <div class="toolbar-right">
        <a href="/cv.html" class="btn">Standard CV (Full)</a>
        <button
          class="btn btn-ai"
          onclick="copyCanonicalText('/cv-llm.txt', this, '✓ Copied AI CV!')"
          title="Copy complete CV in AI-compatible Markdown format"
          >✨ Copy for AI (Markdown)</button
        >
        <button class="btn btn-primary" onclick="printCV()"
          >🖨️ Print / Save 2-Page PDF</button
        >
      </div>
    </div>

    <!-- CV Document (2-Page Concise Format) -->
    <article class="cv two-page-layout" id="cvDocument">
      <header class="cv-header">
        <div class="cv-header-top">
          <h1 class="cv-name" id="cvName">{D.identity.name}</h1>
          <span class="cv-version-pill print-hide"
            >{D.identity.buildVersion} · Updated: {D.identity.evaluationAsOf}</span
          >
        </div>
        <p class="cv-tagline" id="cvTagline">
          {D.identity.jobTitle} | {D.identity.secondaryTitle}
        </p>

        <div class="cv-contact" id="cvContact">
          <span id="cvLocation">{D.identity.relocationVisible}</span>
          <span>·</span>
          <a href="https://mariomarcolongo.com">mariomarcolongo.com</a>
          <span>·</span>
          <a href={`mailto:${D.identity.email}`}>{D.identity.email}</a>
          <span>·</span>
          <a
            href={D.identity.orcidUrl}
            target="_blank"
            rel="noopener noreferrer">ORCID: {D.identity.orcid}</a
          >
          <span>·</span>
          <a
            href={D.identity.linkedin}
            target="_blank"
            rel="noopener noreferrer">LinkedIn</a
          >
          <span>·</span>
          <a
            href={D.identity.github}
            target="_blank"
            rel="noopener noreferrer">GitHub</a
          >
          <span class="cv-phone" id="cvPhoneSlot"></span>
        </div>
      </header>

      <!-- SUMMARY -->
      <section class="cv-section resume-sec-top">
        <h2 class="cv-section-heading">Executive Summary</h2>
        <p class="cv-summary resume-summary" id="cvSummary">
          {D.summary}
        </p>
      </section>

      <!-- EXPERIENCE -->
      <section class="cv-section resume-sec-mid" id="sectionExperience">
        <h2 class="cv-section-heading">
          Professional Experience & Open Science Leadership
        </h2>
        <div id="experienceList">
          {D.experience.map((item, idx) => (
            <div class={`cv-item ${idx === D.experience.length - 1 ? "resume-item-last" : "resume-item"}`}>
              <div class="cv-item-header">
                <span class="cv-item-title">{item.role}</span>
                {item.tag && <span class="cv-role-tag">{item.tag}</span>}
                <span class="cv-item-date">{item.period}</span>
              </div>
              <div class="cv-item-org">
                {item.org}
                {item.links && Object.entries(item.links).map(([key, url]) => (
                  <> · <a href={url} target="_blank" rel="noopener noreferrer">{key === 'website' ? 'Website' : key === 'github' ? 'GitHub' : key === 'playlist' ? 'Documentaries' : key === 'authorPage' ? 'Author Page' : key === 'caseStudy' ? 'Evaluation Record' : key === 'profile' ? 'Profile' : key}</a></>
                ))}
              </div>
              <ul class="cv-item-bullets">
                {(item.resumeBullets || item.bullets.slice(0, 2)).map(b => (
                  <li set:html={b} />
                ))}
              </ul>
            </div>
          ))}
        </div>
      </section>

      <!-- RESEARCH & DATASETS -->
      <section class="cv-section resume-sec-spaced">
        <h2 class="cv-section-heading">
          Scientific Research, Pipelines & Public Domain Datasets
        </h2>
        <div id="researchList">
          {D.research.map((item, idx) => (
            <div class={`cv-item ${idx === D.research.length - 1 ? "resume-item-last" : "resume-item"}`}>
              <div class="cv-item-header">
                <span class="cv-item-title">{item.role}</span>
                {item.tag && <span class="cv-role-tag">{item.tag}</span>}
                <span class="cv-item-date">{item.period}</span>
              </div>
              <div class="cv-item-org">
                {item.org}
                {item.links && Object.entries(item.links).map(([key, url]) => (
                  <> · <a href={url} target="_blank" rel="noopener noreferrer">{key === 'website' ? 'Website' : key === 'github' ? 'GitHub' : key === 'tableau' ? 'Tableau Profile' : key === 'flourish' ? 'Flourish Profile' : key === 'caseStudy' ? 'Evaluation Record' : key === 'profile' ? 'Profile' : key}</a></>
                ))}
              </div>
              <ul class="cv-item-bullets">
                {(item.resumeBullets || item.bullets.slice(0, 2)).map(b => (
                  <li set:html={b} />
                ))}
              </ul>
            </div>
          ))}
        </div>
      </section>

      <!-- SKILLS -->
      <section class="cv-section resume-sec-top">
        <h2 class="cv-section-heading">
          Core Technical & Scientific Competencies
        </h2>
        <div class="skills-list resume-skills" id="skillsList">
          {(D.resumeSkills || D.skills).map(skill => {
            const colonIndex = skill.indexOf(":");
            if (colonIndex !== -1) {
              const category = skill.substring(0, colonIndex).trim();
              const detail = skill.substring(colonIndex + 1).trim();
              return (
                <div class="skill-category resume-skill-box">
                  <strong class="skill-category-title">{category}</strong>
                  <span class="skill-category-detail" set:html={detail} />
                </div>
              );
            }
            return (
              <div class="skill-category resume-skill-box">
                <span class="skill-category-detail" set:html={skill} />
              </div>
            );
          })}
        </div>
      </section>

      <!-- EDUCATION & LANGUAGES -->
      <section class="cv-section resume-sec-zero">
        <h2 class="cv-section-heading">
          Education, Languages & Certifications
        </h2>
        <div id="educationList">
          {D.education.map((edu, idx) => (
            <div class={`edu-item ${idx === D.education.length - 1 ? "resume-edu-last" : "resume-edu"}`}>
              <span class="edu-title">{edu.title}</span>
              {edu.period && <> <span class="edu-period">({edu.period})</span></>}
              {edu.institution && <> — <span class="edu-detail">{edu.institution}</span></>}
              {edu.status && <> · <span class="edu-status">{edu.status}</span></>}
              {edu.credentialUrl && <> · <a class="edu-credential" href={edu.credentialUrl} target="_blank" rel="noopener noreferrer">Credential</a></>}
            </div>
          ))}
        </div>
      </section>
    </article>
  </div>

  <script is:inline>
    function injectPrivateData() {
      const priv = (typeof window !== "undefined" && window._privateData) ? window._privateData : {};
      const phoneSlot = document.getElementById("cvPhoneSlot");
      if (priv.phone && phoneSlot) {
        phoneSlot.innerHTML = `<span>·</span> <a href="tel:${priv.phone.replaceAll(/\s+/g, "")}">${priv.phone}</a>`;
        phoneSlot.classList.add("has-phone");
      }
    }

    function printCV() {
      injectPrivateData();
      window.setTimeout(() => window.print(), 100);
    }

    window.addEventListener("DOMContentLoaded", injectPrivateData);
  </script>

  <SiteFooter version={D.identity.buildVersion} />
</Layout>
