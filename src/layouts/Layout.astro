---
import '../styles/global.css';

export interface Props {
  title?: string;
  description?: string;
  canonical?: string;
}

const {
  title = "Mario Marcolongo — I check the claims other people don't.",
  description = "Primary source verification, open science infrastructure (Yourself to Science™ indexing 55+ research studies), interactive systems simulation (Emergent Humanity), and empirical data synthesis.",
  canonical = "https://mariomarcolongo.com/"
} = Astro.props;
---

<!DOCTYPE html>
<html lang="en" data-theme="dark">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{title}</title>
  <meta name="description" content={description} />
  <link rel="canonical" href={canonical} />

  <!-- Favicon & PWA Manifest -->
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <link rel="icon" type="image/png" sizes="48x48" href="/favicon-48x48.png" />
  <link rel="icon" type="image/png" sizes="32x32" href="/favicon.ico" />
  <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
  <link rel="manifest" href="/site.webmanifest" />

  <!-- WebMCP & Agent-to-Agent Discovery Links -->
  <link rel="api-catalog" href="https://mariomarcolongo.com/.well-known/api-catalog" />
  <link rel="describedby" type="text/plain" href="https://mariomarcolongo.com/llms.txt" />
  <link rel="describedby" type="text/plain" href="https://mariomarcolongo.com/llms-full.txt" />
  <link rel="agent-card" href="https://mariomarcolongo.com/.well-known/agent-card.json" />
  <link rel="mcp-server-card" href="https://mariomarcolongo.com/.well-known/mcp/server-card.json" />

  <!-- Open Graph / Social Previews -->
  <meta property="og:type" content="website" />
  <meta property="og:url" content={canonical} />
  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:image" content="https://mariomarcolongo.com/og-preview.png" />
  <meta property="og:image:width" content="1200" />
  <meta property="og:image:height" content="630" />
  <meta property="og:site_name" content="Mario Marcolongo" />

  <!-- Twitter Card -->
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:url" content={canonical} />
  <meta name="twitter:title" content={title} />
  <meta name="twitter:description" content={description} />
  <meta name="twitter:image" content="https://mariomarcolongo.com/og-preview.png" />

  <!-- Google Fonts -->
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=Outfit:wght@600;700;800;900&family=JetBrains+Mono:wght@500;600&display=swap" rel="stylesheet" />

  <slot name="head" />
</head>
<body>
  <div id="scrollProgress"></div>
  <slot />
</body>
</html>
