---
import '../styles/global.css';

export interface Props {
  title?: string;
  description?: string;
  canonical?: string;
}

const {
  title = "Mario Marcolongo — AI Evaluation & Research Verification Specialist",
  description = "AI evaluation and research verification specialist specializing in model behavior evaluation, scientific evidence review, evaluation operations, and technical research.",
  canonical = "https://mariomarcolongo.com/"
} = Astro.props;
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{title}</title>
  <meta name="description" content={description} />
  <link rel="canonical" href={canonical} />

  <!-- Favicon & PWA Manifest -->
  <link rel="icon" type="image/x-icon" sizes="32x32" href="/favicon.ico" />
  <link rel="shortcut icon" href="/favicon.ico" />
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <link rel="icon" type="image/png" sizes="48x48" href="/favicon-48x48.png" />
  <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
  <link rel="mask-icon" href="/favicon.svg" color="#34D399" />
  <link rel="manifest" href="/site.webmanifest" />

  <!-- mm-theme Pre-Paint Script -->
  <script is:inline id="mm-theme">
    (function() {
      try {
        var stored = null;
        try { stored = localStorage.getItem('theme'); } catch(e) {}
        var prefersDark = window.matchMedia && window.matchMedia('(prefers-color-scheme: dark)').matches;
        if (stored === 'dark' || (!stored && prefersDark)) {
          document.documentElement.setAttribute('data-theme', 'dark');
        } else {
          document.documentElement.setAttribute('data-theme', 'light');
        }
      } catch(err) {}
    })();
  </script>

  <!-- WebMCP & Agent-to-Agent Discovery Links -->
  <link rel="api-catalog" href="https://mariomarcolongo.com/.well-known/api-catalog" />
  <link rel="describedby" type="text/plain" href="https://mariomarcolongo.com/llms.txt" />
  <link rel="describedby" type="text/plain" href="https://mariomarcolongo.com/llms-full.txt" />
  <link rel="agent-card" href="https://mariomarcolongo.com/.well-known/agent-card.json" />
  <link rel="mcp-server-card" href="https://mariomarcolongo.com/.well-known/mcp/server-card.json" />

  <!-- Open Graph / Social Previews -->
  <meta property="og:type" content="website" />
  <meta property="og:url" content={canonical} />
  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:image" content="https://mariomarcolongo.com/og-preview.png" />
  <meta property="og:image:width" content="1200" />
  <meta property="og:image:height" content="630" />
  <meta property="og:site_name" content="Mario Marcolongo" />

  <!-- Twitter Card -->
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:url" content={canonical} />
  <meta name="twitter:title" content={title} />
  <meta name="twitter:description" content={description} />
  <meta name="twitter:image" content="https://mariomarcolongo.com/og-preview.png" />

  <!-- Google Fonts -->
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=Outfit:wght@600;700;800;900&family=JetBrains+Mono:wght@500;600&display=swap" rel="stylesheet" />

  <slot name="head" />
</head>
<body>
  <div id="scrollProgress"></div>
  <main id="main-content">
    <slot />
  </main>
  <script is:inline>
    (function initWebMCP() {
      function registerTools() {
        if (typeof navigator !== 'undefined' && navigator.modelContext && typeof navigator.modelContext.provideContext === 'function') {
          try {
            navigator.modelContext.provideContext({
              tools: [
                {
                  name: "query_dossier",
                  description: "Retrieve comprehensive verified biographical summary, work history, skills, and open science projects.",
                  inputSchema: {
                    type: "object",
                    properties: {
                      format: { type: "string", description: "Format option: 'summary' or 'full'", default: "full" }
                    }
                  },
                  execute: async (args = {}) => {
                    const url = args.format === 'summary' ? '/llms.txt' : '/llms-full.txt';
                    const res = await fetch(url);
                    const text = await res.text();
                    return { content: text };
                  }
                },
                {
                  name: "query_cv",
                  description: "Access Mario Marcolongo's machine-actionable Curriculum Vitae.",
                  inputSchema: {
                    type: "object",
                    properties: {}
                  },
                  execute: async () => {
                    const res = await fetch('/cv-llm.txt');
                    const text = await res.text();
                    return { content: text };
                  }
                },
                {
                  name: "query_genomic_pipeline",
                  description: "Access full technical logs and variant analysis notes for the public 41x WGS genomic donation (ENA PRJEB109744).",
                  inputSchema: {
                    type: "object",
                    properties: {}
                  },
                  execute: async () => {
                    const res = await fetch('/llms-full.txt');
                    const text = await res.text();
                    return { content: text };
                  }
                }
              ]
            });
          } catch (e) {
            console.warn("WebMCP registration error:", e);
          }
        }
      }

      registerTools();
      if (typeof window !== 'undefined') {
        window.addEventListener('DOMContentLoaded', registerTools);
        window.addEventListener('load', registerTools);
      }
    })();
  </script>
</body>
</html>
