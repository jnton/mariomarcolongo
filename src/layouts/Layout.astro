---
import '../styles/global.css';
import '../styles/v3-accessibility.css';
import '../styles/portfolio-v7-safety.css';
import '../styles/portfolio-v7-mobile.css';

export interface Props {
  title?: string;
  description?: string;
  canonical?: string;
}

const {
  title = "Mario Marcolongo — Research, Evidence & AI Operations",
  description = "Research, evidence and AI operations portfolio spanning scientific verification, knowledge integrity, AI evaluation, open science and data quality.",
  canonical = "https://mariomarcolongo.com/"
} = Astro.props;

const htmlClass = canonical === "https://mariomarcolongo.com/" ? "human-portfolio" : undefined;
const socialImagePath = canonical.includes('/security')
  ? '/og/security.png'
  : canonical.includes('/integrity')
    ? '/og/integrity.png'
    : canonical.includes('/cv')
      ? '/og/cv.png'
      : '/og/home.png';
const socialImage = `https://mariomarcolongo.com${socialImagePath}`;
---

<!DOCTYPE html>
<html lang="en" class={htmlClass}>
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="theme-color" content="#f7f6f2" />
  <title>{title}</title>
  <meta name="description" content={description} />
  <link rel="canonical" href={canonical} />

  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <link rel="icon" type="image/png" sizes="48x48" href="/favicon-48x48.png" />
  <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
  <link rel="manifest" href="/site.webmanifest" />

  <script is:inline id="mm-theme">
    (function() {
      try {
        var stored = null;
        try { stored = localStorage.getItem('theme'); } catch(e) {}
        var prefersDark = window.matchMedia && window.matchMedia('(prefers-color-scheme: dark)').matches;
        if (stored === 'dark' || (!stored && prefersDark)) {
          document.documentElement.setAttribute('data-theme', 'dark');
        } else {
          document.documentElement.setAttribute('data-theme', 'light');
        }
      } catch(err) {}
    })();
  </script>

  <link rel="api-catalog" href="https://mariomarcolongo.com/.well-known/api-catalog" />
  <link rel="describedby" type="text/plain" href="https://mariomarcolongo.com/llms.txt" />
  <link rel="describedby" type="text/plain" href="https://mariomarcolongo.com/llms-full.txt" />
  <link rel="agent-card" href="https://mariomarcolongo.com/.well-known/agent-card.json" />
  <link rel="mcp-server-card" href="https://mariomarcolongo.com/.well-known/mcp/server-card.json" />

  <meta property="og:type" content="website" />
  <meta property="og:url" content={canonical} />
  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:image" content={socialImage} />
  <meta property="og:image:secure_url" content={socialImage} />
  <meta property="og:image:type" content="image/png" />
  <meta property="og:image:width" content="1200" />
  <meta property="og:image:height" content="630" />
  <meta property="og:image:alt" content={`${title} — social preview`} />
  <meta property="og:site_name" content="Mario Marcolongo" />

  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:url" content={canonical} />
  <meta name="twitter:title" content={title} />
  <meta name="twitter:description" content={description} />
  <meta name="twitter:image" content={socialImage} />
  <meta name="twitter:image:alt" content={`${title} — social preview`} />

  <slot name="head" />
</head>
<body>
  <div id="scrollProgress"></div>
  <main id="main-content">
    <slot />
  </main>
  <script is:inline>
    (function initWebMCP() {
      function registerTools() {
        if (typeof navigator !== 'undefined' && navigator.modelContext && typeof navigator.modelContext.provideContext === 'function') {
          try {
            navigator.modelContext.provideContext({
              tools: [
                {
                  name: "query_dossier",
                  description: "Retrieve Mario Marcolongo's evidence-bound professional dossier, work history and public records.",
                  inputSchema: {
                    type: "object",
                    properties: {
                      format: { type: "string", description: "Format option: 'summary' or 'full'", default: "full" }
                    }
                  },
                  execute: async (args = {}) => {
                    const url = args.format === 'summary' ? '/llms.txt' : '/llms-full.txt';
                    const res = await fetch(url);
                    const text = await res.text();
                    return { content: text };
                  }
                },
                {
                  name: "query_cv",
                  description: "Access Mario Marcolongo's machine-readable master CV.",
                  inputSchema: { type: "object", properties: {} },
                  execute: async () => {
                    const res = await fetch('/cv-llm.txt');
                    const text = await res.text();
                    return { content: text };
                  }
                },
                {
                  name: "query_genomic_pipeline",
                  description: "Access technical notes for the public 41x WGS genomic donation under ENA PRJEB109744.",
                  inputSchema: { type: "object", properties: {} },
                  execute: async () => {
                    const res = await fetch('/llms-full.txt');
                    const text = await res.text();
                    return { content: text };
                  }
                }
              ]
            });
          } catch (e) {
            console.warn("WebMCP registration error:", e);
          }
        }
      }

      registerTools();
      if (typeof window !== 'undefined') {
        window.addEventListener('DOMContentLoaded', registerTools);
        window.addEventListener('load', registerTools);
      }
    })();
  </script>
</body>
</html>
