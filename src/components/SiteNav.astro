---
export interface Props {
  activePage?: "home" | "integrity" | "security" | "cv" | "resume";
}

const { activePage = "home" } = Astro.props;
---

<header class="nav print-hide" id="siteNav">
  <a href="/" class="nav-name" aria-label="Mario Marcolongo — Home">
    <span class="nav-name-full">Mario Marcolongo</span>
    <span class="nav-name-short" aria-hidden="true">MM</span>
  </a>
  <nav class="nav-actions" aria-label="Primary navigation">
    <a
      href="/"
      class={`nav-link nav-overview ${activePage === "home" ? "active" : ""}`}
      aria-current={activePage === "home" ? "page" : undefined}
    >Portfolio</a>
    <a
      href="/integrity.html"
      class={`nav-link nav-integrity ${activePage === "integrity" ? "active" : ""}`}
      aria-current={activePage === "integrity" ? "page" : undefined}
    ><span class="evaluation-label-full">Work Samples</span><span class="evaluation-label-short" aria-hidden="true">Work</span></a>
    <a
      href="/#documents"
      class={`nav-link nav-documents ${activePage === "resume" ? "active" : ""}`}
      aria-current={activePage === "resume" ? "page" : undefined}
    >CVs</a>
    <a
      href="/cv.html"
      class={`nav-link nav-full-cv ${activePage === "cv" ? "active" : ""}`}
      aria-current={activePage === "cv" ? "page" : undefined}
    >Master CV</a>
    <a
      href="/#contact"
      class="btn btn-primary btn-sm nav-resume"
      aria-label="Contact Mario Marcolongo"
    ><span class="resume-label-full">Contact</span><span class="resume-label-short" aria-hidden="true">Email</span></a>
    <button
      class="theme-toggle"
      id="themeBtn"
      aria-label="Switch to dark theme"
      aria-pressed="false"
      type="button"
    >
      <span class="theme-icon-light" aria-hidden="true">☀️</span>
      <span class="theme-icon-dark" aria-hidden="true" hidden>🌙</span>
    </button>
  </nav>
</header>

<script is:inline>
  (function initNavAndTheme() {
    var navEl = document.getElementById("siteNav");
    if (navEl) {
      var onScroll = function() {
        navEl.classList.toggle("scrolled", window.scrollY > 20);
      };
      window.addEventListener("scroll", onScroll, { passive: true });
      onScroll();
    }

    var themeBtn = document.getElementById("themeBtn");
    if (!themeBtn) return;

    function updateThemeControl(theme) {
      var isDark = theme === "dark";
      var lightIcon = themeBtn.querySelector(".theme-icon-light");
      var darkIcon = themeBtn.querySelector(".theme-icon-dark");
      if (lightIcon) lightIcon.hidden = isDark;
      if (darkIcon) darkIcon.hidden = !isDark;
      themeBtn.setAttribute("aria-pressed", isDark ? "true" : "false");
      themeBtn.setAttribute("aria-label", isDark ? "Switch to light theme" : "Switch to dark theme");
    }

    var current = document.documentElement.getAttribute("data-theme") === "dark" ? "dark" : "light";
    updateThemeControl(current);

    themeBtn.addEventListener("click", function() {
      var active = document.documentElement.getAttribute("data-theme") === "dark" ? "dark" : "light";
      var next = active === "dark" ? "light" : "dark";
      document.documentElement.setAttribute("data-theme", next);
      updateThemeControl(next);
      try { localStorage.setItem("theme", next); } catch (e) {}
    });
  })();
</script>
