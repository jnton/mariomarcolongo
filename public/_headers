/*
  X-Content-Type-Options: nosniff
  Access-Control-Allow-Origin: *
  Access-Control-Allow-Methods: GET, HEAD, OPTIONS
  Link: <https://mariomarcolongo.com/.well-known/api-catalog>; rel="api-catalog"
  Link: <https://mariomarcolongo.com/llms.txt>; rel="describedby"; type="text/plain"
  Link: <https://mariomarcolongo.com/llms-full.txt>; rel="describedby"; type="text/plain"
  Link: <https://mariomarcolongo.com/.well-known/agent-card.json>; rel="agent-card"
  Link: <https://mariomarcolongo.com/.well-known/mcp/server-card.json>; rel="mcp-server-card"

/.well-known/*
  Content-Type: application/json; charset=utf-8
  Access-Control-Allow-Origin: *

/.well-known/api-catalog
  Content-Type: application/linkset+json; charset=utf-8
  Access-Control-Allow-Origin: *

/llms.txt
  Content-Type: text/markdown; charset=utf-8
  Access-Control-Allow-Origin: *

/llms-full.txt
  Content-Type: text/markdown; charset=utf-8
  Access-Control-Allow-Origin: *

/cv-llm.txt
  Content-Type: text/markdown; charset=utf-8
  Access-Control-Allow-Origin: *

/auth.md
  Content-Type: text/markdown; charset=utf-8
  Access-Control-Allow-Origin: *

/favicon.ico
  Content-Type: image/x-icon
  Cache-Control: public, max-age=86400, must-revalidate

/favicon.svg
  Content-Type: image/svg+xml
  Cache-Control: public, max-age=86400, must-revalidate

/favicon-48x48.png
  Content-Type: image/png
  Cache-Control: public, max-age=86400, must-revalidate

/apple-touch-icon.png
  Content-Type: image/png
  Cache-Control: public, max-age=86400, must-revalidate

/site.webmanifest
  Content-Type: application/manifest+json
  Cache-Control: public, max-age=86400, must-revalidate


/_astro/*
  Cache-Control: public, max-age=31536000, immutable

/media/*
  Cache-Control: public, max-age=31536000, immutable

/og/*
  Cache-Control: public, max-age=604800, stale-while-revalidate=86400

/favicon-192x192.png
  Content-Type: image/png
  Cache-Control: public, max-age=604800, stale-while-revalidate=86400

/favicon-512x512.png
  Content-Type: image/png
  Cache-Control: public, max-age=604800, stale-while-revalidate=86400
